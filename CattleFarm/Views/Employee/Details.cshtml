@model CattleFarm.ViewModels.EmployeeViewModel
@{
    ViewData["Title"] = $"Employee Profile: {Model.FullName}";
    bool isAdminOrOwner = User.IsInRole("Admin") || User.IsInRole("Owner");
    var initials = string.Join("", Model.FullName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(w => w[0])).ToUpper();
    if (string.IsNullOrEmpty(initials) && !string.IsNullOrEmpty(Model.Username))
    {
        initials = Model.Username.Substring(0, Math.Min(2, Model.Username.Length)).ToUpper();
    }
}

<div class="page-header">
    <div>
        <h1 class="page-title">Profile Details</h1>
        <p class="page-subtitle">Personal and professional details of @Model.FullName</p>
    </div>
    <div style="display:flex;gap:10px">
        <a href="/Employee" class="btn btn-outline">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
        @if (isAdminOrOwner)
        {
            <a href="/Employee/Edit/@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Edit Profile
            </a>
        }
    </div>
</div>

<div style="display:grid;grid-template-columns: 280px 1fr;gap:24px;align-items:start">
    @* Left column - Avatar and Status Summary *@
    <div class="card" style="text-align:center;padding:24px 16px">
        <div style="width:96px;height:96px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:800;color:var(--primary);margin:0 auto 16px">
            @initials
        </div>
        <h2 style="font-size:18px;font-weight:700;margin-bottom:4px">@Model.FullName</h2>
        <p style="font-size:13px;color:var(--text-muted);font-family:monospace;margin-bottom:16px">@@@Model.Username</p>
        
        <div style="border-top:1px solid var(--border);padding-top:16px;margin-top:8px">
            <span class="badge @(Model.IsActive ? "badge-success" : "badge-gray")" style="padding:6px 12px;font-size:12px">
                @(Model.IsActive ? "Active Staff" : "Inactive / Suspended")
            </span>
        </div>
    </div>

    @* Right column - Information Groups *@
    <div class="card" style="padding:24px">
        <h3 style="font-size:16px;font-weight:700;border-bottom:1px solid var(--border);padding-bottom:10px;margin-bottom:20px;display:flex;align-items:center;gap:8px">
            <i class="bi bi-briefcase text-primary"></i> Employment & Role Details
        </h3>

        <div style="display:grid;grid-template-columns:repeat(2, 1fr);gap:20px;margin-bottom:32px">
            <div>
                <label style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);display:block;margin-bottom:4px">Designation</label>
                <div style="font-weight:600">@(string.IsNullOrEmpty(Model.Designation) ? "Worker" : Model.Designation)</div>
            </div>
            <div>
                <label style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);display:block;margin-bottom:4px">Department</label>
                <div style="font-weight:600">@(string.IsNullOrEmpty(Model.Department) ? "Operations / Field work" : Model.Department)</div>
            </div>
            <div>
                <label style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);display:block;margin-bottom:4px">Base Salary</label>
                <div style="font-weight:700;font-size:16px;color:var(--primary)">@Currency.Format(Model.BaseSalary)</div>
            </div>
            <div>
                <label style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);display:block;margin-bottom:4px">Date of Hire</label>
                <div style="font-weight:600">@Model.HiredAt.ToString("MMMM dd, yyyy")</div>
            </div>
        </div>

        <h3 style="font-size:16px;font-weight:700;border-bottom:1px solid var(--border);padding-bottom:10px;margin-bottom:20px;display:flex;align-items:center;gap:8px">
            <i class="bi bi-telephone text-primary"></i> Contact & Communication
        </h3>

        <div style="display:grid;grid-template-columns:repeat(2, 1fr);gap:20px">
            <div>
                <label style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);display:block;margin-bottom:4px">Email Address</label>
                <div style="font-weight:600"><a href="mailto:@Model.Email" style="color:inherit">@Model.Email</a></div>
            </div>
            <div>
                <label style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);display:block;margin-bottom:4px">Phone Number</label>
                <div style="font-weight:600">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber)</div>
            </div>
        </div>

        @if (ViewBag.DailyAttendances != null)
        {
            var dailyAttendances = ViewBag.DailyAttendances as List<CattleFarm.Models.Attendance>;
            <h3 style="font-size:16px;font-weight:700;border-bottom:1px solid var(--border);padding-bottom:10px;margin-top:32px;margin-bottom:20px;display:flex;align-items:center;gap:8px">
                <i class="bi bi-calendar-check text-primary"></i> Recent Attendance (Last 10 Days)
            </h3>
            
            if (dailyAttendances == null || !dailyAttendances.Any())
            {
                <div class="empty-state" style="padding:20px;text-align:center;border:1px dashed var(--border);border-radius:var(--radius-md)">
                    <p style="color:var(--text-muted);font-size:13.5px;margin:0">No attendance records found for this worker</p>
                </div>
            }
            else
            {
                <div class="table-wrapper" style="border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden;">
                    <table class="data-table" style="width:100%; border-collapse:collapse; font-size:13.5px">
                        <thead>
                            <tr style="background:#f8fafc; border-bottom:1px solid var(--border)">
                                <th style="text-align:left; padding:12px">Date</th>
                                <th style="text-align:left; padding:12px">Status</th>
                                <th style="text-align:left; padding:12px">Marked By</th>
                                <th style="text-align:left; padding:12px">Marked At</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in dailyAttendances)
                            {
                                var statusBadgeClass = a.Status switch
                                {
                                    "Present" => "badge-success",
                                    "Late" => "badge-warning",
                                    "Absent" => "badge-danger",
                                    _ => "badge-gray"
                                };
                                <tr style="border-bottom:1px solid var(--border)">
                                    <td style="font-weight:600; padding:12px">@a.Date.ToString("MMM dd, yyyy")</td>
                                    <td style="padding:12px"><span class="badge @statusBadgeClass">@a.Status</span></td>
                                    <td style="padding:12px">@(a.MarkedByUser?.FullName ?? "System")</td>
                                    <td style="padding:12px; color:var(--text-muted)">@a.MarkedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>
</div>
