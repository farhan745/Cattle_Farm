@model CattleFarm.ViewModels.EmployeeViewModel
@inject CattleFarm.Services.Interfaces.ICurrencyService Currency
@{
    ViewData["Title"] = $"Delete Employee: {Model.FullName}";
}

<div class="page-header">
    <div>
        <h1 class="page-title">🗑️ Delete Employee Profile</h1>
        <p class="page-subtitle">Permanently delete or suspend this employee profile from the system</p>
    </div>
    <a href="/Employee" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Back to List</a>
</div>

<div style="max-width:560px">
    <div class="card" style="border:1.5px solid rgba(239,68,68,.35)">
        <div class="card-body" style="display:flex;flex-direction:column;gap:20px">

            <div style="display:flex;align-items:center;gap:14px;padding:16px;background:rgba(239,68,68,.06);border-radius:10px;border:1px solid rgba(239,68,68,.2)">
                <div style="font-size:36px">⚠️</div>
                <div>
                    <div style="font-weight:700;color:#dc2626;margin-bottom:4px">Confirm Profile Deletion</div>
                    <div style="font-size:13px;color:var(--text-muted);line-height:1.4">
                        Warning: This action will permanently remove the employee user login profile and professional records. This cannot be undone.
                    </div>
                </div>
            </div>

            <div style="display:flex;flex-direction:column;gap:12px;padding:16px;background:var(--bg);border-radius:10px;border:1px solid var(--border)">
                <div style="display:flex;justify-content:space-between">
                    <span style="font-size:12px;color:var(--text-muted);font-weight:600">FULL NAME</span>
                    <span style="font-weight:700">@Model.FullName</span>
                </div>
                <div style="display:flex;justify-content:space-between">
                    <span style="font-size:12px;color:var(--text-muted);font-weight:600">USERNAME</span>
                    <span style="font-family:monospace;font-weight:600">@@@Model.Username</span>
                </div>
                <div style="display:flex;justify-content:space-between">
                    <span style="font-size:12px;color:var(--text-muted);font-weight:600">DESIGNATION</span>
                    <span style="font-weight:600"><span class="badge badge-info">@(string.IsNullOrEmpty(Model.Designation) ? "Worker" : Model.Designation)</span></span>
                </div>
                <div style="display:flex;justify-content:space-between">
                    <span style="font-size:12px;color:var(--text-muted);font-weight:600">DEPARTMENT</span>
                    <span>@(string.IsNullOrEmpty(Model.Department) ? "—" : Model.Department)</span>
                </div>
                <div style="display:flex;justify-content:space-between">
                    <span style="font-size:12px;color:var(--text-muted);font-weight:600">BASE SALARY</span>
                    <span style="font-weight:700;color:var(--primary)">@Currency.Format(Model.BaseSalary)</span>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:flex;gap:10px">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn" style="flex:1;background:#ef4444;color:#fff;border-color:#ef4444">
                    <i class="bi bi-trash"></i> Yes, Delete Profile
                </button>
                <a href="/Employee" class="btn btn-outline" style="flex:1;text-align:center">Cancel</a>
            </form>

        </div>
    </div>
</div>
