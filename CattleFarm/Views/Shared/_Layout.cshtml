<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Smart Cattle Farm</title>
    <meta name="description" content="Smart Cattle Farm Management System — livestock tracking, health records, milk production, and farm analytics." />
    <link rel="icon" href="~/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

        <div class="app-shell">
            <!-- SIDEBAR -->
            <nav class="sidebar" id="sidebar">
                <!-- Brand -->
                <div class="sidebar-brand">
                    <div class="brand-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <div>
                        <div class="brand-name">Smart Cattle Farm</div>
                        <div class="brand-sub">Management System</div>
                    </div>
                </div>

                <!-- Navigation -->
                <div class="sidebar-nav">
                    <div class="nav-section">Overview</div>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" href="/Dashboard">
                        <i class="bi bi-grid-1x2 nav-icon"></i> Dashboard
                    </a>

                    @if (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager"))
                    {
                        <div class="nav-section">Farm Management</div>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Farm" ? "active" : "")" href="/Farm">
                            <i class="bi bi-house-door nav-icon"></i> Farms
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cattle" ? "active" : "")" href="/Cattle">
                            <i class="bi bi-geo-alt nav-icon"></i> Cattle
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Worker" ? "active" : "")" href="/Worker">
                            <i class="bi bi-people nav-icon"></i> Workers
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "MilkProduction" ? "active" : "")" href="/MilkProduction">
                            <i class="bi bi-droplet nav-icon"></i> Milk Production
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Breeding" ? "active" : "")" href="/Breeding">
                            <i class="bi bi-diagram-2 nav-icon"></i> Breeding
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Feed" ? "active" : "")" href="/Feed">
                            <i class="bi bi-box2 nav-icon"></i> Feed Management
                        </a>
                    }

                    <div class="nav-section">Health</div>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Health" ? "active" : "")" href="/Health">
                        <i class="bi bi-heart-pulse nav-icon"></i> Health Records
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctor" ? "active" : "")" href="/Doctor">
                        <i class="bi bi-person-badge nav-icon"></i> Veterinarians
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointment" ? "active" : "")" href="/Appointment">
                        <i class="bi bi-calendar-check nav-icon"></i> Appointments
                    </a>

                    <div class="nav-section">Commerce</div>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")" href="/Product">
                        <i class="bi bi-box-seam nav-icon"></i> Products
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")" href="/Order">
                        <i class="bi bi-receipt nav-icon"></i> Orders
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cattle" && ViewContext.RouteData.Values["action"]?.ToString() == "Marketplace" ? "active" : "")" href="/Cattle/Marketplace">
                        <i class="bi bi-shop nav-icon"></i> Marketplace
                    </a>

                    @if (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager"))
                    {
                        <div class="nav-section">Finance</div>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Financial" ? "active" : "")" href="/Financial">
                            <i class="bi bi-bar-chart-line nav-icon"></i> Financials
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")" href="/Reports">
                            <i class="bi bi-file-earmark-bar-graph nav-icon"></i> Reports
                        </a>
                    }

                    <div class="nav-section">My Account</div>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Subscription" ? "active" : "")" href="/Subscription">
                        <i class="bi bi-star nav-icon"></i> My Plan
                        @{
                            var subType = User.FindFirst("SubscriptionType")?.Value ?? "";
                            if (!string.IsNullOrEmpty(subType) && subType != "Free")
                            { <span class="nav-badge">@subType</span> }
                        }
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" && ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")" href="/Account/Profile">
                        <i class="bi bi-person-circle nav-icon"></i> My Profile
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="nav-section">Administration</div>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")" href="/Admin/Users">
                            <i class="bi bi-people-fill nav-icon"></i> Users
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Farms" ? "active" : "")" href="/Admin/Farms">
                            <i class="bi bi-check2-circle nav-icon"></i> Approvals
                        </a>
                        <a class="nav-item" href="/Admin/Subscriptions">
                            <i class="bi bi-credit-card nav-icon"></i> Subscriptions
                        </a>
                        <a class="nav-item" href="/Admin/AuditLogs">
                            <i class="bi bi-journal-text nav-icon"></i> Audit Logs
                        </a>
                        <a class="nav-item" href="/UserManagement">
                            <i class="bi bi-sliders nav-icon"></i> User Management
                        </a>
                    }

                    <div class="nav-section">Alerts</div>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "active" : "")" href="/Notification" id="notif-link">
                        <i class="bi bi-bell nav-icon"></i> Notifications
                        <span class="nav-badge" id="notif-count" style="display:none"></span>
                    </a>
                </div>

                <!-- Sidebar Footer -->
                <div class="sidebar-footer">
                    <div class="sidebar-user">
                        @{
                            var profileImg   = User.FindFirst("ProfileImage")?.Value;
                            var sideInitials = (User.Identity?.Name ?? "U").Substring(0, Math.Min(2, (User.Identity?.Name ?? "U").Length)).ToUpper();
                        }
                        @if (!string.IsNullOrEmpty(profileImg))
                        {
                            <img src="@profileImg" id="sidebarAvatar" alt="Avatar" style="border-radius:50%;object-fit:cover;width:32px;height:32px" />
                        }
                        else
                        {
                            <div style="width:32px;height:32px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0">@sideInitials</div>
                        }
                        <div class="user-info flex-1">
                            <div class="user-name">@User.Identity?.Name</div>
                            <div class="user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                        </div>
                        <form method="post" asp-controller="Account" asp-action="Logout" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" title="Sign Out" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:15px;padding:0;display:flex;align-items:center">
                                <i class="bi bi-box-arrow-right"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </nav>

            <!-- MAIN CONTENT -->
            <div class="main-content">
                <!-- Top Header -->
                <header class="top-header">
                    <button class="header-btn" id="sidebarToggle" onclick="toggleSidebar()" aria-label="Toggle sidebar">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="header-search">
                        <span class="search-icon"><i class="bi bi-search"></i></span>
                        <input type="search" placeholder="Search cattle, farms, workers..." id="globalSearch" />
                    </div>
                    <div class="header-actions">
                        <!-- Theme toggle -->
                        <button class="header-btn" id="themeToggle" title="Toggle theme" onclick="toggleTheme()">
                            <i class="bi bi-moon" id="themeIcon"></i>
                        </button>
                        <!-- Notifications -->
                        <a class="header-btn" href="/Notification" title="Notifications" aria-label="View notifications">
                            <i class="bi bi-bell"></i>
                            <span class="badge" id="header-notif-count" style="display:none"></span>
                        </a>
                        <!-- User Menu -->
                        <div class="header-user" style="cursor:pointer" onclick="window.location='/Account/Profile'" title="My Profile">
                            @{
                                var hProfileImg = User.FindFirst("ProfileImage")?.Value;
                                var hInitials   = (User.Identity?.Name ?? "U").Substring(0, Math.Min(2, (User.Identity?.Name ?? "U").Length)).ToUpper();
                            }
                            @if (!string.IsNullOrEmpty(hProfileImg))
                            {
                                <img src="@hProfileImg" id="navAvatar" alt="Avatar" style="width:26px;height:26px;border-radius:50%;object-fit:cover" />
                            }
                            else
                            {
                                <div id="navAvatar" style="width:26px;height:26px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff">@hInitials</div>
                            }
                            <span>@User.Identity?.Name</span>
                            <form method="post" asp-controller="Account" asp-action="Logout" style="display:inline" onclick="event.stopPropagation()">
                                @Html.AntiForgeryToken()
                                <button type="submit" title="Sign Out" style="background:none;border:none;cursor:pointer;padding:0;display:flex;align-items:center;color:var(--text-muted)">
                                    <i class="bi bi-box-arrow-right"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </header>

                <!-- Toast Notifications -->
                <div class="toast-container" id="toastContainer"></div>

                <!-- Flash Messages -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div style="padding: 0 24px; margin-top: 14px;">
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle-fill"></i>
                            <span>@TempData["SuccessMessage"]</span>
                            <button onclick="this.parentElement.remove()" style="margin-left:auto;background:none;border:none;cursor:pointer;color:inherit;font-size:14px">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div style="padding: 0 24px; margin-top: 14px;">
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>@TempData["ErrorMessage"]</span>
                            <button onclick="this.parentElement.remove()" style="margin-left:auto;background:none;border:none;cursor:pointer;color:inherit;font-size:14px">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                }

                <!-- Page Body -->
                <main class="page-content" role="main">
                    @RenderBody()
                </main>

                <footer style="padding:14px 24px;border-top:1px solid var(--border);font-size:12px;color:var(--text-muted);display:flex;justify-content:space-between;align-items:center;">
                    <span>&copy; @DateTime.Now.Year Smart Cattle Farm Management System</span>
                    <span>v2.1 Enterprise</span>
                </footer>
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Sidebar toggle
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('open');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('open');
        }

        // Theme toggle
        function toggleTheme() {
            const html = document.documentElement;
            const isDark = html.getAttribute('data-theme') === 'dark';
            html.setAttribute('data-theme', isDark ? 'light' : 'dark');
            document.getElementById('themeIcon').className = isDark ? 'bi bi-moon' : 'bi bi-sun';
            localStorage.setItem('theme', isDark ? 'light' : 'dark');
        }
        (function () {
            const saved = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', saved);
            const icon = document.getElementById('themeIcon');
            if (icon) icon.className = saved === 'dark' ? 'bi bi-sun' : 'bi bi-moon';
        })();

        // Scroll animation observer
        const observer = new IntersectionObserver(entries => {
            entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.animate-in').forEach(el => observer.observe(el));

        // Notification badge
        async function loadNotifCount() {
            try {
                const r = await fetch('/Notification/UnreadCount');
                if (!r.ok) return;
                const data = await r.json();
                const count = data.count || 0;
                ['notif-count', 'header-notif-count'].forEach(id => {
                    const el = document.getElementById(id);
                    if (!el) return;
                    el.style.display = count > 0 ? 'flex' : 'none';
                    el.textContent = count > 9 ? '9+' : count;
                });
            } catch {}
        }
        loadNotifCount();
        setInterval(loadNotifCount, 60000);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
