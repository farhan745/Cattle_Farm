@model IEnumerable<CattleFarm.Models.User>
@{
    ViewData["Title"] = "User Management";
    var availableRoles = ViewBag.AvailableRoles as IReadOnlyList<string> ?? new List<string>();
    var currentUserId  = (int)ViewBag.CurrentUserId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="bi bi-people-fill text-primary me-2"></i>User Management
    </h2>
    <span class="badge bg-secondary fs-6">@Model.Count() user(s)</span>
</div>

@* ── Flash messages ─────────────────────────────────────────────────── *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Role Legend ────────────────────────────────────────────────────── *@
<div class="d-flex gap-2 mb-3 flex-wrap">
    <span class="badge bg-danger fs-6 px-3 py-2">🔴 Admin</span>
    <span class="badge bg-warning text-dark fs-6 px-3 py-2">🟡 Manager</span>
    <span class="badge bg-secondary fs-6 px-3 py-2">⚪ User</span>
</div>

@* ── User Table ─────────────────────────────────────────────────────── *@
<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        <i class="bi bi-table"></i> All Registered Users
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="usersTable">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th><i class="bi bi-person me-1"></i>Username</th>
                    <th><i class="bi bi-envelope me-1"></i>Email</th>
                    <th><i class="bi bi-shield me-1"></i>Current Role</th>
                    <th><i class="bi bi-calendar3 me-1"></i>Joined</th>
                    <th class="text-center">Change Role</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.OrderBy(u => u.CreatedAt))
                {
                    var isSelf = user.Id == currentUserId;

                    <tr class="@(isSelf ? "table-active" : "")">
                        <td class="text-muted small">@user.Id</td>
                        <td>
                            <strong>@user.Username</strong>
                            @if (isSelf)
                            {
                                <span class="badge bg-info ms-1">You</span>
                            }
                        </td>
                        <td class="text-muted">@user.Email</td>
                        <td>
                            @{
                                var badgeClass = user.Role switch
                                {
                                    AppRoles.Admin   => "bg-danger",
                                    AppRoles.Manager => "bg-warning text-dark",
                                    _                => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass px-3 py-2">@user.Role</span>
                        </td>
                        <td class="text-muted small">
                            @user.CreatedAt.ToString("dd MMM yyyy")
                        </td>
                        <td class="text-center">
                            @if (isSelf)
                            {
                                <span class="text-muted small fst-italic">Cannot change own role</span>
                            }
                            else
                            {
                                <form asp-controller="UserManagement"
                                      asp-action="ChangeRole"
                                      method="post"
                                      class="d-flex gap-2 justify-content-center"
                                      id="roleForm-@user.Id">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="UserId" value="@user.Id" />

                                    <select name="NewRole"
                                            class="form-select form-select-sm"
                                            style="width: auto; min-width: 120px"
                                            id="roleSelect-@user.Id">
                                        @foreach (var role in availableRoles)
                                        {
                                            if (role == user.Role)
                                            {
                                                <option value="@role" selected>@role</option>
                                            }
                                            else
                                            {
                                                <option value="@role">@role</option>
                                            }
                                        }
                                    </select>

                                    <button type="submit"
                                            class="btn btn-primary btn-sm"
                                            id="applyRoleBtn-@user.Id"
                                            title="Apply role change">
                                        <i class="bi bi-check-lg"></i> Apply
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3 text-muted small">
    <i class="bi bi-info-circle me-1"></i>
    You cannot change your own role. Role changes take effect on the user's next login.
</div>
