@model IEnumerable<CattleFarm.Models.MilkProduction>
@{
    ViewData["Title"] = "Milk Production";
    double totalToday  = (double)(ViewData["TotalToday"]  ?? 0.0);
    double totalMonth  = (double)(ViewData["TotalMonth"]  ?? 0.0);
    int    currentPage = (int)(ViewData["CurrentPage"]    ?? 1);
    int    totalPages  = (int)(ViewData["TotalPages"]     ?? 1);
}

<div class="page-header">
    <div><h1 class="page-title">🥛 Milk Production</h1><p class="page-subtitle">Daily yield tracking and production analytics</p></div>
    <div class="page-actions">
        <a href="/MilkProduction/Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Log Yield</a>
    </div>
</div>

<!-- KPIs -->
<div class="stat-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:20px">
    <div class="stat-card blue">
        <div class="stat-icon blue">🥛</div>
        <div><div class="stat-value">@totalToday.ToString("F1")<span style="font-size:14px;font-weight:400">L</span></div><div class="stat-label">Today's Total Yield</div></div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon green">📅</div>
        <div><div class="stat-value">@totalMonth.ToString("F0")<span style="font-size:14px;font-weight:400">L</span></div><div class="stat-label">This Month's Total</div></div>
    </div>
    <div class="stat-card amber">
        <div class="stat-icon amber">📈</div>
        <div><div class="stat-value">@(Model.Any() ? (Model.Average(m => m.MorningYieldLiters + m.EveningYieldLiters)).ToString("F1") : "0.0")<span style="font-size:14px;font-weight:400">L</span></div><div class="stat-label">Avg Per Record</div></div>
    </div>
</div>

<!-- Chart -->
<div class="card" style="margin-bottom:20px">
    <div class="card-header"><h3 class="card-title">📊 Production Trend (Last 14 Days)</h3></div>
    <div class="card-body"><div class="chart-container" style="height:220px"><canvas id="milkTrendChart"></canvas></div></div>
</div>

<!-- Log Form + Table -->
<div style="display:grid;grid-template-columns:320px 1fr;gap:20px;align-items:start">
    <!-- Quick Log -->
    <div class="card">
        <div class="card-header"><h3 class="card-title">➕ Quick Log</h3></div>
        <div class="card-body">
            <form method="post" asp-action="Create">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Cattle</label>
                    <select name="CattleId" class="form-control" required>
                        <option value="">Select cattle...</option>
                        @foreach (var c in (IEnumerable<CattleFarm.Models.Cattle>)ViewBag.Cattles)
                        { <option value="@c.Id">@c.Name (@c.TagId)</option> }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Farm</label>
                    <select name="FarmId" class="form-control" required>
                        <option value="">Select farm...</option>
                        @foreach (var f in (IEnumerable<CattleFarm.Models.Farm>)ViewBag.Farms)
                        { <option value="@f.Id">@f.Name</option> }
                    </select>
                </div>
                <div class="form-group"><label class="form-label">Date</label><input name="Date" class="form-control" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" required /></div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                    <div class="form-group"><label class="form-label">Morning (L)</label><input name="MorningYieldLiters" class="form-control" type="number" step="0.1" placeholder="0.0" /></div>
                    <div class="form-group"><label class="form-label">Evening (L)</label><input name="EveningYieldLiters" class="form-control" type="number" step="0.1" placeholder="0.0" /></div>
                </div>
                <div class="form-group"><label class="form-label">Notes</label><input name="Notes" class="form-control" placeholder="Optional notes..." /></div>
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-circle"></i> Log Yield</button>
            </form>
        </div>
    </div>

    <!-- Records Table -->
    <div class="card">
        <div class="card-header"><h3 class="card-title">📋 Recent Records</h3></div>
        <div class="table-wrapper">
            @if (!Model.Any())
            { <div class="empty-state" style="padding:30px"><div class="empty-icon">🥛</div><p>No records yet</p></div> }
            else
            {
                <table class="data-table">
                    <thead><tr><th>Date</th><th>Cattle</th><th>Farm</th><th>Morning</th><th>Evening</th><th>Total</th><th>Notes</th></tr></thead>
                    <tbody>
                        @foreach (var m in Model)
                        {
                            var total = m.MorningYieldLiters + m.EveningYieldLiters;
                            <tr>
                                <td style="font-size:12px;white-space:nowrap">@m.Date.ToString("MMM dd, yyyy")</td>
                                <td><a href="/Cattle/Details/@m.CattleId" style="font-weight:600">@(m.Cattle?.Name ?? "—")</a></td>
                                <td style="font-size:12px">@(m.Farm?.Name ?? "—")</td>
                                <td style="color:var(--info);font-weight:600">@m.MorningYieldLiters.ToString("F1")L</td>
                                <td style="color:var(--primary);font-weight:600">@m.EveningYieldLiters.ToString("F1")L</td>
                                <td style="font-weight:800;color:var(--text-primary)">@total.ToString("F1")L</td>
                                <td style="font-size:11px;color:var(--text-muted);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@(m.Notes ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (totalPages > 1)
                {
                    <div style="padding:12px;display:flex;justify-content:center">
                        <div class="pagination" style="padding:0">
                            @if (currentPage>1){<a href="?page=@(currentPage-1)" class="page-link"><i class="bi bi-chevron-left"></i></a>}
                            @for(int i=Math.Max(1,currentPage-2);i<=Math.Min(totalPages,currentPage+2);i++){<a href="?page=@i" class="page-link @(i==currentPage?"active":"")">@i</a>}
                            @if(currentPage<totalPages){<a href="?page=@(currentPage+1)" class="page-link"><i class="bi bi-chevron-right"></i></a>}
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
const mlabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((IEnumerable<string>)ViewBag.TrendDates)));
const mdata   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((IEnumerable<double>)ViewBag.TrendYields)));
new Chart(document.getElementById('milkTrendChart'), {
    type: 'bar',
    data: { labels: mlabels, datasets: [{ label: 'Yield (L)', data: mdata, backgroundColor: 'rgba(59,130,246,.7)', borderRadius: 4 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true }, x: { grid: { display: false } } } }
});
</script>
}
