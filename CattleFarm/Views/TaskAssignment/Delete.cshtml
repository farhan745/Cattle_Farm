@model CattleFarm.ViewModels.TaskViewModel
@{
    ViewData["Title"] = $"Delete Task Assignment: {Model.Title}";
}

<div class="page-header">
    <div>
        <h1 class="page-title">⚠️ Delete Task Assignment</h1>
        <p class="page-subtitle">Are you sure you want to delete this task assignment?</p>
    </div>
    <div>
        <a href="/TaskAssignment/Details/@Model.Id" class="btn btn-outline">
            <i class="bi bi-arrow-left"></i> Cancel & Back
        </a>
    </div>
</div>

<div style="max-width:600px;margin:0 auto">
    <div class="card" style="padding:28px;border-color:var(--danger)">
        @* Danger Warning Header *@
        <div style="text-align:center;margin-bottom:24px">
            <div style="font-size:48px;color:var(--danger);line-height:1;margin-bottom:12px">⚠️</div>
            <h2 style="font-size:18px;font-weight:800;margin:0 0 6px">Permanent Deletion</h2>
            <p style="font-size:13.5px;color:var(--text-muted);margin:0">This action cannot be undone. The task assignment will be permanently removed.</p>
        </div>

        @* Task Summary *@
        <div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:20px;margin-bottom:28px">
            <div style="margin-bottom:14px">
                <label style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);display:block;margin-bottom:2px">Task Title</label>
                <div style="font-weight:700;font-size:15px">@Model.Title</div>
            </div>

            <div style="margin-bottom:14px">
                <label style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);display:block;margin-bottom:2px">Assigned To</label>
                <div style="font-weight:600">@Model.WorkerName</div>
            </div>

            <div>
                <label style="font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);display:block;margin-bottom:2px">Due Date</label>
                <div style="font-weight:600">@Model.DueDate.ToString("MMMM dd, yyyy")</div>
            </div>
        </div>

        @* Delete Form *@
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div style="display:flex;justify-content:end;gap:12px;border-top:1px solid var(--border);padding-top:20px">
                <a href="/TaskAssignment/Details/@Model.Id" class="btn btn-outline">Cancel</a>
                <button type="submit" class="btn btn-primary" style="background:var(--danger);border-color:var(--danger);color:#fff">
                    <i class="bi bi-trash"></i> Yes, Delete Assignment
                </button>
            </div>
        </form>
    </div>
</div>
