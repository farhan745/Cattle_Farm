@model IEnumerable<CattleFarm.ViewModels.TaskViewModel>
@{
    ViewData["Title"] = "Task Assignments";
    var tasks = Model.ToList();
    var totalTasks = tasks.Count;
    var pendingTasks = tasks.Count(t => t.Status == "Pending");
    var inProgressTasks = tasks.Count(t => t.Status == "InProgress");
    var completedTasks = tasks.Count(t => t.Status == "Completed");
    bool isStaffManager = User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager");
    bool isWorker = User.IsInRole("Worker");
}

@section Styles {
<style>
    .task-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .task-stat-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
        transition: transform .2s, box-shadow .2s;
    }

    .task-stat-card:hover { 
        transform: translateY(-2px); 
        box-shadow: 0 6px 20px rgba(0,0,0,.08); 
    }

    .task-stat-icon {
        width: 44px; height: 44px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .task-stat-value { font-size: 24px; font-weight: 800; line-height: 1; }
    .task-stat-label { font-size: 12px; color: var(--text-muted); margin-top: 3px; }

    .filter-bar {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
        padding: 14px 18px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: 16px;
    }

    .filter-bar input, .filter-bar select {
        padding: 8px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--bg);
        color: var(--text);
        font-size: 13px;
        font-family: inherit;
    }

    .filter-bar input:focus, .filter-bar select:focus {
        outline: none;
        border-color: var(--primary);
    }

    /* ── Worker Kanban Board ─────────────────────────── */
    .kanban-board {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 8px;
    }

    .kanban-column {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 0;
        overflow: hidden;
    }

    .kanban-column-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 18px;
        font-weight: 700;
        font-size: 13px;
        letter-spacing: .4px;
        border-bottom: 2px solid var(--border);
    }

    .kanban-column-header .col-badge {
        min-width: 22px;
        height: 22px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 800;
    }

    .kanban-column-header.pending-header  { color: #ef4444; border-color: #ef4444; background: rgba(239,68,68,.05); }
    .kanban-column-header.doing-header    { color: #f59e0b; border-color: #f59e0b; background: rgba(245,158,11,.05); }
    .kanban-column-header.done-header     { color: #10b981; border-color: #10b981; background: rgba(16,185,129,.05); }

    .col-badge.pending-badge  { background: rgba(239,68,68,.15);  color: #ef4444; }
    .col-badge.doing-badge    { background: rgba(245,158,11,.15); color: #f59e0b; }
    .col-badge.done-badge     { background: rgba(16,185,129,.15); color: #10b981; }

    .kanban-cards {
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-height: 120px;
    }

    .kanban-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 14px 16px;
        box-shadow: 0 1px 4px rgba(0,0,0,.04);
        transition: box-shadow .2s, transform .15s;
    }

    .kanban-card:hover {
        box-shadow: 0 4px 14px rgba(0,0,0,.1);
        transform: translateY(-1px);
    }

    .kanban-card.overdue {
        border-left: 3px solid #ef4444;
    }

    .kanban-card-title {
        font-weight: 700;
        font-size: 14px;
        margin-bottom: 6px;
        line-height: 1.3;
    }

    .kanban-card-desc {
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 10px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .kanban-card-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 11px;
        color: var(--text-muted);
        margin-bottom: 12px;
    }

    .kanban-card-meta .due-overdue {
        color: #ef4444;
        font-weight: 600;
    }

    .kanban-card-actions {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .status-select-worker {
        flex: 1;
        padding: 5px 10px;
        font-size: 12px;
        border-radius: 7px;
        border: 1px solid var(--border);
        background: var(--card-bg);
        color: var(--text);
        cursor: pointer;
        font-family: inherit;
    }

    .status-select-worker:focus {
        outline: none;
        border-color: var(--primary);
    }

    .btn-submit-status {
        padding: 5px 12px;
        font-size: 12px;
        border-radius: 7px;
        background: var(--primary);
        color: #fff;
        border: none;
        cursor: pointer;
        font-weight: 600;
        white-space: nowrap;
        transition: opacity .2s;
    }

    .btn-submit-status:hover { opacity: .85; }

    .kanban-empty {
        text-align: center;
        padding: 28px 16px;
        color: var(--text-muted);
        font-size: 12px;
    }

    .kanban-empty-icon { font-size: 28px; margin-bottom: 8px; }

    /* Toast notification */
    #toast {
        position: fixed;
        bottom: 28px;
        right: 28px;
        background: #10b981;
        color: #fff;
        padding: 12px 22px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        box-shadow: 0 4px 16px rgba(0,0,0,.18);
        opacity: 0;
        transform: translateY(10px);
        transition: opacity .3s, transform .3s;
        z-index: 9999;
        pointer-events: none;
    }

    #toast.show {
        opacity: 1;
        transform: translateY(0);
    }
</style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">📋 Task Assignments</h1>
        <p class="page-subtitle">
            @if (isWorker)
            { <text>Your daily task board — update your progress below</text> }
            else
            { <text>Track and assign farm operations duties</text> }
        </p>
    </div>
    <div>
        @if (isStaffManager)
        {
            <a href="/TaskAssignment/Assign" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Assign New Task
            </a>
        }
    </div>
</div>

@* ── Stats Row ────────────────────────────────────────────── *@
<div class="task-stats-grid">
    <div class="task-stat-card">
        <div class="task-stat-icon" style="background:rgba(99,102,241,.12)"><i class="bi bi-list-task" style="color:#6366f1"></i></div>
        <div>
            <div class="task-stat-value">@totalTasks</div>
            <div class="task-stat-label">Total Tasks</div>
        </div>
    </div>
    <div class="task-stat-card">
        <div class="task-stat-icon" style="background:rgba(239,68,68,.12)"><i class="bi bi-hourglass" style="color:#ef4444"></i></div>
        <div>
            <div class="task-stat-value" style="color:#ef4444">@pendingTasks</div>
            <div class="task-stat-label">Pending</div>
        </div>
    </div>
    <div class="task-stat-card">
        <div class="task-stat-icon" style="background:rgba(245,158,11,.12)"><i class="bi bi-activity" style="color:#f59e0b"></i></div>
        <div>
            <div class="task-stat-value" style="color:#f59e0b">@inProgressTasks</div>
            <div class="task-stat-label">In Progress</div>
        </div>
    </div>
    <div class="task-stat-card">
        <div class="task-stat-icon" style="background:rgba(16,185,129,.12)"><i class="bi bi-check-circle" style="color:#10b981"></i></div>
        <div>
            <div class="task-stat-value" style="color:#10b981">@completedTasks</div>
            <div class="task-stat-label">Completed</div>
        </div>
    </div>
</div>

@* ════════════════════════════════════════════════════════════
   WORKER VIEW — Kanban Taskboard
   ════════════════════════════════════════════════════════════ *@
@if (isWorker)
{
    var pendingList    = tasks.Where(t => t.Status == "Pending").OrderBy(t => t.DueDate).ToList();
    var inProgressList = tasks.Where(t => t.Status == "InProgress").OrderBy(t => t.DueDate).ToList();
    var completedList  = tasks.Where(t => t.Status == "Completed").OrderByDescending(t => t.CompletedAt).ToList();

    <div id="toast"><i class="bi bi-check-circle-fill"></i> <span id="toastMsg">Status updated!</span></div>

    <div class="kanban-board">

        @* ── Pending Column ── *@
        <div class="kanban-column">
            <div class="kanban-column-header pending-header">
                <span><i class="bi bi-hourglass me-1"></i> Pending</span>
                <span class="col-badge pending-badge">@pendingList.Count</span>
            </div>
            <div class="kanban-cards">
                @if (!pendingList.Any())
                {
                    <div class="kanban-empty">
                        <div class="kanban-empty-icon">✅</div>
                        No pending tasks
                    </div>
                }
                @foreach (var t in pendingList)
                {
                    bool overdue = t.DueDate.Date < DateTime.Today;
                    <div class="kanban-card @(overdue ? "overdue" : "")">
                        <div class="kanban-card-title">@t.Title</div>
                        @if (!string.IsNullOrWhiteSpace(t.Description))
                        {
                            <div class="kanban-card-desc">@t.Description</div>
                        }
                        <div class="kanban-card-meta">
                            <span><i class="bi bi-calendar3"></i> Due @t.DueDate.ToString("MMM dd")</span>
                            @if (overdue)
                            {
                                <span class="due-overdue"><i class="bi bi-exclamation-triangle"></i> Overdue</span>
                            }
                        </div>
                        <form asp-action="UpdateStatus" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="taskId" value="@t.Id" />
                            <div class="kanban-card-actions">
                                <select name="status" class="status-select-worker">
                                    <option value="Pending"    selected>Pending</option>
                                    <option value="InProgress">Doing</option>
                                    <option value="Completed" >Completed</option>
                                </select>
                                <button type="submit" class="btn-submit-status">
                                    <i class="bi bi-check-lg"></i> Submit
                                </button>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>

        @* ── Doing Column ── *@
        <div class="kanban-column">
            <div class="kanban-column-header doing-header">
                <span><i class="bi bi-activity me-1"></i> Doing</span>
                <span class="col-badge doing-badge">@inProgressList.Count</span>
            </div>
            <div class="kanban-cards">
                @if (!inProgressList.Any())
                {
                    <div class="kanban-empty">
                        <div class="kanban-empty-icon">🔄</div>
                        Nothing in progress
                    </div>
                }
                @foreach (var t in inProgressList)
                {
                    bool overdue = t.DueDate.Date < DateTime.Today;
                    <div class="kanban-card @(overdue ? "overdue" : "")">
                        <div class="kanban-card-title">@t.Title</div>
                        @if (!string.IsNullOrWhiteSpace(t.Description))
                        {
                            <div class="kanban-card-desc">@t.Description</div>
                        }
                        <div class="kanban-card-meta">
                            <span><i class="bi bi-calendar3"></i> Due @t.DueDate.ToString("MMM dd")</span>
                            @if (overdue)
                            {
                                <span class="due-overdue"><i class="bi bi-exclamation-triangle"></i> Overdue</span>
                            }
                        </div>
                        <form asp-action="UpdateStatus" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="taskId" value="@t.Id" />
                            <div class="kanban-card-actions">
                                <select name="status" class="status-select-worker">
                                    <option value="Pending"    >Pending</option>
                                    <option value="InProgress" selected>Doing</option>
                                    <option value="Completed"  >Completed</option>
                                </select>
                                <button type="submit" class="btn-submit-status">
                                    <i class="bi bi-check-lg"></i> Submit
                                </button>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>

        @* ── Completed Column ── *@
        <div class="kanban-column">
            <div class="kanban-column-header done-header">
                <span><i class="bi bi-check-circle me-1"></i> Completed</span>
                <span class="col-badge done-badge">@completedList.Count</span>
            </div>
            <div class="kanban-cards">
                @if (!completedList.Any())
                {
                    <div class="kanban-empty">
                        <div class="kanban-empty-icon">🏆</div>
                        No completed tasks yet
                    </div>
                }
                @foreach (var t in completedList)
                {
                    <div class="kanban-card" style="opacity:.8">
                        <div class="kanban-card-title" style="text-decoration:line-through;color:var(--text-muted)">@t.Title</div>
                        @if (!string.IsNullOrWhiteSpace(t.Description))
                        {
                            <div class="kanban-card-desc">@t.Description</div>
                        }
                        <div class="kanban-card-meta">
                            @if (t.CompletedAt.HasValue)
                            {
                                <span><i class="bi bi-check2-circle" style="color:#10b981"></i> Done @t.CompletedAt.Value.ToString("MMM dd")</span>
                            }
                            else
                            {
                                <span><i class="bi bi-check2-circle" style="color:#10b981"></i> Completed</span>
                            }
                        </div>
                        <form asp-action="UpdateStatus" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="taskId" value="@t.Id" />
                            <div class="kanban-card-actions">
                                <select name="status" class="status-select-worker">
                                    <option value="Pending"    >Pending</option>
                                    <option value="InProgress" >Doing</option>
                                    <option value="Completed"  selected>Completed</option>
                                </select>
                                <button type="submit" class="btn-submit-status" style="background:#10b981">
                                    <i class="bi bi-check-lg"></i> Submit
                                </button>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>

    </div>
}

@* ════════════════════════════════════════════════════════════
   MANAGER / ADMIN VIEW — Table (unchanged)
   ════════════════════════════════════════════════════════════ *@
else
{
    @* ── Filter Bar ── *@
    <div class="filter-bar">
        <i class="bi bi-funnel" style="color:var(--text-muted)"></i>
        <input type="text" id="searchInput" placeholder="Search tasks or workers…" oninput="filterTable()" style="min-width:240px" />
        <select id="statusFilter" onchange="filterTable()">
            <option value="">All Statuses</option>
            <option value="Pending">Pending</option>
            <option value="InProgress">In Progress</option>
            <option value="Completed">Completed</option>
        </select>
        <button class="btn btn-ghost btn-sm" onclick="clearFilters()"><i class="bi bi-x-circle"></i> Clear</button>
        <span style="margin-left:auto;font-size:12px;color:var(--text-muted)">
            Showing <strong id="visibleCount">@totalTasks</strong> of @totalTasks tasks
        </span>
    </div>

    @* ── Table ── *@
    <div class="card">
        <div class="table-wrapper">
            <table class="data-table" id="taskIndexTable">
                <thead>
                    <tr>
                        <th>Task Details</th>
                        <th>Assigned To</th>
                        <th>Assigned At</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th style="text-align:center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!tasks.Any())
                    {
                        <tr>
                            <td colspan="6" style="text-align:center;padding:48px 20px;color:var(--text-muted)">
                                <div style="font-size:48px;margin-bottom:12px">📋</div>
                                <div style="font-weight:600;margin-bottom:6px">No tasks found</div>
                                @if (isStaffManager)
                                {
                                    <a href="/TaskAssignment/Assign" class="btn btn-primary btn-sm" style="margin-top:8px">
                                        <i class="bi bi-plus-circle"></i> Assign a Task Now
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                    @foreach (var t in tasks)
                    {
                        var statusText = t.Status switch
                        {
                            "InProgress" => "In Progress",
                            _ => t.Status
                        };
                        var badgeCss = t.Status switch
                        {
                            "Pending"    => "badge-danger",
                            "InProgress" => "badge-warning",
                            "Completed"  => "badge-success",
                            _            => "badge-gray"
                        };

                        <tr data-search="@t.Title.ToLower() @t.Description?.ToLower() @(t.WorkerName?.ToLower() ?? "")"
                            data-status="@t.Status">
                            <td>
                                <div>
                                    <span style="font-weight:600;display:block">@t.Title</span>
                                    <span style="font-size:12px;color:var(--text-muted);display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden">@t.Description</span>
                                </div>
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:8px">
                                    <div style="width:28px;height:28px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:10px;color:var(--primary);flex-shrink:0">
                                        @(!string.IsNullOrWhiteSpace(t.WorkerName) ? string.Join("", t.WorkerName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper() : "W")
                                    </div>
                                    <span style="font-weight:500">@(string.IsNullOrEmpty(t.WorkerName) ? "Unassigned" : t.WorkerName)</span>
                                </div>
                            </td>
                            <td style="font-size:12px">@t.AssignedAt.ToString("MMM dd, yyyy")</td>
                            <td style="font-size:12px;font-weight:600;color:@(t.DueDate.Date < DateTime.Today && t.Status != "Completed" ? "var(--danger)" : "inherit")">
                                @t.DueDate.ToString("MMM dd, yyyy")
                                @if (t.DueDate.Date < DateTime.Today && t.Status != "Completed")
                                {
                                    <span style="color:var(--danger);font-size:10px;display:block"><i class="bi bi-exclamation-triangle"></i> Overdue</span>
                                }
                            </td>
                            <td>
                                <span class="badge @badgeCss">@statusText</span>
                            </td>
                            <td style="text-align:center">
                                <div style="display:flex;gap:6px;justify-content:center;align-items:center">
                                    <a href="/TaskAssignment/Details/@t.Id" class="btn btn-outline btn-sm" title="View details">
                                        View
                                    </a>
                                    <a href="/TaskAssignment/Edit/@t.Id" class="btn btn-ghost btn-sm" title="Edit task">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="/TaskAssignment/Delete/@t.Id" class="btn btn-ghost btn-sm" title="Delete assignment">
                                        <i class="bi bi-trash text-danger"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
    // ── Manager table filter ──────────────────────────────────
    function filterTable() {
        const search = document.getElementById('searchInput')?.value.toLowerCase() ?? '';
        const status = document.getElementById('statusFilter')?.value ?? '';
        const rows = document.querySelectorAll('#taskIndexTable tbody tr[data-search]');
        let visible = 0;

        rows.forEach(row => {
            const searchMatch = !search || row.dataset.search.includes(search);
            const statusMatch = !status || row.dataset.status === status;
            const show = searchMatch && statusMatch;
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        const vc = document.getElementById('visibleCount');
        if (vc) vc.textContent = visible;
    }

    function clearFilters() {
        const si = document.getElementById('searchInput');
        const sf = document.getElementById('statusFilter');
        if (si) si.value = '';
        if (sf) sf.value = '';
        filterTable();
    }

    // ── Worker: toast on form submit ─────────────────────────
    document.querySelectorAll('.kanban-card form').forEach(form => {
        form.addEventListener('submit', () => {
            const select = form.querySelector('select[name="status"]');
            const labels = { Pending: 'Marked as Pending', InProgress: 'Marked as Doing', Completed: 'Marked as Completed ✓' };
            showToast(labels[select?.value] ?? 'Status updated!');
        });
    });

    function showToast(msg) {
        const toast = document.getElementById('toast');
        if (!toast) return;
        document.getElementById('toastMsg').textContent = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2800);
    }
</script>
}
