@model CattleFarm.ViewModels.SubmitProofViewModel
@{
    ViewData["Title"] = "Submit Proof";
    var task = ViewBag.Task as CattleFarm.ViewModels.TaskViewModel;
}

@section Styles {
<style>
    .proof-card { max-width: 560px; margin: 0 auto; }
    .task-summary {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 18px 20px;
        margin-bottom: 24px;
        display: flex; gap: 14px; align-items: flex-start;
    }
    .task-icon { font-size: 28px; flex-shrink: 0; margin-top: 2px; }
    .upload-zone {
        border: 2px dashed var(--border);
        border-radius: 12px;
        padding: 40px 20px;
        text-align: center;
        cursor: pointer;
        transition: border-color .2s, background .2s;
    }
    .upload-zone:hover, .upload-zone.drag-over {
        border-color: var(--primary);
        background: rgba(var(--primary-rgb),.04);
    }
    .upload-preview {
        max-width: 100%; max-height: 220px;
        border-radius: 8px; margin-top: 12px;
        object-fit: cover;
    }
    .form-label { font-weight: 600; display: block; margin-bottom: 6px; font-size: 13.5px; }
    .form-input {
        width: 100%; padding: 10px 12px;
        border: 1px solid var(--border); border-radius: 8px;
        background: var(--bg); color: var(--text);
        font-family: inherit; font-size: 14px; outline: none;
    }
    .form-input:focus { border-color: var(--primary); }
</style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">📸 Submit Proof</h1>
        <p class="page-subtitle">Upload proof of completion to receive owner approval</p>
    </div>
    <a href="/TaskAssignment" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Back</a>
</div>

@if (task != null)
{
    <div class="proof-card">
        <div class="task-summary">
            <div class="task-icon">📋</div>
            <div>
                <div style="font-weight:700;font-size:15px">@task.Title</div>
                @if (!string.IsNullOrWhiteSpace(task.Description))
                {
                    <div style="font-size:13px;color:var(--text-muted);margin-top:4px">@task.Description</div>
                }
                <div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap">
                    <span class="badge badge-@(task.Priority == "Emergency" ? "danger" : task.Priority == "High" ? "danger" : task.Priority == "Medium" ? "warning" : "info")">@task.Priority</span>
                    <span style="font-size:12px;color:var(--text-muted)"><i class="bi bi-calendar3"></i> Due @task.DueDate.ToString("MMM dd, yyyy")</span>
                    @if (task.BonusAmount > 0)
                    {
                        <span style="font-size:12px;color:#059669;font-weight:700"><i class="bi bi-cash-coin"></i> ৳@task.BonusAmount.ToString("N0") bonus on approval</span>
                    }
                </div>
            </div>
        </div>

        <div class="card" style="padding:28px">
            <form asp-action="SubmitProof" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="TaskId" />

                @* ── Photo Upload ── *@
                <div style="margin-bottom:24px">
                    <label class="form-label">Proof Photo <span style="color:var(--text-muted);font-weight:400">(optional but recommended)</span></label>
                    <div class="upload-zone" id="uploadZone" onclick="document.getElementById('proofFile').click()">
                        <div id="uploadPlaceholder">
                            <i class="bi bi-cloud-arrow-up" style="font-size:32px;color:var(--primary)"></i>
                            <div style="font-weight:600;margin-top:8px">Click to upload or drag & drop</div>
                            <div style="font-size:12px;color:var(--text-muted);margin-top:4px">JPG, PNG up to 5MB</div>
                        </div>
                        <img id="previewImg" class="upload-preview" style="display:none" alt="Preview" />
                    </div>
                    <input type="file" id="proofFile" name="ProofImage" accept="image/*"
                           style="display:none" onchange="previewImage(this)" />
                </div>

                @* ── Note ── *@
                <div style="margin-bottom:28px">
                    <label class="form-label" asp-for="ProofNote">Work Note <span style="color:var(--text-muted);font-weight:400">(describe what you did)</span></label>
                    <textarea asp-for="ProofNote" class="form-input" rows="4"
                              placeholder="e.g. Cleaned barn 3, replaced bedding, checked all water troughs..."></textarea>
                </div>

                <div style="display:flex;justify-content:end;gap:12px;border-top:1px solid var(--border);padding-top:20px">
                    <a href="/TaskAssignment" class="btn btn-outline">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send-check"></i> Submit for Review
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('uploadPlaceholder').style.display = 'none';
                const img = document.getElementById('previewImg');
                img.src = e.target.result;
                img.style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    // Drag and drop
    const zone = document.getElementById('uploadZone');
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
        e.preventDefault();
        zone.classList.remove('drag-over');
        const input = document.getElementById('proofFile');
        input.files = e.dataTransfer.files;
        previewImage(input);
    });
</script>
}
