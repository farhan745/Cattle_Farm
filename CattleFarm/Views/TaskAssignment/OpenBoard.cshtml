@model CattleFarm.ViewModels.OpenTaskBoardViewModel
@{
    ViewData["Title"] = "Open Task Board";
}

@section Styles {
<style>
    .board-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 18px;
    }

    .open-task-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }
    .open-task-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(0,0,0,.1);
    }

    .card-priority-bar { height: 4px; }
    .bar-Low       { background: #6366f1; }
    .bar-Medium    { background: #f59e0b; }
    .bar-High      { background: #ef4444; }
    .bar-Emergency { background: linear-gradient(90deg,#dc2626,#f97316); }

    .card-body { padding: 18px; }
    .card-title { font-weight: 700; font-size: 15px; margin-bottom: 6px; }
    .card-desc  { font-size: 13px; color: var(--text-muted); margin-bottom: 14px;
                  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    .card-meta { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 14px; font-size: 12px; }
    .meta-chip {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 4px 10px; border-radius: 20px;
        border: 1px solid var(--border); font-weight: 600;
    }

    .chip-Emergency { background: rgba(220,38,38,.12); color: #dc2626; border-color: rgba(220,38,38,.3); }
    .chip-High      { background: rgba(239,68,68,.1);  color: #ef4444; border-color: rgba(239,68,68,.3); }
    .chip-Medium    { background: rgba(245,158,11,.1); color: #d97706; border-color: rgba(245,158,11,.3); }
    .chip-Low       { background: rgba(99,102,241,.1); color: #6366f1; border-color: rgba(99,102,241,.3); }
    .chip-bonus     { background: rgba(16,185,129,.1); color: #059669; border-color: rgba(16,185,129,.3); }
    .chip-due       { background: rgba(0,0,0,.04);     color: var(--text-muted); }

    .card-footer { padding: 14px 18px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }

    .my-tasks-section { margin-top: 36px; }
    .section-header { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
    .section-header h2 { font-size: 16px; font-weight: 700; margin: 0; }

    .active-task-row {
        display: flex; align-items: center; gap: 14px;
        padding: 14px 18px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: 10px;
    }
    .active-task-info { flex: 1; }
    .active-task-title { font-weight: 600; font-size: 14px; }
    .active-task-meta  { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

    .empty-state { text-align: center; padding: 48px 20px; color: var(--text-muted); }
    .empty-icon  { font-size: 40px; margin-bottom: 10px; }
</style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">🎯 Open Task Board</h1>
        <p class="page-subtitle">Claim available tasks — first to accept gets the job!</p>
    </div>
    <a href="/TaskAssignment" class="btn btn-outline"><i class="bi bi-list-task"></i> My Tasks</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger"><i class="bi bi-x-circle-fill me-2"></i>@TempData["ErrorMessage"]</div>
}

@* ── Open Tasks ── *@
<h2 style="font-size:15px;font-weight:700;margin-bottom:16px">
    Available Tasks
    <span style="font-size:12px;color:var(--text-muted);font-weight:500;margin-left:8px">@Model.OpenTasks.Count() open</span>
</h2>

@if (!Model.OpenTasks.Any())
{
    <div class="empty-state">
        <div class="empty-icon">✅</div>
        <div style="font-weight:600">No open tasks right now</div>
        <div style="font-size:13px;margin-top:4px">Check back later — your owner will post new tasks here.</div>
    </div>
}
else
{
    <div class="board-grid">
        @foreach (var task in Model.OpenTasks)
        {
            bool isExpiringSoon = task.ExpiresAt.HasValue && task.ExpiresAt.Value < DateTime.UtcNow.AddHours(2);
            <div class="open-task-card">
                <div class="card-priority-bar bar-@task.Priority"></div>
                <div class="card-body">
                    <div class="card-title">@task.Title</div>
                    @if (!string.IsNullOrWhiteSpace(task.Description))
                    {
                        <div class="card-desc">@task.Description</div>
                    }
                    <div class="card-meta">
                        <span class="meta-chip chip-@task.Priority">
                            @(task.Priority == "Emergency" ? "🚨" : task.Priority == "High" ? "🔴" : task.Priority == "Medium" ? "🟡" : "🔵")
                            @task.Priority
                        </span>
                        @if (task.BonusAmount > 0)
                        {
                            <span class="meta-chip chip-bonus">
                                <i class="bi bi-cash-coin"></i> ৳@task.BonusAmount.ToString("N0") Bonus
                            </span>
                        }
                        <span class="meta-chip chip-due">
                            <i class="bi bi-calendar3"></i> Due @task.DueDate.ToString("dd MMM yyyy")
                        </span>
                        @if (isExpiringSoon)
                        {
                            <span class="meta-chip" style="background:rgba(239,68,68,.1);color:#ef4444;border-color:rgba(239,68,68,.3)">
                                <i class="bi bi-clock"></i> Expires soon!
                            </span>
                        }
                    </div>
                </div>
                <div class="card-footer">
                    @if (task.ExpiresAt.HasValue)
                    {
                        <span style="font-size:11px;color:var(--text-muted)">
                            <i class="bi bi-clock"></i> Closes @task.ExpiresAt.Value.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")
                        </span>
                    }
                    else { <span></span> }
                    <form asp-action="AcceptTask" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="taskId" value="@task.Id" />
                        <button type="submit" class="btn btn-primary btn-sm"
                                onclick="return confirm('Accept task: @task.Title?')">
                            <i class="bi bi-hand-index-thumb"></i> Claim Task
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}

@* ── My Active Tasks ── *@
<div class="my-tasks-section">
    <div class="section-header">
        <h2>⚡ My Active Tasks</h2>
        <span style="font-size:12px;color:var(--text-muted)">@Model.MyActiveTasks.Count() tasks</span>
    </div>

    @if (!Model.MyActiveTasks.Any())
    {
        <div style="color:var(--text-muted);font-size:13px;padding:16px 0">
            No active tasks. Claim something from above!
        </div>
    }
    else
    {
        @foreach (var task in Model.MyActiveTasks.OrderBy(t => t.DueDate))
        {
            var badgeCss = task.Status switch
            {
                "Accepted"       => "badge-info",
                "InProgress"     => "badge-warning",
                "ProofSubmitted" => "badge-primary",
                _                => "badge-gray"
            };
            <div class="active-task-row">
                <div style="width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;background:var(--primary-light);flex-shrink:0">
                    @(task.Status == "ProofSubmitted" ? "📸" : task.Status == "InProgress" ? "⚡" : "📋")
                </div>
                <div class="active-task-info">
                    <div class="active-task-title">@task.Title</div>
                    <div class="active-task-meta">Due @task.DueDate.ToString("dd MMM yyyy") @(task.IsOverdue ? "OVERDUE" : "")</div>
                </div>
                @if (task.HasBonus)
                {
                    <span class="meta-chip chip-bonus" style="font-size:11px">৳@task.BonusAmount.ToString("N0")</span>
                }
                <span class="badge @badgeCss">@task.Status</span>
                @if (task.Status == "Accepted" || task.Status == "InProgress")
                {
                    <a href="/TaskAssignment/SubmitProof/@task.Id" class="btn btn-primary btn-sm">
                        <i class="bi bi-camera"></i> Submit Proof
                    </a>
                }
            </div>
        }
    }
</div>
