@model IEnumerable<CattleFarm.ViewModels.TaskViewModel>
@{
    ViewData["Title"] = "Task Assignments";
    var tasks = Model.ToList();
    var totalTasks      = tasks.Count;
    var openTasks       = tasks.Count(t => t.Status == "Open");
    var activeTasks     = tasks.Count(t => t.Status == "Accepted" || t.Status == "InProgress");
    var proofTasks      = tasks.Count(t => t.Status == "ProofSubmitted");
    var completedTasks  = tasks.Count(t => t.Status == "Completed");
    bool isStaffManager = User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager");
    bool isWorker       = User.IsInRole("Worker");
    bool isOwner        = User.IsInRole("Admin") || User.IsInRole("Owner");
}

@section Styles {
<style>
    /* ── Stats ── */
    .task-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .task-stat-card {
        background: var(--card-bg); border: 1px solid var(--border);
        border-radius: 12px; padding: 18px 20px;
        display: flex; align-items: center; gap: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
        transition: transform .2s, box-shadow .2s;
    }
    .task-stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.08); }
    .task-stat-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .task-stat-value { font-size: 24px; font-weight: 800; line-height: 1; }
    .task-stat-label { font-size: 12px; color: var(--text-muted); margin-top: 3px; }

    /* ── Priority chip ── */
    .pchip { display: inline-flex; align-items: center; gap: 3px; padding: 2px 8px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .pchip-Emergency { background: rgba(220,38,38,.12); color: #dc2626; }
    .pchip-High      { background: rgba(239,68,68,.1);  color: #ef4444; }
    .pchip-Medium    { background: rgba(245,158,11,.1); color: #d97706; }
    .pchip-Low       { background: rgba(99,102,241,.1); color: #6366f1; }

    /* ── Filter bar ── */
    .filter-bar {
        display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
        padding: 14px 18px; background: var(--card-bg);
        border: 1px solid var(--border); border-radius: 10px; margin-bottom: 16px;
    }
    .filter-bar input, .filter-bar select {
        padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px;
        background: var(--bg); color: var(--text); font-size: 13px; font-family: inherit; outline: none;
    }
    .filter-bar input:focus, .filter-bar select:focus { border-color: var(--primary); }

    /* ── Worker Kanban ── */
    .kanban-board { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 8px; }
    .kanban-column { background: var(--card-bg); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
    .kanban-column-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 18px; font-weight: 700; font-size: 13px;
        letter-spacing: .4px; border-bottom: 2px solid var(--border);
    }
    .kanban-column-header .col-badge { min-width: 22px; height: 22px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 800; }
    .kanban-column-header.pending-header  { color: #ef4444; border-color: #ef4444; background: rgba(239,68,68,.05); }
    .kanban-column-header.doing-header    { color: #f59e0b; border-color: #f59e0b; background: rgba(245,158,11,.05); }
    .kanban-column-header.done-header     { color: #10b981; border-color: #10b981; background: rgba(16,185,129,.05); }
    .col-badge.pending-badge  { background: rgba(239,68,68,.15);  color: #ef4444; }
    .col-badge.doing-badge    { background: rgba(245,158,11,.15); color: #f59e0b; }
    .col-badge.done-badge     { background: rgba(16,185,129,.15); color: #10b981; }
    .kanban-cards { padding: 14px; display: flex; flex-direction: column; gap: 12px; min-height: 120px; }
    .kanban-card {
        background: var(--bg); border: 1px solid var(--border);
        border-radius: 10px; padding: 14px 16px;
        box-shadow: 0 1px 4px rgba(0,0,0,.04);
        transition: box-shadow .2s, transform .15s;
    }
    .kanban-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,.1); transform: translateY(-1px); }
    .kanban-card.overdue  { border-left: 3px solid #ef4444; }
    .kanban-card-title    { font-weight: 700; font-size: 14px; margin-bottom: 6px; }
    .kanban-card-desc     { font-size: 12px; color: var(--text-muted); margin-bottom: 8px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .kanban-card-meta     { display: flex; align-items: center; justify-content: space-between; font-size: 11px; color: var(--text-muted); margin-bottom: 10px; }
    .kanban-card-meta .due-overdue { color: #ef4444; font-weight: 600; }
    .status-select-worker { flex: 1; padding: 5px 10px; font-size: 12px; border-radius: 7px; border: 1px solid var(--border); background: var(--card-bg); color: var(--text); cursor: pointer; font-family: inherit; }
    .btn-submit-status    { padding: 5px 12px; font-size: 12px; border-radius: 7px; background: var(--primary); color: #fff; border: none; cursor: pointer; font-weight: 600; transition: opacity .2s; }
    .btn-submit-status:hover { opacity: .85; }
    .kanban-empty { text-align: center; padding: 28px 16px; color: var(--text-muted); font-size: 12px; }
    .kanban-empty-icon { font-size: 28px; margin-bottom: 8px; }
    #toast { position: fixed; bottom: 28px; right: 28px; background: #10b981; color: #fff; padding: 12px 22px; border-radius: 10px; font-size: 14px; font-weight: 600; box-shadow: 0 4px 16px rgba(0,0,0,.18); opacity: 0; transform: translateY(10px); transition: opacity .3s, transform .3s; z-index: 9999; pointer-events: none; }
    #toast.show { opacity: 1; transform: translateY(0); }
</style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">📋 Task Assignments</h1>
        <p class="page-subtitle">
            @if (isWorker) { <text>Your task board — submit proof to complete tasks</text> }
            else           { <text>Manage and track all farm task assignments</text> }
        </p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        @if (isWorker)
        {
            <a href="/TaskAssignment/OpenBoard" class="btn btn-outline">
                <i class="bi bi-grid-3x3-gap"></i> Open Board
            </a>
        }
        @if (isOwner && proofTasks > 0)
        {
            <a href="/TaskAssignment/ReviewProofs" class="btn btn-warning" style="position:relative">
                <i class="bi bi-check2-square"></i> Review Proofs
                <span style="position:absolute;top:-8px;right:-8px;background:#ef4444;color:#fff;border-radius:50%;width:20px;height:20px;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center">@proofTasks</span>
            </a>
        }
        @if (isStaffManager)
        {
            <a href="/TaskAssignment/Assign" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> New Task
            </a>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger"><i class="bi bi-x-circle-fill me-2"></i>@TempData["ErrorMessage"]</div>
}
@if (TempData["InfoMessage"] != null)
{
    <div class="alert alert-info"><i class="bi bi-info-circle-fill me-2"></i>@TempData["InfoMessage"]</div>
}

@* ── Stats ── *@
<div class="task-stats-grid">
    <div class="task-stat-card">
        <div class="task-stat-icon" style="background:rgba(99,102,241,.12)"><i class="bi bi-list-task" style="color:#6366f1"></i></div>
        <div><div class="task-stat-value">@totalTasks</div><div class="task-stat-label">Total Tasks</div></div>
    </div>
    <div class="task-stat-card">
        <div class="task-stat-icon" style="background:rgba(16,185,129,.12)"><i class="bi bi-people" style="color:#10b981"></i></div>
        <div><div class="task-stat-value" style="color:#10b981">@openTasks</div><div class="task-stat-label">Open / Claimable</div></div>
    </div>
    <div class="task-stat-card">
        <div class="task-stat-icon" style="background:rgba(245,158,11,.12)"><i class="bi bi-activity" style="color:#f59e0b"></i></div>
        <div><div class="task-stat-value" style="color:#f59e0b">@activeTasks</div><div class="task-stat-label">In Progress</div></div>
    </div>
    <div class="task-stat-card">
        <div class="task-stat-icon" style="background:rgba(16,185,129,.12)"><i class="bi bi-check-circle" style="color:#10b981"></i></div>
        <div><div class="task-stat-value" style="color:#10b981">@completedTasks</div><div class="task-stat-label">Completed</div></div>
    </div>
</div>

@* ════════════════════════════════════
   WORKER VIEW — Kanban
   ════════════════════════════════════ *@
@if (isWorker)
{
    var pendingList    = tasks.Where(t => t.Status == "Open" || t.Status == "Accepted").OrderBy(t => t.DueDate).ToList();
    var inProgressList = tasks.Where(t => t.Status == "InProgress" || t.Status == "ProofSubmitted").OrderBy(t => t.DueDate).ToList();
    var completedList  = tasks.Where(t => t.Status == "Completed" || t.Status == "Rejected").OrderByDescending(t => t.CompletedAt).ToList();

    <div id="toast"><i class="bi bi-check-circle-fill"></i> <span id="toastMsg">Status updated!</span></div>

    <div class="kanban-board">

        @* Pending / Accepted column *@
        <div class="kanban-column">
            <div class="kanban-column-header pending-header">
                <span><i class="bi bi-hourglass me-1"></i> To Do</span>
                <span class="col-badge pending-badge">@pendingList.Count</span>
            </div>
            <div class="kanban-cards">
                @if (!pendingList.Any())
                {
                    <div class="kanban-empty"><div class="kanban-empty-icon">✅</div>Nothing pending</div>
                }
                @foreach (var t in pendingList)
                {
                    bool overdue = t.IsOverdue;
                    <div class="kanban-card @(overdue ? "overdue" : "")">
                        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:4px">
                            <div class="kanban-card-title">@t.Title</div>
                            <span class="pchip pchip-@t.Priority" style="flex-shrink:0;margin-left:6px">@t.Priority</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(t.Description)) { <div class="kanban-card-desc">@t.Description</div> }
                        <div class="kanban-card-meta">
                            <span><i class="bi bi-calendar3"></i> Due @t.DueDate.ToString("MMM dd")</span>
                            @if (t.BonusAmount > 0) { <span style="color:#059669;font-weight:700"><i class="bi bi-cash-coin"></i> ৳@t.BonusAmount.ToString("N0")</span> }
                            @if (overdue) { <span class="due-overdue"><i class="bi bi-exclamation-triangle"></i> Overdue</span> }
                        </div>
                        <div style="display:flex;gap:6px">
                            <a href="/TaskAssignment/SubmitProof/@t.Id" class="btn btn-primary btn-sm" style="flex:1;text-align:center">
                                <i class="bi bi-camera"></i> Submit Proof
                            </a>
                            <form asp-action="UpdateStatus" method="post" style="flex:1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="taskId" value="@t.Id" />
                                <select name="status" class="status-select-worker" style="width:100%">
                                    <option value="Accepted" selected="@(t.Status == "Accepted")">Accepted</option>
                                    <option value="InProgress">Start Working</option>
                                </select>
                                <button type="submit" class="btn-submit-status" style="width:100%;margin-top:4px"><i class="bi bi-check-lg"></i> Update</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* Doing / Proof Submitted column *@
        <div class="kanban-column">
            <div class="kanban-column-header doing-header">
                <span><i class="bi bi-activity me-1"></i> Doing</span>
                <span class="col-badge doing-badge">@inProgressList.Count</span>
            </div>
            <div class="kanban-cards">
                @if (!inProgressList.Any())
                {
                    <div class="kanban-empty"><div class="kanban-empty-icon">🔄</div>Nothing in progress</div>
                }
                @foreach (var t in inProgressList)
                {
                    bool overdue = t.IsOverdue;
                    <div class="kanban-card @(overdue ? "overdue" : "")">
                        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:4px">
                            <div class="kanban-card-title">@t.Title</div>
                            <span class="pchip pchip-@t.Priority" style="flex-shrink:0;margin-left:6px">@t.Priority</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(t.Description)) { <div class="kanban-card-desc">@t.Description</div> }
                        <div class="kanban-card-meta">
                            <span><i class="bi bi-calendar3"></i> Due @t.DueDate.ToString("MMM dd")</span>
                            @if (t.BonusAmount > 0) { <span style="color:#059669;font-weight:700"><i class="bi bi-cash-coin"></i> ৳@t.BonusAmount.ToString("N0")</span> }
                        </div>
                        @if (t.Status == "ProofSubmitted")
                        {
                            <div style="background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.3);border-radius:8px;padding:8px 12px;font-size:12px;color:#d97706;font-weight:600">
                                <i class="bi bi-clock-history"></i> Proof submitted — awaiting owner review
                            </div>
                        }
                        else
                        {
                            <a href="/TaskAssignment/SubmitProof/@t.Id" class="btn btn-primary btn-sm" style="width:100%;text-align:center">
                                <i class="bi bi-camera"></i> Submit Proof to Complete
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        @* Done column *@
        <div class="kanban-column">
            <div class="kanban-column-header done-header">
                <span><i class="bi bi-check-circle me-1"></i> Done</span>
                <span class="col-badge done-badge">@completedList.Count</span>
            </div>
            <div class="kanban-cards">
                @if (!completedList.Any())
                {
                    <div class="kanban-empty"><div class="kanban-empty-icon">🏆</div>No completed tasks yet</div>
                }
                @foreach (var t in completedList)
                {
                    bool rejected = t.Status == "Rejected";
                    <div class="kanban-card" style="opacity:.85">
                        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:4px">
                            <div class="kanban-card-title" style="@(rejected?"":"text-decoration:line-through;")color:var(--text-muted)">@t.Title</div>
                        </div>
                        <div class="kanban-card-meta">
                            @if (rejected)
                            {
                                <span style="color:#ef4444;font-weight:600"><i class="bi bi-x-circle"></i> Rejected</span>
                                @if (!string.IsNullOrWhiteSpace(t.RejectionReason)) { <span style="font-size:11px">@t.RejectionReason</span> }
                            }
                            else if (t.CompletedAt.HasValue)
                            {
                                <span><i class="bi bi-check2-circle" style="color:#10b981"></i> Done @t.CompletedAt.Value.ToString("MMM dd")</span>
                                @if (t.BonusApproved) { <span style="color:#059669;font-weight:700"><i class="bi bi-cash-coin"></i> +৳@t.BonusAmount.ToString("N0")</span> }
                            }
                        </div>
                        @if (rejected)
                        {
                            <a href="/TaskAssignment/SubmitProof/@t.Id" class="btn btn-outline btn-sm" style="width:100%;text-align:center">
                                <i class="bi bi-arrow-clockwise"></i> Resubmit Proof
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

    </div>
}

@* ════════════════════════════════════
   MANAGER / ADMIN VIEW — Table
   ════════════════════════════════════ *@
else
{
    <div class="filter-bar">
        <i class="bi bi-funnel" style="color:var(--text-muted)"></i>
        <input type="text" id="searchInput" placeholder="Search tasks or workers…" oninput="filterTable()" style="min-width:240px" />
        <select id="statusFilter" onchange="filterTable()">
            <option value="">All Statuses</option>
            <option>Open</option>
            <option>Accepted</option>
            <option>InProgress</option>
            <option>ProofSubmitted</option>
            <option>Completed</option>
            <option>Rejected</option>
            <option>Expired</option>
        </select>
        <select id="priorityFilter" onchange="filterTable()">
            <option value="">All Priorities</option>
            <option>Emergency</option>
            <option>High</option>
            <option>Medium</option>
            <option>Low</option>
        </select>
        <button class="btn btn-ghost btn-sm" onclick="clearFilters()"><i class="bi bi-x-circle"></i> Clear</button>
        <span style="margin-left:auto;font-size:12px;color:var(--text-muted)">
            Showing <strong id="visibleCount">@totalTasks</strong> of @totalTasks tasks
        </span>
    </div>

    <div class="card">
        <div class="table-wrapper">
            <table class="data-table" id="taskIndexTable">
                <thead>
                    <tr>
                        <th>Task</th>
                        <th>Priority</th>
                        <th>Assigned To</th>
                        <th>Due Date</th>
                        <th>Bonus</th>
                        <th>Status</th>
                        <th style="text-align:center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!tasks.Any())
                    {
                        <tr>
                            <td colspan="7" style="text-align:center;padding:48px 20px;color:var(--text-muted)">
                                <div style="font-size:48px;margin-bottom:12px">📋</div>
                                <div style="font-weight:600;margin-bottom:6px">No tasks found</div>
                                @if (isStaffManager)
                                {
                                    <a href="/TaskAssignment/Assign" class="btn btn-primary btn-sm" style="margin-top:8px">
                                        <i class="bi bi-plus-circle"></i> Create First Task
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                    @foreach (var t in tasks)
                    {
                        var badgeCss = t.Status switch
                        {
                            "Open"           => "badge-info",
                            "Accepted"       => "badge-info",
                            "InProgress"     => "badge-warning",
                            "ProofSubmitted" => "badge-warning",
                            "Completed"      => "badge-success",
                            "Rejected"       => "badge-danger",
                            "Expired"        => "badge-gray",
                            _                => "badge-gray"
                        };
                        var statusLabel = t.Status == "InProgress" ? "In Progress"
                                        : t.Status == "ProofSubmitted" ? "Proof Sent" : t.Status;

                        <tr data-search="@t.Title.ToLower() @t.Description?.ToLower() @(t.WorkerName?.ToLower() ?? "")"
                            data-status="@t.Status"
                            data-priority="@t.Priority">
                            <td>
                                <div>
                                    <span style="font-weight:600;display:block">@t.Title</span>
                                    <span style="font-size:12px;color:var(--text-muted);display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden">@t.Description</span>
                                    @if (t.TaskType == "Open")
                                    {
                                        <span style="font-size:11px;color:#10b981;font-weight:600"><i class="bi bi-people"></i> Open Task</span>
                                    }
                                </div>
                            </td>
                            <td><span class="pchip pchip-@t.Priority">@t.Priority</span></td>
                            <td>
                                <div style="display:flex;align-items:center;gap:8px">
                                    <div style="width:28px;height:28px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:10px;color:var(--primary);flex-shrink:0">
                                        @(!string.IsNullOrWhiteSpace(t.WorkerName) ? string.Join("", t.WorkerName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper() : "?")
                                    </div>
                                    <span>@(string.IsNullOrEmpty(t.WorkerName) ? "—" : t.WorkerName)</span>
                                </div>
                            </td>
                            <td style="font-size:12px;font-weight:600;color:@(t.IsOverdue ? "var(--danger)" : "inherit")">
                                @t.DueDate.ToString("MMM dd, yyyy")
                                @if (t.IsOverdue) { <span style="color:var(--danger);font-size:10px;display:block"><i class="bi bi-exclamation-triangle"></i> Overdue</span> }
                            </td>
                            <td>
                                @if (t.BonusAmount > 0)
                                {
                                    <span style="font-weight:700;color:@(t.BonusApproved ? "#059669" : "#d97706")">
                                        ৳@t.BonusAmount.ToString("N0")
                                        @if (t.BonusApproved) { <i class="bi bi-check-circle-fill" style="color:#059669"></i> }
                                    </span>
                                }
                                else { <span style="color:var(--text-muted);font-size:12px">—</span> }
                            </td>
                            <td><span class="badge @badgeCss">@statusLabel</span></td>
                            <td style="text-align:center">
                                <div style="display:flex;gap:6px;justify-content:center;align-items:center">
                                    <a href="/TaskAssignment/Details/@t.Id" class="btn btn-outline btn-sm">View</a>
                                    @if (isOwner && t.Status == "ProofSubmitted")
                                    {
                                        <a href="/TaskAssignment/ReviewProofs" class="btn btn-warning btn-sm" title="Review proof">
                                            <i class="bi bi-eye"></i> Review
                                        </a>
                                    }
                                    <a href="/TaskAssignment/Edit/@t.Id" class="btn btn-ghost btn-sm" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="/TaskAssignment/Delete/@t.Id" class="btn btn-ghost btn-sm" title="Delete">
                                        <i class="bi bi-trash text-danger"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
    function filterTable() {
        const search   = document.getElementById('searchInput')?.value.toLowerCase() ?? '';
        const status   = document.getElementById('statusFilter')?.value ?? '';
        const priority = document.getElementById('priorityFilter')?.value ?? '';
        const rows     = document.querySelectorAll('#taskIndexTable tbody tr[data-search]');
        let visible    = 0;

        rows.forEach(row => {
            const ok = (!search   || row.dataset.search.includes(search))
                    && (!status   || row.dataset.status   === status)
                    && (!priority || row.dataset.priority === priority);
            row.style.display = ok ? '' : 'none';
            if (ok) visible++;
        });

        const vc = document.getElementById('visibleCount');
        if (vc) vc.textContent = visible;
    }

    function clearFilters() {
        ['searchInput','statusFilter','priorityFilter'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.value = '';
        });
        filterTable();
    }

    // Worker toast
    document.querySelectorAll('.kanban-card form').forEach(form => {
        form.addEventListener('submit', () => {
            const select = form.querySelector('select[name="status"]');
            const labels = { Accepted: 'Marked as Accepted', InProgress: 'Marked as In Progress' };
            showToast(labels[select?.value] ?? 'Status updated!');
        });
    });

    function showToast(msg) {
        const toast = document.getElementById('toast');
        if (!toast) return;
        document.getElementById('toastMsg').textContent = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2800);
    }
</script>
}
