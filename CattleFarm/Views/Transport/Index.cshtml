@model CattleFarm.ViewModels.TransportDashboardViewModel
@{
    ViewData["Title"] = "Transport Management";
    var months = Model.MonthlyStats.Select(s => s.Month).ToArray();
    var costs  = Model.MonthlyStats.Select(s => s.TotalCost).ToArray();
    var trips  = Model.MonthlyStats.Select(s => s.TripCount).ToArray();
    var vsBreakdown = Model.VehicleStatusBreakdown;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Transport Management</h1>
        <p class="page-subtitle">Fleet operations, driver assignments, and trip analytics</p>
    </div>
    <div class="page-actions">
        <a href="/Transport/CreateRequest" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> New Booking
        </a>
    </div>
</div>

<!-- KPI Cards -->
<div class="kpi-grid animate-in">
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(37,99,235,.12);color:#2563eb">
            <i class="bi bi-truck"></i>
        </div>
        <div class="kpi-body">
            <div class="kpi-value">@Model.TotalVehicles</div>
            <div class="kpi-label">Total Vehicles</div>
            <div class="kpi-sub" style="color:var(--success)">
                <i class="bi bi-circle-fill" style="font-size:7px"></i> @Model.AvailableVehicles available
            </div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(16,185,129,.12);color:#10b981">
            <i class="bi bi-person-badge"></i>
        </div>
        <div class="kpi-body">
            <div class="kpi-value">@Model.TotalDrivers</div>
            <div class="kpi-label">Total Drivers</div>
            <div class="kpi-sub" style="color:var(--success)">
                <i class="bi bi-circle-fill" style="font-size:7px"></i> @Model.AvailableDrivers available
            </div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(245,158,11,.12);color:#f59e0b">
            <i class="bi bi-hourglass-split"></i>
        </div>
        <div class="kpi-body">
            <div class="kpi-value">@Model.PendingRequests</div>
            <div class="kpi-label">Pending Requests</div>
            <div class="kpi-sub">Awaiting approval or assignment</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(139,92,246,.12);color:#8b5cf6">
            <i class="bi bi-geo-alt"></i>
        </div>
        <div class="kpi-body">
            <div class="kpi-value">@Model.OngoingTrips</div>
            <div class="kpi-label">Ongoing Trips</div>
            <div class="kpi-sub">Currently on the road</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(16,185,129,.12);color:#10b981">
            <i class="bi bi-check-circle"></i>
        </div>
        <div class="kpi-body">
            <div class="kpi-value">@Model.CompletedTripsTotal</div>
            <div class="kpi-label">Completed Trips</div>
            <div class="kpi-sub">All time</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(239,68,68,.12);color:#ef4444">
            <i class="bi bi-currency-dollar"></i>
        </div>
        <div class="kpi-body">
            <div class="kpi-value">@Currency.Format(Model.TotalCostThisMonth)</div>
            <div class="kpi-label">Cost This Month</div>
            <div class="kpi-sub">Total: @Currency.Format(Model.TotalCostAllTime)</div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="grid-2 mt-6">
    <!-- Monthly Cost & Trips Chart -->
    <div class="card animate-in">
        <div class="card-header">
            <h3 class="card-title">Monthly Transport Overview</h3>
            <span class="badge badge-info">Last 6 months</span>
        </div>
        <div class="card-body">
            <canvas id="monthlyChart" height="220"></canvas>
        </div>
    </div>

    <!-- Vehicle Status Donut -->
    <div class="card animate-in">
        <div class="card-header">
            <h3 class="card-title">Fleet Status</h3>
            <a href="/Transport/Vehicles" class="btn btn-sm btn-ghost">View All</a>
        </div>
        <div class="card-body" style="display:flex;align-items:center;gap:24px">
            <div style="flex:0 0 160px">
                <canvas id="fleetDonut" width="160" height="160"></canvas>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;gap:10px">
                <div class="legend-item"><span class="legend-dot" style="background:#10b981"></span>Available <strong>@Model.AvailableVehicles</strong></div>
                <div class="legend-item"><span class="legend-dot" style="background:#8b5cf6"></span>On Trip <strong>@Model.OnTripVehicles</strong></div>
                <div class="legend-item"><span class="legend-dot" style="background:#f59e0b"></span>Maintenance <strong>@Model.MaintenanceVehicles</strong></div>
                <div class="legend-item"><span class="legend-dot" style="background:#6b7280"></span>Retired <strong>@(Model.TotalVehicles - Model.AvailableVehicles - Model.OnTripVehicles - Model.MaintenanceVehicles)</strong></div>
            </div>
        </div>
    </div>
</div>

<!-- Ongoing Trips & Recent Completed -->
<div class="grid-2 mt-6">
    <!-- Ongoing Trips -->
    <div class="card animate-in">
        <div class="card-header">
            <h3 class="card-title">Live Trips</h3>
            <a href="/Transport/Trips?status=Ongoing" class="btn btn-sm btn-ghost">View All</a>
        </div>
        <div class="card-body p-0">
            @if (!Model.OngoingTripList.Any())
            {
                <div class="empty-state-sm"><i class="bi bi-truck"></i><span>No trips currently ongoing</span></div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var trip in Model.OngoingTripList)
                    {
                        <a href="/Transport/TripDetails/@trip.Id" class="list-item">
                            <div class="list-item-icon" style="background:rgba(139,92,246,.1);color:#8b5cf6">
                                <i class="bi bi-geo-alt"></i>
                            </div>
                            <div class="list-item-body">
                                <div class="list-item-title">@trip.TransportRequest?.PickupLocation <i class="bi bi-arrow-right"></i> @trip.TransportRequest?.Destination</div>
                                <div class="list-item-sub">@trip.Vehicle?.Name &bull; @trip.Driver?.FullName &bull; @trip.DistanceKm km</div>
                            </div>
                            <span class="badge badge-purple">Ongoing</span>
                        </a>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Recent Completed Trips -->
    <div class="card animate-in">
        <div class="card-header">
            <h3 class="card-title">Recently Completed</h3>
            <a href="/Transport/Trips?status=Completed" class="btn btn-sm btn-ghost">View All</a>
        </div>
        <div class="card-body p-0">
            @if (!Model.RecentTrips.Any())
            {
                <div class="empty-state-sm"><i class="bi bi-check-circle"></i><span>No completed trips yet</span></div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var trip in Model.RecentTrips)
                    {
                        <a href="/Transport/TripDetails/@trip.Id" class="list-item">
                            <div class="list-item-icon" style="background:rgba(16,185,129,.1);color:#10b981">
                                <i class="bi bi-check-circle"></i>
                            </div>
                            <div class="list-item-body">
                                <div class="list-item-title">@trip.TransportRequest?.PickupLocation <i class="bi bi-arrow-right"></i> @trip.TransportRequest?.Destination</div>
                                <div class="list-item-sub">@trip.Driver?.FullName &bull; @Currency.Format(trip.TotalCost) &bull; @trip.DistanceKm km</div>
                            </div>
                            <span class="badge badge-success">Done</span>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Quick Action Panel -->
<div class="card mt-6 animate-in">
    <div class="card-header">
        <h3 class="card-title">Quick Actions</h3>
    </div>
    <div class="card-body">
        <div class="quick-actions">
            <a href="/Transport/Vehicles" class="quick-action-btn">
                <i class="bi bi-truck"></i>
                <span>Manage Vehicles</span>
            </a>
            <a href="/Transport/Drivers" class="quick-action-btn">
                <i class="bi bi-person-badge"></i>
                <span>Manage Drivers</span>
            </a>
            <a href="/Transport/Requests" class="quick-action-btn">
                <i class="bi bi-clipboard-plus"></i>
                <span>View Requests</span>
            </a>
            <a href="/Transport/Trips" class="quick-action-btn">
                <i class="bi bi-map"></i>
                <span>All Trips</span>
            </a>
            <a href="/Transport/Reports" class="quick-action-btn">
                <i class="bi bi-bar-chart-line"></i>
                <span>Analytics</span>
            </a>
            <a href="/Transport/CreateRequest" class="quick-action-btn primary">
                <i class="bi bi-plus-circle"></i>
                <span>New Booking</span>
            </a>
        </div>
    </div>
</div>

@section Scripts {
<script>
const activeCurrencySymbol = '@Html.Raw(Currency.GetSettings().Symbol)';
const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
const gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
const textColor = isDark ? '#94a3b8' : '#6b7280';

// Monthly Overview Chart
new Chart(document.getElementById('monthlyChart'), {
    type: 'bar',
    data: {
        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(months)),
        datasets: [
            {
                label: 'Cost (@Html.Raw(Currency.GetSettings().Symbol))',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(costs)),
                backgroundColor: 'rgba(37,99,235,0.8)',
                borderRadius: 6,
                yAxisID: 'y'
            },
            {
                label: 'Trips',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(trips)),
                type: 'line',
                borderColor: '#10b981',
                backgroundColor: 'rgba(16,185,129,0.1)',
                fill: true,
                tension: 0.4,
                pointBackgroundColor: '#10b981',
                yAxisID: 'y1'
            }
        ]
    },
    options: {
        responsive: true,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { labels: { color: textColor, usePointStyle: true } } },
        scales: {
            x:  { grid: { color: gridColor }, ticks: { color: textColor } },
            y:  { grid: { color: gridColor }, ticks: { color: textColor, callback: v => activeCurrencySymbol + ' ' + v.toLocaleString() }, position: 'left' },
            y1: { grid: { display: false },  ticks: { color: textColor }, position: 'right' }
        }
    }
});

// Fleet Donut
new Chart(document.getElementById('fleetDonut'), {
    type: 'doughnut',
    data: {
        labels: ['Available', 'On Trip', 'Maintenance', 'Retired'],
        datasets: [{
            data: [
                @Model.AvailableVehicles,
                @Model.OnTripVehicles,
                @Model.MaintenanceVehicles,
                @(Model.TotalVehicles - Model.AvailableVehicles - Model.OnTripVehicles - Model.MaintenanceVehicles)
            ],
            backgroundColor: ['#10b981','#8b5cf6','#f59e0b','#6b7280'],
            borderWidth: 0,
            hoverOffset: 6
        }]
    },
    options: {
        cutout: '72%',
        plugins: { legend: { display: false } }
    }
});
</script>
}
