@model CattleFarm.ViewModels.VehicleViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Vehicle" : "Add Vehicle";
}

<div class="page-header">
    <div>
        <h1 class="page-title">@ViewData["Title"]</h1>
        <p class="page-subtitle">@(isEdit ? "Update vehicle information" : "Register a new vehicle to your fleet")</p>
    </div>
    <a href="/Transport/Vehicles" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Back to Fleet</a>
</div>

<div class="form-card-wrap">
    <div class="form-card animate-in">
        <form method="post" action="@(isEdit ? $"/Transport/EditVehicle/{Model.Id}" : "/Transport/CreateVehicle")">
            @Html.AntiForgeryToken()

            <div class="form-section">
                <h3 class="form-section-title">Basic Information</h3>
                <div class="form-grid-2">
                    <div class="form-group">
                        <label class="form-label">Vehicle Name <span class="required">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Farm Truck 01" />
                        <span asp-validation-for="Name" class="validation-msg"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Registration Number <span class="required">*</span></label>
                        <input asp-for="RegistrationNumber" class="form-control" placeholder="e.g. DH-KA-11-1234" />
                        <span asp-validation-for="RegistrationNumber" class="validation-msg"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Vehicle Type</label>
                        <select asp-for="Type" class="form-select"
                                asp-items="Html.GetEnumSelectList<CattleFarm.Models.VehicleType>()"></select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fuel Type</label>
                        <select asp-for="FuelType" class="form-select"
                                asp-items="Html.GetEnumSelectList<CattleFarm.Models.FuelType>()"></select>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3 class="form-section-title">Capacity & Cost</h3>
                <div class="form-grid-3">
                    <div class="form-group">
                        <label class="form-label">Capacity <span class="required">*</span></label>
                        <div class="input-group">
                            <input asp-for="Capacity" type="number" step="0.01" class="form-control" placeholder="5" />
                            <select asp-for="CapacityUnit" class="form-select" style="max-width:100px">
                                <option value="tonnes">tonnes</option>
                                <option value="units">units</option>
                                <option value="liters">liters</option>
                                <option value="kg">kg</option>
                            </select>
                        </div>
                        <span asp-validation-for="Capacity" class="validation-msg"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fuel Cost / km (@Currency.GetSettings().Symbol)</label>
                        <input asp-for="FuelCostPerKm" type="number" step="0.01" class="form-control" placeholder="12.50" />
                        <span asp-validation-for="FuelCostPerKm" class="validation-msg"></span>
                    </div>
                    @if (isEdit)
                    {
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select asp-for="Status" class="form-select"
                                    asp-items="Html.GetEnumSelectList<CattleFarm.Models.VehicleStatus>()"></select>
                        </div>
                    }
                </div>
            </div>

            <div class="form-section">
                <h3 class="form-section-title">Additional Notes</h3>
                <div class="form-group">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"
                              placeholder="Maintenance history, special features, etc."></textarea>
                </div>
            </div>

            <div class="form-actions">
                <a href="/Transport/Vehicles" class="btn btn-ghost">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-@(isEdit ? "check-lg" : "plus-lg")"></i>
                    @(isEdit ? "Save Changes" : "Add Vehicle")
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
