@model IEnumerable<CattleFarm.Models.Vehicle>
@{
    ViewData["Title"] = "Vehicles";
    string[] statuses = { "Available", "Assigned", "OnTrip", "Maintenance", "Retired" };
}

<div class="page-header">
    <div>
        <h1 class="page-title">Fleet Management</h1>
        <p class="page-subtitle">@Model.Count() vehicle(s) &bull; Manage your transport fleet</p>
    </div>
    <a href="/Transport/CreateVehicle" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add Vehicle
    </a>
</div>

<!-- Filters -->
<div class="filter-bar">
    <form method="get" class="filter-form">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input name="search" value="@ViewBag.Search" placeholder="Search vehicles..." class="form-control" />
        </div>
        <select name="status" class="form-select" onchange="this.form.submit()">
            <option value="">All Statuses</option>
            @foreach (var s in statuses)
            {
                <option value="@s" selected="@(ViewBag.StatusFilter == s)">@s</option>
            }
        </select>
        <button type="submit" class="btn btn-secondary">Filter</button>
        <a href="/Transport/Vehicles" class="btn btn-ghost">Clear</a>
    </form>
</div>

<!-- Vehicle Grid -->
@if (!Model.Any())
{
    <div class="empty-state">
        <i class="bi bi-truck"></i>
        <h3>No vehicles found</h3>
        <p>Add your first vehicle to get started with transport management.</p>
        <a href="/Transport/CreateVehicle" class="btn btn-primary">Add Vehicle</a>
    </div>
}
else
{
    <div class="vehicle-grid">
        @foreach (var v in Model)
        {
            <div class="vehicle-card animate-in">
                <div class="vehicle-card-header">
                    <div class="vehicle-icon">
                        @switch (v.Type)
                        {
                            case CattleFarm.Models.VehicleType.Truck:    <i class="bi bi-truck"></i>; break;
                            case CattleFarm.Models.VehicleType.Pickup:   <i class="bi bi-truck-flatbed"></i>; break;
                            case CattleFarm.Models.VehicleType.Van:      <i class="bi bi-minecart"></i>; break;
                            case CattleFarm.Models.VehicleType.Tractor:  <i class="bi bi-tools"></i>; break;
                            default:                                      <i class="bi bi-truck"></i>; break;
                        }
                    </div>
                    <span class="badge @GetVehicleStatusBadge(v.Status)">@v.Status</span>
                </div>
                <div class="vehicle-card-body">
                    <h4 class="vehicle-name">@v.Name</h4>
                    <p class="vehicle-reg">@v.RegistrationNumber</p>
                    <div class="vehicle-meta">
                        <span><i class="bi bi-lightning-charge"></i> @v.FuelType</span>
                        <span><i class="bi bi-box-seam"></i> @v.Capacity @v.CapacityUnit</span>
                    </div>
                    <div class="vehicle-meta">
                        <span><i class="bi bi-speedometer2"></i> @Currency.Format(v.FuelCostPerKm)/km</span>
                        @if (v.Driver != null)
                        {
                            <span><i class="bi bi-person"></i> @v.Driver.FullName</span>
                        }
                        else
                        {
                            <span class="text-muted"><i class="bi bi-person-x"></i> No driver</span>
                        }
                    </div>
                </div>
                <div class="vehicle-card-footer">
                    <a href="/Transport/EditVehicle/@v.Id" class="btn btn-sm btn-ghost">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form method="post" action="/Transport/DeleteVehicle/@v.Id" class="d-inline"
                          onsubmit="return confirm('Delete this vehicle?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger-ghost">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}

<!-- Pagination -->
@if ((int)ViewBag.TotalPages > 1)
{
    <div class="pagination">
        @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
        {
            <a href="?page=@i&status=@ViewBag.StatusFilter&search=@ViewBag.Search"
               class="page-btn @(i == (int)ViewBag.CurrentPage ? "active" : "")">@i</a>
        }
    </div>
}

@functions {
    string GetVehicleStatusBadge(CattleFarm.Models.VehicleStatus s) => s switch {
        CattleFarm.Models.VehicleStatus.Available   => "badge-success",
        CattleFarm.Models.VehicleStatus.OnTrip      => "badge-purple",
        CattleFarm.Models.VehicleStatus.Assigned    => "badge-info",
        CattleFarm.Models.VehicleStatus.Maintenance => "badge-warning",
        _                                           => "badge-secondary"
    };
}
