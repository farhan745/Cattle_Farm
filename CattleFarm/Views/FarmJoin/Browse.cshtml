@model CattleFarm.ViewModels.FarmJoinBrowseViewModel
@{
    ViewData["Title"] = "Farm খোঁজো";
}

@section Styles {
<style>
    .farm-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; }
    .farm-card {
        background: var(--card-bg); border: 1px solid var(--border);
        border-radius: 14px; overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }
    .farm-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.1); }
    .farm-img { width: 100%; height: 140px; object-fit: cover; background: var(--bg); display: flex; align-items: center; justify-content: center; font-size: 40px; }
    .farm-body { padding: 16px; }
    .farm-name { font-weight: 700; font-size: 15px; margin-bottom: 4px; }
    .farm-loc  { font-size: 12px; color: var(--text-muted); margin-bottom: 12px; }
    .farm-footer { padding: 12px 16px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
</style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">🌾 Farm খোঁজো</h1>
        <p class="page-subtitle">
            @if (Model.MyActiveFarmName != null)
            { <text>তুমি এখন <strong>@Model.MyActiveFarmName</strong> এ আছো</text> }
            else
            { <text>একটি farm এ join করো</text> }
        </p>
    </div>
    <a href="/FarmJoin/MyRequests" class="btn btn-outline">
        <i class="bi bi-list-check"></i> আমার Applications
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger"><i class="bi bi-x-circle-fill me-2"></i>@TempData["ErrorMessage"]</div>
}

@if (!Model.Farms.Any())
{
    <div style="text-align:center;padding:64px 20px;color:var(--text-muted)">
        <div style="font-size:48px;margin-bottom:12px">🌾</div>
        <div style="font-weight:700">কোনো farm পাওয়া যায়নি</div>
        <div style="font-size:13px;margin-top:6px">Admin এখনো কোনো farm approve করেননি।</div>
    </div>
}
else
{
    <div class="farm-grid">
        @foreach (var farm in Model.Farms)
        {
            <div class="farm-card">
                @if (!string.IsNullOrEmpty(farm.ImagePath))
                {
                    <img src="@farm.ImagePath" class="farm-img" alt="@farm.Name" />
                }
                else
                {
                    <div class="farm-img">🏡</div>
                }
                <div class="farm-body">
                    <div class="farm-name">@farm.Name</div>
                    <div class="farm-loc"><i class="bi bi-geo-alt"></i> @farm.Location</div>
                    <div style="font-size:12px;color:var(--text-muted)">
                        <i class="bi bi-people"></i> @farm.WorkerCount জন কাজ করছে
                    </div>
                </div>
                <div class="farm-footer">
                    @if (farm.AlreadyJoined)
                    {
                        <span class="badge badge-success"><i class="bi bi-check-circle"></i> Joined</span>
                        <form asp-action="Leave" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="farmId" value="@farm.Id" />
                            <button type="submit" class="btn btn-outline btn-sm"
                                    onclick="return confirm('এই farm থেকে leave নেবে?')">
                                Leave
                            </button>
                        </form>
                    }
                    else if (farm.ApplicationStatus == "Pending" || farm.ApplicationStatus == "Applied")
                    {
                        <span class="badge badge-warning"><i class="bi bi-clock"></i> Pending</span>
                        <span style="font-size:11px;color:var(--text-muted)">Owner এর approval বাকি</span>
                    }
                    else if (farm.ApplicationStatus == "Cooldown")
                    {
                        <span class="badge badge-danger"><i class="bi bi-slash-circle"></i> Cooldown</span>
                        <span style="font-size:11px;color:var(--text-muted)">
                            @farm.CooldownEnds?.ToLocalTime().ToString("MMM dd") পর্যন্ত
                        </span>
                    }
                    else if (Model.MyActiveFarmId.HasValue && !farm.AlreadyJoined)
                    {
                        <span style="font-size:12px;color:var(--text-muted)">অন্য farm এ আছো</span>
                    }
                    else
                    {
                        <span style="font-size:12px;color:var(--text-muted)">@farm.WorkerCount workers</span>
                        <a href="/FarmJoin/Apply?farmId=@farm.Id&farmName=@Uri.EscapeDataString(farm.Name)"
                           class="btn btn-primary btn-sm">
                            <i class="bi bi-send"></i> Apply
                        </a>
                    }
                </div>
            </div>
        }
    </div>
}
