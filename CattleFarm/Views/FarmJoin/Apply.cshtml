@model CattleFarm.ViewModels.FarmJoinApplyViewModel
@{ ViewData["Title"] = "Farm এ Apply"; }

<div class="page-header">
    <div><h1 class="page-title">📨 Farm এ Apply</h1></div>
    <a href="/FarmJoin/Browse" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div style="max-width:520px;margin:0 auto">
    <div class="card" style="padding:28px">
        <div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:24px;display:flex;gap:12px;align-items:center">
            <span style="font-size:28px">🏡</span>
            <div>
                <div style="font-weight:700;font-size:15px">@Model.FarmName</div>
                <div style="font-size:12px;color:var(--text-muted)">এই farm এ join করতে চাও</div>
            </div>
        </div>

        <form asp-action="Apply" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="FarmId" />
            <input type="hidden" asp-for="FarmName" />

            <div style="margin-bottom:24px">
                <label style="font-weight:600;display:block;margin-bottom:6px;font-size:13.5px">
                    Owner কে একটি message (optional)
                </label>
                <textarea asp-for="Message" rows="4"
                    style="width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;background:var(--bg);color:var(--text);font-family:inherit;font-size:14px;outline:none;resize:vertical"
                    placeholder="যেমন: আমি ৫ বছর ধরে গরু পালন করছি, দুধ সংগ্রহ ও পরিচর্যায় অভিজ্ঞ..."></textarea>
            </div>

            <div style="display:flex;justify-content:end;gap:12px;border-top:1px solid var(--border);padding-top:20px">
                <a href="/FarmJoin/Browse" class="btn btn-outline">বাতিল</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send"></i> Application পাঠাও
                </button>
            </div>
        </form>
    </div>
</div>
