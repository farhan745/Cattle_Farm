@model IEnumerable<CattleFarm.ViewModels.IncomingRequestViewModel>
@{ ViewData["Title"] = "Join Requests"; }
@functions {
    private static string GetInitials(string? name)
    {
        var initials = (name ?? string.Empty)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]))
            .ToArray();

        return initials.Length > 0 ? new string(initials) : "?";
    }
}

<div class="page-header">
    <div>
        <h1 class="page-title">👥 Join Requests</h1>
        <p class="page-subtitle">Worker দের farm join request approve বা reject করো</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger"><i class="bi bi-x-circle-fill me-2"></i>@TempData["ErrorMessage"]</div>
}

@if (!Model.Any())
{
    <div style="text-align:center;padding:64px 20px;color:var(--text-muted)">
        <div style="font-size:48px;margin-bottom:12px">🎉</div>
        <div style="font-weight:700">কোনো pending request নেই</div>
    </div>
}
else
{
    <div style="display:flex;flex-direction:column;gap:16px">
        @foreach (var r in Model)
        {
            <div style="background:var(--card-bg);border:1px solid var(--border);border-radius:14px;padding:20px;display:flex;gap:16px;align-items:flex-start;flex-wrap:wrap">
                <div style="width:44px;height:44px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;color:var(--primary);flex-shrink:0">
                    @GetInitials(r.WorkerName)
                </div>
                <div style="flex:1;min-width:200px">
                    <div style="font-weight:700;font-size:15px">@r.WorkerName</div>
                    <div style="font-size:12px;color:var(--text-muted);margin-top:2px">
                        <i class="bi bi-envelope"></i> @r.WorkerEmail ·
                        <i class="bi bi-house"></i> @r.FarmName ·
                        <i class="bi bi-clock"></i> @r.AppliedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")
                    </div>
                    @if (!string.IsNullOrWhiteSpace(r.Message))
                    {
                        <div style="margin-top:10px;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 12px;font-size:13px;font-style:italic">
                            <i class="bi bi-chat-quote me-1" style="color:var(--primary)"></i>@r.Message
                        </div>
                    }
                </div>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                    <form asp-action="Accept" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="requestId" value="@r.Id" />
                        <button type="submit" class="btn btn-success"
                                onclick="return confirm('@r.WorkerName কে accept করবে?')">
                            <i class="bi bi-check-circle"></i> Accept
                        </button>
                    </form>

                    <form asp-action="Reject" method="post" style="display:inline;display:flex;gap:8px;align-items:center" id="reject-form-@r.Id">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="requestId" value="@r.Id" />
                        <input type="text" name="note"
                               placeholder="Rejection note (optional)"
                               style="padding:8px 12px;border:1px solid var(--border);border-radius:8px;background:var(--bg);color:var(--text);font-size:13px;font-family:inherit;outline:none;min-width:180px" />
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('@r.WorkerName কে reject করবে?')">
                            <i class="bi bi-x-circle"></i> Reject
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
