    <div style="text-align:center">
        <div class="section-label">Simple Pricing</div>
        <h2 class="section-title">Choose Your Plan</h2>
        <p class="section-sub" style="margin:0 auto">Start free, upgrade anytime. All plans include a 30-day money-back guarantee.</p>
    </div>
    <div class="pricing-grid">
        <!-- Free -->
        <div class="price-card">
            <div style="font-size:32px;margin-bottom:8px">🌱</div>
            <div class="price-name">Free</div>
            <div class="price-num">Free</div>
            <div class="price-period">forever</div>
            <ul class="price-features">
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> 1 Farm</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> 10 Cattle</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Basic Dashboard</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Community Support</li>
            </ul>
            <a href="/Account/Register" class="btn-land-outline" style="display:block;text-align:center;padding:12px">Get Started Free</a>
        </div>
        <!-- Basic -->
        <div class="price-card">
            <div style="font-size:32px;margin-bottom:8px">⭐</div>
            <div class="price-name">Basic</div>
            <div class="price-num">৳999</div>
            <div class="price-period">/ month</div>
            <ul class="price-features">
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> 3 Farms</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> 100 Cattle</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Advanced Analytics</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Health Monitoring</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Email Support</li>
            </ul>
            <a href="/Account/Register" class="btn-land-outline" style="display:block;text-align:center;padding:12px">Start Basic</a>
        </div>
        <!-- Pro (Popular) -->
        <div class="price-card-popular">
            <div class="popular-badge">✦ MOST POPULAR</div>
            <div style="font-size:32px;margin-bottom:8px">🏆</div>
            <div class="price-name">Pro</div>
            <div class="price-num">৳2,999</div>
            <div class="price-period">/ month</div>
            <ul class="price-features">
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Unlimited Farms</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Unlimited Cattle</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> AI Dashboard</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> IoT Ready</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Priority Support</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> PDF/Excel Export</li>
            </ul>
            <a href="/Account/Register" class="btn-land-primary" style="display:block;text-align:center;padding:12px">Start Pro</a>
        </div>
        <!-- Enterprise -->
        <div class="price-card">
            <div style="font-size:32px;margin-bottom:8px">🚀</div>
            <div class="price-name">Enterprise</div>
            <div class="price-num">৳5,000</div>
            <div class="price-period">/ month</div>
            <ul class="price-features">
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Everything in Pro</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> White-label</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Dedicated Support</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> Custom Integrations</li>
                <li><i class="bi bi-check-circle-fill" style="color:#2D5A3D"></i> SLA Guarantee</li>
            </ul>
            <a href="/Account/Register" class="btn-land-outline" style="display:block;text-align:center;padding:12px">Contact Sales</a>
        </div>
    </div>
</section>

<section id="testimonials">
    <div class="section-label">What Farmers Say</div>
    <h2 class="section-title">Trusted Across Bangladesh</h2>
    <div class="testimonials-grid">
        @foreach (var t in testimonials)
        {
            <div class="testimonial-card fade-up">
                <div class="stars">★★★★★</div>
                <div class="testimonial-text">@t.Item1</div>
                <div class="testimonial-author">
                    <div class="author-avatar">@t.Item2</div>
                    <div>
                        <div class="author-name">@t.Item3</div>
                        <div class="author-role">@t.Item4</div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<section class="cta-section" id="about">
    <div class="section-label" style="color:#F4C97A">Start Today</div>
    <h2>Ready to Transform Your Farm?</h2>
    <p>Join thousands of farmers already using Smart Cattle Farm. Free plan — no credit card required.</p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
        <a href="/Account/Register" class="btn-land-primary" style="background:#C8761A"><i class="bi bi-person-plus-fill"></i> Create Free Account</a>
        <a href="/Account/Login" class="btn-land-outline" style="border-color:rgba(255,255,255,.4);color:#fff"><i class="bi bi-box-arrow-in-right"></i> Sign In</a>
    </div>
</section>

<footer class="land-footer">
    <div class="footer-grid">
        <div>
            <div class="footer-brand-text">🐄 Smart Cattle Farm</div>
            <div class="footer-desc">Bangladesh's most advanced cattle farm management platform. Built for farmers, by farmers.</div>
        </div>
        <div>
            <div class="footer-heading">Platform</div>
            <ul class="footer-links">
                <li><a href="#features">Features</a></li>
                <li><a href="#pricing">Pricing</a></li>
                <li><a href="/Cattle/Marketplace">Marketplace</a></li>
                <li><a href="/Account/Register">Get Started</a></li>
            </ul>
        </div>
        <div>
            <div class="footer-heading">Company</div>
            <ul class="footer-links">
                <li><a href="#about">About Us</a></li>
                <li><a href="#">Blog</a></li>
                <li><a href="#">Careers</a></li>
                <li><a href="#">Contact</a></li>
            </ul>
        </div>
        <div>
            <div class="footer-heading">Support</div>
            <ul class="footer-links">
                <li><a href="#">Help Center</a></li>
                <li><a href="#">Privacy Policy</a></li>
                <li><a href="#">Terms of Service</a></li>
                <li><a href="mailto:support@smartcattlefarm.com">Email Support</a></li>
            </ul>
        </div>
    </div>
    <div class="footer-bottom">
        <span>© @DateTime.Now.Year Smart Cattle Farm. All rights reserved.</span>
        <span>Secured by SSLCommerz &amp; SSL/TLS Encryption</span>
    </div>
</footer>

<script>
function animateCount(el, target, suffix) {
    let s = 0, step = target / 60;
    const t = setInterval(() => {
        s += step;
        if (s >= target) { el.textContent = target.toLocaleString() + (suffix||''); clearInterval(t); }
        else el.textContent = Math.floor(s).toLocaleString() + (suffix||'');
    }, 25);
}
window.addEventListener('load', () => {
    animateCount(document.getElementById('statFarms'),  1200, '+');
    animateCount(document.getElementById('statCattle'), 85000, '+');
    animateCount(document.getElementById('statUsers'),  4500, '+');
});
const obs = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }), { threshold: 0.15 });
document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
</script>
</body>
</html>
