@{
    Layout = null;
    ViewData["Title"] = "Smart Cattle Farm — Premium Livestock Management";

    var features = new[] {
        ("🐄","Cattle Management","Track every animal — weight, breed, health status, vaccination history and full lifecycle records."),
        ("🏥","Health Monitoring","Schedule vet appointments, record diagnoses, track medications and get alerts for at-risk cattle."),
        ("🥛","Milk Production","Log daily milk output per cattle, visualize trends and generate production reports."),
        ("💰","Financial Dashboard","Track income, expenses, payroll and generate profit/loss reports in one click."),
        ("👷","Worker Management","Manage farm workers, track attendance, assign tasks and monitor performance."),
        ("📅","Appointments","Schedule and manage veterinarian visits with calendar view and automated reminders."),
        ("🏪","Marketplace","List cattle for sale, browse the market and complete transactions securely."),
        ("📊","Analytics & Reports","AI-ready analytics with charts, trends and exportable PDF/Excel reports."),
        ("🔒","Secure & Reliable","Role-based access control, audit logs, encrypted data and 99.9% uptime.")
    };

    var testimonials = new[] {
        ("\"This platform transformed how I manage my 200-head dairy farm. The health tracking alone has saved me thousands in vet bills.\"","RH","Rahman Hossain","Farm Owner, Mymensingh"),
        ("\"The milk production reports help me spot drops early. I upgraded to Pro last month — best decision I made this year.\"","SA","Sakina Akter","Dairy Farmer, Sirajganj"),
        ("\"SSLCommerz payment works perfectly. Subscription took seconds and the marketplace feature helped me sell 15 cattle last month.\"","MK","Mohammad Karim","Cattle Trader, Bogura")
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smart Cattle Farm — Premium Livestock Management</title>
    <meta name="description" content="Bangladesh's #1 cattle farm management platform. Track livestock, health, milk production, finances and more." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700;800&family=Barlow+Condensed:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:'Lora',Georgia,serif;background:#FAF8F4;color:#1C3A2A;overflow-x:hidden}
        .land-nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 40px;height:70px;display:flex;align-items:center;justify-content:space-between;background:rgba(250,248,244,.95);backdrop-filter:blur(12px);border-bottom:1px solid rgba(200,118,26,.15)}
        .land-nav .brand{display:flex;align-items:center;gap:10px;font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:#1C3A2A;text-decoration:none}
        .land-nav .nav-links{display:flex;align-items:center;gap:32px}
        .land-nav .nav-links a{font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:600;color:#3D3D3A;text-decoration:none;letter-spacing:.05em;text-transform:uppercase;transition:color .2s}
        .land-nav .nav-links a:hover{color:#C8761A}
        .land-nav .nav-cta{display:flex;gap:10px}
        .hero{min-height:100vh;display:flex;align-items:center;padding:100px 80px 80px;background:linear-gradient(135deg,#FAF8F4 0%,#F2EDE4 50%,#EDE3D4 100%);position:relative;overflow:hidden}
        .hero::before{content:'🐄';position:absolute;right:5%;top:50%;transform:translateY(-50%);font-size:320px;opacity:.07;pointer-events:none}
        .hero-content{max-width:680px}
        .hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(200,118,26,.12);border:1px solid rgba(200,118,26,.3);color:#C8761A;padding:6px 16px;border-radius:20px;font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:28px}
        .hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(42px,5vw,72px);font-weight:800;line-height:1.1;color:#1C3A2A;margin-bottom:24px}
        .hero h1 span{color:#C8761A}
        .hero p{font-size:18px;color:#6B6B66;line-height:1.8;margin-bottom:40px;max-width:520px}
        .hero-actions{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:56px}
        .hero-stats{display:flex;gap:40px}
        .hero-stat-num{font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:800;color:#1C3A2A}
        .hero-stat-label{font-size:12px;color:#9CA3AF;font-family:'Barlow Condensed',sans-serif;font-weight:600;text-transform:uppercase;letter-spacing:.08em}
        .btn-land-primary{background:#1C3A2A;color:#fff;padding:14px 32px;border-radius:8px;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;text-decoration:none;letter-spacing:.05em;text-transform:uppercase;border:none;cursor:pointer;transition:background .2s,transform .2s;display:inline-flex;align-items:center;gap:8px}
        .btn-land-primary:hover{background:#2D5A3D;transform:translateY(-2px);color:#fff}
        .btn-land-outline{background:transparent;color:#1C3A2A;padding:14px 32px;border-radius:8px;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;text-decoration:none;letter-spacing:.05em;text-transform:uppercase;border:2px solid #DDD5C8;cursor:pointer;transition:border-color .2s,transform .2s;display:inline-flex;align-items:center;gap:8px}
        .btn-land-outline:hover{border-color:#1C3A2A;transform:translateY(-2px);color:#1C3A2A}
        section{padding:100px 80px}
        .section-label{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#C8761A;margin-bottom:12px}
        .section-title{font-family:'Cormorant Garamond',serif;font-size:clamp(32px,3vw,52px);font-weight:800;color:#1C3A2A;margin-bottom:16px;line-height:1.15}
        .section-sub{font-size:17px;color:#6B6B66;line-height:1.8;max-width:560px}
        .stats-strip{background:#1C3A2A;padding:60px 80px}
        .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:40px;text-align:center}
        .stat-big-num{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:800;color:#F4C97A}
        .stat-big-label{font-family:'Barlow Condensed',sans-serif;font-size:14px;color:rgba(255,255,255,.7);letter-spacing:.1em;text-transform:uppercase;margin-top:4px}
        .features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:64px}
        .feature-card{background:#fff;border:1px solid #E8E0D4;border-radius:16px;padding:36px 28px;transition:transform .25s,box-shadow .25s}
        .feature-card:hover{transform:translateY(-6px);box-shadow:0 20px 60px rgba(28,58,42,.1)}
        .feature-icon{font-size:40px;margin-bottom:20px}
        .feature-title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:#1C3A2A;margin-bottom:10px}
        .feature-desc{font-size:14px;color:#6B6B66;line-height:1.75}
        .pricing-section{background:#F2EDE4}
        .pricing-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:60px}
        .price-card{background:#fff;border:1px solid #DDD5C8;border-radius:16px;padding:36px 24px;text-align:center;transition:transform .25s}
        .price-card-popular{background:#fff;border:2px solid #C8761A;border-radius:16px;padding:36px 24px;text-align:center;transform:scale(1.04);box-shadow:0 20px 60px rgba(200,118,26,.15);transition:transform .25s}
        .price-card:hover,.price-card-popular:hover{transform:translateY(-4px)}
        .price-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:#9CA3AF;margin-bottom:8px}
        .price-num{font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:800;color:#1C3A2A}
        .price-period{font-size:13px;color:#9CA3AF;margin-bottom:24px}
        .price-features{text-align:left;margin-bottom:28px;list-style:none;padding:0}
        .price-features li{display:flex;align-items:center;gap:8px;padding:5px 0;font-size:13px;color:#3D3D3A}
        .testimonials-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:60px}
        .testimonial-card{background:#fff;border:1px solid #E8E0D4;border-radius:16px;padding:32px}
        .stars{color:#F4C97A;font-size:16px;margin-bottom:16px}
        .testimonial-text{font-style:italic;color:#3D3D3A;line-height:1.75;margin-bottom:20px;font-size:14px}
        .testimonial-author{display:flex;align-items:center;gap:12px}
        .author-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#2D5A3D,#4A7C59);display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:16px}
        .author-name{font-weight:700;color:#1C3A2A;font-size:14px}
        .author-role{font-size:12px;color:#9CA3AF}
        .cta-section{background:linear-gradient(135deg,#1C3A2A 0%,#2D5A3D 100%);text-align:center;color:#fff}
        .cta-section h2{font-family:'Cormorant Garamond',serif;font-size:clamp(32px,3vw,52px);font-weight:800;margin-bottom:16px}
        .cta-section p{font-size:17px;color:rgba(255,255,255,.75);margin-bottom:40px}
        .land-footer{background:#12200E;color:rgba(255,255,255,.6);padding:60px 80px 32px}
        .footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px}
        .footer-brand-text{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:#fff;margin-bottom:12px}
        .footer-desc{font-size:13px;line-height:1.8}
        .footer-heading{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#F4C97A;margin-bottom:16px}
        .footer-links{list-style:none;padding:0}
        .footer-links li{margin-bottom:8px}
        .footer-links a{color:rgba(255,255,255,.55);font-size:13px;text-decoration:none;transition:color .2s}
        .footer-links a:hover{color:#F4C97A}
        .footer-bottom{border-top:1px solid rgba(255,255,255,.1);padding-top:28px;display:flex;justify-content:space-between;align-items:center;font-size:12px}
        .fade-up{opacity:0;transform:translateY(30px);transition:opacity .6s ease,transform .6s ease}
        .fade-up.visible{opacity:1;transform:none}
        .popular-badge{background:#C8761A;color:#fff;font-size:11px;font-weight:700;padding:4px 16px;border-radius:20px;display:inline-block;margin-bottom:16px;font-family:'Barlow Condensed',sans-serif;letter-spacing:.08em}
        @@media(max-width:1024px){.hero{padding:100px 40px 60px} section{padding:70px 40px} .stats-strip,.cta-section{padding:60px 40px} .features-grid,.pricing-grid,.testimonials-grid{grid-template-columns:1fr 1fr} .stats-grid{grid-template-columns:1fr 1fr;gap:24px} .land-footer{padding:60px 40px 32px} .footer-grid{grid-template-columns:1fr 1fr}}
        @@media(max-width:640px){.land-nav{padding:0 20px} .land-nav .nav-links{display:none} .hero{padding:90px 24px 60px} .hero-stats{gap:24px} section{padding:60px 24px} .stats-strip{padding:50px 24px} .stats-grid,.features-grid,.pricing-grid,.testimonials-grid{grid-template-columns:1fr} .price-card-popular{transform:none} .land-footer{padding:50px 24px 24px} .footer-grid{grid-template-columns:1fr} .footer-bottom{flex-direction:column;gap:8px;text-align:center}}
    </style>
</head>
<body>

<nav class="land-nav">
    <a href="/" class="brand"><span style="font-size:28px">🐄</span> Smart Cattle Farm</a>
    <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#pricing">Pricing</a>
        <a href="#testimonials">Reviews</a>
        <a href="#about">About</a>
    </div>
    <div class="nav-cta">
        <a href="/Account/Login" class="btn-land-outline" style="padding:10px 22px;font-size:14px">Sign In</a>
        <a href="/Account/Register" class="btn-land-primary" style="padding:10px 22px;font-size:14px">Get Started Free</a>
    </div>
</nav>

<section class="hero">
    <div class="hero-content">
        <div class="hero-badge">🏆 Bangladesh's #1 Farm Platform</div>
        <h1>Manage Your Farm<br />with <span>Industrial Precision</span></h1>
        <p>From cattle health tracking to financial reporting — everything your farm needs in one powerful, modern platform.</p>
        <div class="hero-actions">
            <a href="/Account/Register" class="btn-land-primary"><i class="bi bi-arrow-right-circle-fill"></i> Start Free Today</a>
            <a href="#features" class="btn-land-outline"><i class="bi bi-play-circle"></i> See Features</a>
        </div>
        <div class="hero-stats">
            <div><div class="hero-stat-num" id="statFarms">0</div><div class="hero-stat-label">Active Farms</div></div>
            <div><div class="hero-stat-num" id="statCattle">0</div><div class="hero-stat-label">Cattle Tracked</div></div>
            <div><div class="hero-stat-num" id="statUsers">0</div><div class="hero-stat-label">Farmers Served</div></div>
        </div>
    </div>
</section>

<div class="stats-strip">
    <div class="stats-grid">
        <div><div class="stat-big-num">৳2.4B+</div><div class="stat-big-label">Farm Revenue Managed</div></div>
        <div><div class="stat-big-num">99.9%</div><div class="stat-big-label">Platform Uptime</div></div>
        <div><div class="stat-big-num">50K+</div><div class="stat-big-label">Health Records Stored</div></div>
        <div><div class="stat-big-num">4.9★</div><div class="stat-big-label">Average User Rating</div></div>
    </div>
</div>

<section id="features">
    <div class="section-label">Platform Features</div>
    <h2 class="section-title">Everything Your Farm Needs</h2>
    <p class="section-sub">One platform to manage all aspects of your cattle farm — from health to finance.</p>
    <div class="features-grid">
        @foreach (var f in features)
        {
            <div class="feature-card fade-up">
                <div class="feature-icon">@f.Item1</div>
                <div class="feature-title">@f.Item2</div>
                <div class="feature-desc">@f.Item3</div>
            </div>
        }
    </div>
</section>

