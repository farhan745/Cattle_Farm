@{
    ViewData["Title"] = "Dashboard";
    var isAdmin  = User.IsInRole("Admin");
    var canCrud  = isAdmin || User.IsInRole("Manager");
    var roleName = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
}

<!-- ── Welcome Banner ── -->
<div class="card animate-in" style="margin-bottom:24px;border-left:4px solid var(--accent);background:linear-gradient(135deg, var(--bg-card) 0%, var(--primary-light) 100%);">
    <div class="card-body" style="padding:28px 24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;">
        <div>
            <h2 style="font-size:22px;font-weight:800;margin-bottom:4px;">🐄 Welcome, <strong>@User.Identity?.Name</strong>!</h2>
            <p style="font-size:13px;color:var(--text-secondary);margin:0;">
                CattleFarm Management System
                <span class="badge badge-primary" style="margin-left:8px;">@roleName</span>
            </p>
        </div>
        <a href="/Cattle" class="btn btn-primary btn-lg" id="dashboardViewCattleBtn">
            <i class="bi bi-list-ul"></i> View Cattle List
        </a>
    </div>
</div>

<!-- ── Quick Action Cards ── -->
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px;margin-bottom:24px;">
    <div class="card animate-in" style="text-align:center;">
        <div class="card-body" style="padding:32px 20px;">
            <div style="font-size:42px;margin-bottom:12px;">📋</div>
            <h3 style="font-size:16px;font-weight:700;margin-bottom:6px;">All Cattle</h3>
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">Browse, search, and view all cattle records in the farm.</p>
            <a href="/Cattle" class="btn btn-outline" id="dashboardAllCattleBtn">
                <i class="bi bi-eye"></i> Browse
            </a>
        </div>
    </div>

    @if (canCrud)
    {
        <div class="card animate-in" style="text-align:center;">
            <div class="card-body" style="padding:32px 20px;">
                <div style="font-size:42px;margin-bottom:12px;">➕</div>
                <h3 style="font-size:16px;font-weight:700;margin-bottom:6px;">Add New Cattle</h3>
                <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">Register a new cattle record with full details.</p>
                <a href="/Cattle/Create" class="btn btn-primary" id="dashboardAddCattleBtn">
                    <i class="bi bi-plus-circle"></i> Add Cattle
                </a>
            </div>
        </div>
    }

    <div class="card animate-in" style="text-align:center;">
        <div class="card-body" style="padding:32px 20px;">
            <div style="font-size:42px;margin-bottom:12px;">🔍</div>
            <h3 style="font-size:16px;font-weight:700;margin-bottom:6px;">Search Records</h3>
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">Find cattle by name or breed quickly.</p>
            <a href="/Cattle" class="btn btn-outline" id="dashboardSearchBtn">
                <i class="bi bi-search"></i> Search
            </a>
        </div>
    </div>
</div>

<!-- ── Role Notice ── -->
@if (!canCrud)
{
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle-fill" style="font-size:18px;flex-shrink:0"></i>
        <div>You are logged in as a <strong>User</strong>. You can view and search cattle records. Contact an <strong>Admin</strong> to upgrade your role.</div>
    </div>
}
else if (isAdmin)
{
    <div class="alert alert-success" role="alert">
        <i class="bi bi-shield-check" style="font-size:18px;flex-shrink:0"></i>
        <div>You have <strong>Admin</strong> access — full CRUD + User Management.</div>
    </div>
}
else
{
    <div class="alert alert-warning" role="alert">
        <i class="bi bi-person-badge" style="font-size:18px;flex-shrink:0"></i>
        <div>You have <strong>Manager</strong> access — you can Add, Edit, and Delete cattle records.</div>
    </div>
}
