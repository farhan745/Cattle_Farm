@model CattleFarm.Models.Farm
@{
    ViewData["Title"] = Model.Name;
    var canManageFarm = User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager");
    var activeFarmWorkers = Model.FarmWorkers.Where(fw => fw.IsActive && !fw.IsDeleted).ToList();
    var membershipUserIds = activeFarmWorkers.Select(fw => fw.WorkerUserId).ToHashSet();
    var membershipEmails = activeFarmWorkers
        .Select(fw => fw.WorkerUser?.Email)
        .Where(email => !string.IsNullOrWhiteSpace(email))
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
    var directWorkers = Model.Workers
        .Where(w => w.IsActive && !w.IsDeleted &&
            (!w.UserId.HasValue || !membershipUserIds.Contains(w.UserId.Value)) &&
            (string.IsNullOrWhiteSpace(w.Email) || !membershipEmails.Contains(w.Email)))
        .ToList();
    var workerCount = activeFarmWorkers.Count + directWorkers.Count;
}
<div class="page-header">
    <div>
        <h1 class="page-title"> @Model.Name</h1>
        <p class="page-subtitle">@Model.Location — @Model.FarmType Farm</p>
    </div>
    <div class="page-actions" style="display:flex;gap:8px;align-items:center">
        @if (canManageFarm)
        {
            <a href="/Farm/Edit/@Model.Id" class="btn btn-outline"><i class="bi bi-pencil"></i> Edit</a>
        }
        @if (User.IsInRole("Admin"))
        {
            <form method="post" asp-action="Delete" asp-route-id="@Model.Id" onsubmit="return confirm('Are you sure you want to delete this farm? This action cannot be undone.');" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
            </form>
        }
        <a href="/Farm" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 340px;gap:24px;align-items:start">
    <div style="display:flex;flex-direction:column;gap:20px">

        <!-- Farm Image Banner -->
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <div class="card" style="padding:0;overflow:hidden">
                <img src="@Model.ImagePath" alt="@Model.Name" style="width:100%;height:260px;object-fit:cover" />
            </div>
        }

        <!-- Cattle -->
        <div class="card">
            <div class="card-header" style="display:flex;justify-content:space-between;align-items:center">
                <h3 class="card-title">🐄 Cattle (@Model.Cattles.Count)</h3>
                @if (canManageFarm)
                {
                    <a href="/Cattle/Create?farmId=@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Add</a>
                }
            </div>
            <div class="table-wrapper">
                @if (!Model.Cattles.Any())
                { <div class="empty-state" style="padding:24px"><div class="empty-icon">🐄</div><p>No cattle registered</p></div> }
                else
                {
                    <table class="data-table">
                        <thead><tr><th>Name</th><th>Breed</th><th>Health</th><th>Status</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var c in Model.Cattles.Take(5))
                            {
                                <tr>
                                    <td style="font-weight:600">@c.Name <span style="font-size:11px;color:var(--text-muted)">@c.TagId</span></td>
                                    <td style="font-size:12px">@c.Breed</td>
                                    <td><span class="badge @(c.HealthStatus == CattleFarm.Models.HealthStatus.Healthy ? "badge-success" : "badge-danger")">@c.HealthStatus</span></td>
                                    <td><span class="badge badge-gray">@c.Status</span></td>
                                    <td><a href="/Cattle/Details/@c.Id" class="btn btn-ghost btn-sm">View</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (Model.Cattles.Count > 5)
                    { <div style="padding:10px 16px;font-size:12px;color:var(--text-muted)"><a href="/Cattle?farmId=@Model.Id">View all @Model.Cattles.Count cattle →</a></div> }
                }
            </div>
        </div>

        <!-- Workers -->
        <div class="card">
            <div class="card-header" style="display:flex;justify-content:space-between;align-items:center">
                <h3 class="card-title">👷 Workers (@workerCount)</h3>
                @if (canManageFarm)
                {
                    <a href="/Worker/Create?farmId=@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Hire</a>
                }
            </div>
            <div class="card-body">
                @if (workerCount == 0)
                { <div class="empty-state" style="padding:16px"><div class="empty-icon">👷</div><p>No workers assigned</p></div> }
                else
                {
                    <div style="display:flex;flex-wrap:wrap;gap:10px">
                        @foreach (var fw in activeFarmWorkers.Take(6))
                        {
                            var profile = Model.Workers.FirstOrDefault(w => w.UserId == fw.WorkerUserId && !w.IsDeleted)
                                ?? Model.Workers.FirstOrDefault(w => !w.IsDeleted &&
                                    w.FarmId == Model.Id &&
                                    !string.IsNullOrWhiteSpace(w.Email) &&
                                    w.Email == fw.WorkerUser?.Email);
                            var name = profile?.FullName ?? fw.WorkerUser?.FullName ?? "Worker";
                            var roleText = profile?.Role ?? fw.Position;
                            var salary = (profile?.Salary ?? 0) > 0 ? profile!.Salary : fw.Salary;
                            var imagePath = profile?.ImagePath ?? fw.WorkerUser?.ProfileImagePath;
                            var initial = string.IsNullOrWhiteSpace(name) ? "W" : name.Trim()[0].ToString().ToUpperInvariant();
                            var workerUrl = profile != null ? $"/Worker/Details/{profile.Id}" : "#";

                            <a href="@workerUrl" style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--bg);border-radius:8px;text-decoration:none;border:1px solid var(--border)">
                                @if (!string.IsNullOrWhiteSpace(imagePath))
                                {
                                    <img src="@imagePath" alt="@name" style="width:32px;height:32px;border-radius:50%;object-fit:cover;border:1px solid var(--border)" />
                                }
                                else
                                {
                                    <div style="width:32px;height:32px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--primary);font-size:13px">@initial</div>
                                }
                                <div>
                                    <div style="font-size:13px;font-weight:600;color:var(--text-primary)">@name</div>
                                    <div style="font-size:11px;color:var(--text-muted)">@roleText · @Currency.Format(salary)</div>
                                </div>
                            </a>
                        }
                        @foreach (var w in directWorkers.Take(Math.Max(0, 6 - activeFarmWorkers.Count)))
                        {
                            var imagePath = w.ImagePath;
                            var initial = string.IsNullOrWhiteSpace(w.FullName) ? "W" : w.FullName.Trim()[0].ToString().ToUpperInvariant();
                            <a href="/Worker/Details/@w.Id" style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--bg);border-radius:8px;text-decoration:none;border:1px solid var(--border)">
                                @if (!string.IsNullOrWhiteSpace(imagePath))
                                {
                                    <img src="@imagePath" alt="@w.FullName" style="width:32px;height:32px;border-radius:50%;object-fit:cover;border:1px solid var(--border)" />
                                }
                                else
                                {
                                    <div style="width:32px;height:32px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--primary);font-size:13px">@initial</div>
                                }
                                <div>
                                    <div style="font-size:13px;font-weight:600;color:var(--text-primary)">@w.FullName</div>
                                    <div style="font-size:11px;color:var(--text-muted)">@w.Role · @Currency.Format(w.Salary)</div>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right sidebar info -->
    <div style="display:flex;flex-direction:column;gap:16px">
        <!-- Approval Status -->
        <div class="card">
            <div class="card-body">
                @{
                    var (apColor, apIcon, apLabel) = Model.ApprovalStatus switch {
                        CattleFarm.Models.ApprovalStatus.Approved => ("var(--success)", "✅", "Approved"),
                        CattleFarm.Models.ApprovalStatus.Rejected => ("var(--danger)",  "❌", "Rejected"),
                        _                                         => ("var(--warning)", "⏳", "Pending Approval")
                    };
                }
                <div style="text-align:center;padding:10px 0">
                    <div style="font-size:28px">@apIcon</div>
                    <div style="font-size:13px;font-weight:700;color:@apColor;margin-top:4px">@apLabel</div>
                </div>
                @if (User.IsInRole("Admin") && Model.ApprovalStatus == CattleFarm.Models.ApprovalStatus.Pending)
                {
                    <div style="display:flex;gap:10px;margin-top:8px">
                        <form method="post" asp-action="Approve" style="flex:1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary w-100">✅ Approve</button>
                        </form>
                        <form method="post" asp-action="Reject" style="flex:1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger w-100">❌ Reject</button>
                        </form>
                    </div>
                }
            </div>
        </div>

        <!-- Farm Info -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">📊 Farm Info</h3></div>
            <div class="card-body">
                @{
                    var infoRows = new[] {
                        ("🏷️ Type",     Model.FarmType.ToString()),
                        ("📐 Size",     $"{Model.SizeInAcres} acres"),
                        ("🐄 Capacity", $"{Model.Capacity} cattle"),
                        ("👤 Owner",    Model.Owner?.FullName ?? "—"),
                        ("📅 Registered", Model.CreatedAt.ToString("MMM dd, yyyy"))
                    };
                }
                @foreach (var (label, value) in infoRows)
                {
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px">
                        <span style="color:var(--text-muted)">@label</span>
                        <span style="font-weight:600;text-align:right;max-width:60%">@value</span>
                    </div>
                }
                @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                {
                    <div style="margin-top:12px">
                        <a href="https://maps.google.com/?q=@Model.Latitude,@Model.Longitude" target="_blank" class="btn btn-outline w-100 btn-sm">
                            <i class="bi bi-geo-alt-fill"></i> View on Google Maps
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- Description -->
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="card">
                <div class="card-header"><h3 class="card-title">📝 Description</h3></div>
                <div class="card-body" style="font-size:13px;color:var(--text-secondary);line-height:1.6">@Model.Description</div>
            </div>
        }
    </div>
</div>
