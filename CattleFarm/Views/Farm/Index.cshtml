@model IEnumerable<CattleFarm.Models.Farm>
@{
    ViewData["Title"] = "Farms";
    int currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    int totalPages  = (int)(ViewData["TotalPages"]  ?? 1);
}

<div class="page-header">
    <div>
        <h1 class="page-title">🏡 Farms</h1>
        <p class="page-subtitle">@Model.Count() farms registered on the platform</p>
    </div>
    <div class="page-actions">
        @if (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager"))
        {
            <a href="/Farm/Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Register Farm</a>
        }
    </div>
</div>

<!-- Search -->
<div class="card" style="margin-bottom:20px">
    <div class="card-body" style="padding:14px">
        <form method="get" style="display:flex;gap:12px">
            <div style="position:relative;flex:1">
                <input name="search" value="@ViewData["Search"]" placeholder="Search farms by name or location..." class="form-control" style="padding-left:34px" />
                <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-muted)"></i>
            </div>
            <button type="submit" class="btn btn-primary">Search</button>
            <a href="/Farm" class="btn btn-outline">Reset</a>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state"><div class="empty-icon">🏡</div><h3>No farms found</h3></div>
}
else
{
    <div class="cattle-grid">
        @foreach (var farm in Model)
        {
            <div class="cattle-card">
                <div class="cattle-card-img" style="height:160px">
                    @if (!string.IsNullOrEmpty(farm.ImagePath)) { <img src="@farm.ImagePath" alt="@farm.Name" style="height:160px" /> }
                    else { <span style="font-size:48px">🏡</span> }
                </div>
                <div class="cattle-card-body">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start">
                        <div>
                            <div class="cattle-card-title">@farm.Name</div>
                            <div class="cattle-card-meta">📍 @farm.Location</div>
                        </div>
                        @{
                            var apBadge = farm.ApprovalStatus switch { CattleFarm.Models.ApprovalStatus.Approved => "badge-success", CattleFarm.Models.ApprovalStatus.Rejected => "badge-danger", _ => "badge-warning" };
                        }
                        <span class="badge @apBadge">@farm.ApprovalStatus</span>
                    </div>
                    <div style="display:flex;gap:16px;margin-top:10px;font-size:12px;color:var(--text-secondary)">
                        <span>🐄 @farm.Cattles.Count cattle</span>
                        <span>📐 @farm.SizeInAcres acres</span>
                        <span>🏷️ @farm.FarmType</span>
                    </div>
                </div>
                <div class="cattle-card-footer">
                    <span style="font-size:12px;color:var(--text-muted)">Owner: @(farm.Owner?.FullName ?? "—")</span>
                    <div style="display:flex;gap:6px">
                        <a href="/Farm/Details/@farm.Id" class="btn btn-outline btn-sm">View</a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager"))
                        {
                            <a href="/Farm/Edit/@farm.Id" class="btn btn-ghost btn-sm"><i class="bi bi-pencil"></i></a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
    @if (totalPages > 1)
    {
        <div class="pagination">
            @if (currentPage > 1) { <a href="?page=@(currentPage-1)&search=@ViewData["Search"]" class="page-link"><i class="bi bi-chevron-left"></i></a> }
            @for (int i = Math.Max(1, currentPage-2); i <= Math.Min(totalPages, currentPage+2); i++)
            { <a href="?page=@i&search=@ViewData["Search"]" class="page-link @(i==currentPage?"active":"")">@i</a> }
            @if (currentPage < totalPages) { <a href="?page=@(currentPage+1)&search=@ViewData["Search"]" class="page-link"><i class="bi bi-chevron-right"></i></a> }
        </div>
    }
}
