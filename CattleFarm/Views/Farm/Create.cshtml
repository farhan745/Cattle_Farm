@model CattleFarm.ViewModels.FarmViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Register Farm" : "Edit Farm";
    var isEdit = Model.Id > 0;
}
<div class="page-header">
    <div>
        <h1 class="page-title">@(isEdit ? "✏️ Edit Farm" : "🏡 Register New Farm")</h1>
        <p class="page-subtitle">@(isEdit ? $"Editing {Model.Name}" : "Complete the form to register your farm")</p>
    </div>
    <a href="/Farm" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    <div style="display:grid;grid-template-columns:1fr 300px;gap:24px;align-items:start">
        <div style="display:flex;flex-direction:column;gap:20px">
            <div class="card">
                <div class="card-header"><h3 class="card-title">📋 Farm Details</h3></div>
                <div class="card-body">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                        <div class="form-group" style="grid-column:1/-1">
                            <label class="form-label">Farm Name *</label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Green Valley Farm" />
                            <span asp-validation-for="Name" class="form-error"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Farm Type</label>
                            <select asp-for="FarmType" class="form-control" asp-items="Html.GetEnumSelectList<CattleFarm.Models.FarmType>()"></select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Size (Acres) *</label>
                            <input asp-for="SizeInAcres" class="form-control" type="number" step="0.1" placeholder="0.0" />
                            <span asp-validation-for="SizeInAcres" class="form-error"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Capacity (Cattle)</label>
                            <input asp-for="Capacity" class="form-control" type="number" placeholder="100" />
                        </div>
                        <div class="form-group" style="grid-column:1/-1">
                            <label class="form-label">Location *</label>
                            <input asp-for="Location" class="form-control" placeholder="e.g. Savar, Dhaka" />
                            <span asp-validation-for="Location" class="form-error"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">GPS Latitude</label>
                            <input asp-for="Latitude" class="form-control" type="number" step="0.000001" placeholder="23.8103" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">GPS Longitude</label>
                            <input asp-for="Longitude" class="form-control" type="number" step="0.000001" placeholder="90.4125" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description of the farm..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Image Upload -->
        <div style="display:flex;flex-direction:column;gap:20px">
            <div class="card">
                <div class="card-header"><h3 class="card-title">🖼️ Farm Image</h3></div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ExistingImagePath))
                    { <img id="farmPreview" src="@Model.ExistingImagePath" style="width:100%;height:200px;object-fit:cover;border-radius:8px;margin-bottom:12px" /> }
                    else
                    { <div id="farmPlaceholder" style="width:100%;height:200px;background:var(--bg);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:48px;margin-bottom:12px">🏡</div>
                      <img id="farmPreview" style="display:none;width:100%;height:200px;object-fit:cover;border-radius:8px;margin-bottom:12px" /> }
                    <label class="img-upload-zone" for="farmImageInput">
                        <div style="font-size:24px;margin-bottom:4px">📷</div>
                        <div style="font-size:13px;font-weight:600">Click to upload farm image</div>
                        <div style="font-size:11px;color:var(--text-muted)">JPG, PNG — max 5MB</div>
                    </label>
                    <input type="file" name="ImageFile" id="farmImageInput" accept="image/*" style="display:none"
                           onchange="previewImage(this,'farmPreview');document.getElementById('farmPlaceholder')?.remove()" />
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        <i class="bi bi-@(isEdit ? "check-circle" : "plus-circle")"></i>
                        @(isEdit ? "Save Changes" : "Register Farm")
                    </button>
                    <a href="/Farm" class="btn btn-outline w-100" style="margin-top:10px">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</form>
