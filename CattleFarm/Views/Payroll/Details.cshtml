@model CattleFarm.ViewModels.PayrollViewModel
@{
    var monthName = new System.Globalization.DateTimeFormatInfo().GetMonthName(Model.Month);
    ViewData["Title"] = $"Salary Slip - {monthName} {Model.Year}";
    bool isAdminOrOwner = User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager");
    var backUrl = isAdminOrOwner ? "/Payroll" : $"/Employee/Details/{Model.UserId}";
    var totalEarnings = Model.BaseSalary + Model.Bonus + Model.OvertimePay;
}

@section Styles {
<style>
    .slip-container {
        max-width: 800px;
        margin: 0 auto;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 4px 20px rgba(0,0,0,.05);
        position: relative;
    }

    .slip-header {
        border-bottom: 2px dashed var(--border);
        padding-bottom: 24px;
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: start;
    }

    .slip-title {
        text-align: right;
    }

    .slip-meta-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .slip-section-title {
        font-size: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border);
        padding-bottom: 8px;
        margin-bottom: 16px;
    }

    .salary-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 30px;
    }

    .salary-table th {
        text-align: left;
        padding: 10px 12px;
        background: #f8fafc;
        border-bottom: 2px solid var(--border);
        font-size: 12px;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .salary-table td {
        padding: 12px;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
    }

    .net-salary-box {
        background: var(--primary-light);
        border: 1px solid var(--primary);
        border-radius: 10px;
        padding: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 20px;
    }

    @@media print {
        body * {
            visibility: hidden;
        }
        .slip-container, .slip-container * {
            visibility: visible;
        }
        .slip-container {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            border: none;
            box-shadow: none;
            padding: 0;
        }
        .no-print {
            display: none !important;
        }
    }
</style>
}

<div class="page-header no-print">
    <div>
        <h1 class="page-title">📄 Salary Slip</h1>
        <p class="page-subtitle">Detailed monthly breakdown of worker salary</p>
    </div>
    <div style="display:flex;gap:10px">
        <a href="@backUrl" class="btn btn-outline">
            <i class="bi bi-arrow-left"></i> Back
        </a>
        <button onclick="window.print()" class="btn btn-outline">
            <i class="bi bi-printer"></i> Print Slip
        </button>
        @if (isAdminOrOwner)
        {
            <a href="/Payroll/Edit/@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Adjust / Edit
            </a>
        }
    </div>
</div>

<div class="slip-container">
    @* Paid / Unpaid absolute badge *@
    <div style="position:absolute;top:40px;right:40px" class="no-print">
        <span class="badge @(Model.IsPaid ? "badge-success" : "badge-danger")" style="padding:8px 16px;font-size:13.5px;font-weight:700">
            @(Model.IsPaid ? "PAID" : "UNPAID")
        </span>
    </div>

    @* Slip Header *@
    <div class="slip-header">
        <div>
            <h2 style="font-weight:800;color:var(--primary);font-size:24px;margin:0 0 4px">🚜 CATTLE FARM</h2>
            <span style="font-size:13.5px;color:var(--text-muted)">High-productivity Operations & Agro</span>
        </div>
        <div class="slip-title">
            <h3 style="font-weight:800;font-size:20px;margin:0 0 4px">SALARY SLIP</h3>
            <span style="font-size:14.5px;font-weight:600">For @monthName @Model.Year</span>
        </div>
    </div>

    @* Meta Grid *@
    <div class="slip-meta-grid">
        <div>
            <div class="slip-section-title">Employee Details</div>
            <div style="display:flex;flex-direction:column;gap:6px;font-size:14px">
                <div><span style="color:var(--text-muted)">Name:</span> <strong>@Model.WorkerName</strong></div>
                <div><span style="color:var(--text-muted)">Designation:</span> Worker / Staff</div>
                <div><span style="color:var(--text-muted)">Employee ID:</span> #@Model.WorkerId</div>
            </div>
        </div>
        <div>
            <div class="slip-section-title">Payment Details</div>
            <div style="display:flex;flex-direction:column;gap:6px;font-size:14px">
                <div><span style="color:var(--text-muted)">Slip ID:</span> #@Model.Id</div>
                <div><span style="color:var(--text-muted)">Generated:</span> @Model.GeneratedAt.ToString("MMM dd, yyyy")</div>
                <div><span style="color:var(--text-muted)">Status:</span> <strong style="color:@(Model.IsPaid ? "var(--success)" : "var(--danger)")">@(Model.IsPaid ? "PAID" : "UNPAID")</strong></div>
            </div>
        </div>
    </div>

    @* Salary Breakdown Tables *@
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:30px">
        <div>
            <div class="slip-section-title">Earnings</div>
            <table class="salary-table">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th style="text-align:right">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Base Salary</td>
                        <td style="text-align:right;font-weight:500">@Currency.Format(Model.BaseSalary)</td>
                    </tr>
                    <tr>
                        <td>Overtime Pay (@Model.OvertimeHours hrs)</td>
                        <td style="text-align:right;color:var(--success)">+@Currency.Format(Model.OvertimePay)</td>
                    </tr>
                    <tr>
                        <td>Bonus Incentives</td>
                        <td style="text-align:right;color:var(--success)">+@Currency.Format(Model.Bonus)</td>
                    </tr>
                    <tr style="font-weight:700">
                        <td>Gross Earnings</td>
                        <td style="text-align:right;border-top:1px solid var(--border)">@Currency.Format(totalEarnings)</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div>
            <div class="slip-section-title">Deductions</div>
            <table class="salary-table">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th style="text-align:right">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Unpaid Leaves / Penalties</td>
                        <td style="text-align:right;color:var(--danger)">-@Currency.Format(Model.Deductions)</td>
                    </tr>
                    <tr style="height:37px">
                        <td></td>
                        <td></td>
                    </tr>
                    <tr style="height:37px">
                        <td></td>
                        <td></td>
                    </tr>
                    <tr style="font-weight:700">
                        <td>Total Deductions</td>
                        <td style="text-align:right;border-top:1px solid var(--border);color:var(--danger)">-@Currency.Format(Model.Deductions)</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    @* Net Salary Callout Box *@
    <div class="net-salary-box">
        <div>
            <h4 style="font-weight:700;font-size:14px;color:var(--primary);margin:0 0 2px">NET SALARY PAYOUT</h4>
            <span style="font-size:11.5px;color:var(--text-muted)">Amount Credited / Payable</span>
        </div>
        <div style="font-size:24px;font-weight:800;color:var(--primary)">
            @Currency.Format(Model.NetSalary)
        </div>
    </div>

    @* Signature Lines (visible when printing) *@
    <div style="margin-top:80px;display:flex;justify-content:space-between;font-size:13px;padding:0 20px" class="only-print">
        <div style="border-top:1px solid var(--text);width:180px;text-align:center;padding-top:6px">
            Employee Signature
        </div>
        <div style="border-top:1px solid var(--text);width:180px;text-align:center;padding-top:6px">
            Authorized Signatory
        </div>
    </div>
</div>
