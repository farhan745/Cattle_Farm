@model CattleFarm.ViewModels.PayrollGenerateViewModel
@{
    ViewData["Title"] = "Generate Payroll";
}

<div class="page-header">
    <div>
        <h1 class="page-title">⚙️ Generate Monthly Payroll</h1>
        <p class="page-subtitle">Bulk-initialize payroll entries for all active workers for a specific month and year</p>
    </div>
    <a href="/Payroll" class="btn btn-outline">
        <i class="bi bi-arrow-left"></i> Back to Payroll
    </a>
</div>

<div style="max-width:560px">
    <form asp-action="Generate" method="post">
        @Html.AntiForgeryToken()

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">📅 Select Payroll Period</h3>
            </div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:18px">
                <div class="form-group">
                    <label class="form-label" for="Year">Year *</label>
                    <select asp-for="Year" class="form-control">
                        @{
                            int currentYear = DateTime.Today.Year;
                            for (int y = currentYear - 3; y <= currentYear + 2; y++)
                            {
                                <option value="@y">@y</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="Year" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" for="Month">Month *</label>
                    <select asp-for="Month" class="form-control">
                        @for (int m = 1; m <= 12; m++)
                        {
                            var mName = new System.Globalization.DateTimeFormatInfo().GetMonthName(m);
                            <option value="@m">@mName</option>
                        }
                    </select>
                    <span asp-validation-for="Month" class="form-error"></span>
                </div>

                <div style="background:rgba(99,102,241,.06);border:1px solid rgba(99,102,241,.15);border-radius:10px;padding:14px 16px;display:flex;gap:12px;align-items:start;margin-top:4px">
                    <i class="bi bi-info-circle-fill" style="color:var(--primary);font-size:18px;margin-top:2px"></i>
                    <div style="font-size:12.5px;line-height:1.45;color:var(--text-muted)">
                        <strong>Important:</strong> Generating payroll will create new records for all active, non-deleted workers. Already existing payroll entries for the chosen period will not be overwritten or duplicated.
                    </div>
                </div>

                <div style="display:flex;gap:10px;padding-top:10px">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-play-circle"></i> Generate Payroll
                    </button>
                    <a href="/Payroll" class="btn btn-outline">Cancel</a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
