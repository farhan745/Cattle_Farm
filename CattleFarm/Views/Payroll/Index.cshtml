@model IEnumerable<CattleFarm.ViewModels.PayrollViewModel>
@{
    ViewData["Title"] = "Payroll Management";
    var payrolls = Model.ToList();
    var totalCost = payrolls.Sum(p => p.NetSalary);
    var paidCount = payrolls.Count(p => p.IsPaid);
    var unpaidCount = payrolls.Count(p => !p.IsPaid);
    bool isAdminOrOwner = User.IsInRole("Admin") || User.IsInRole("Owner");
}

@section Styles {
<style>
    .pay-stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .pay-stat-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
        transition: transform .2s, box-shadow .2s;
    }

    .pay-stat-card:hover { 
        transform: translateY(-2px); 
        box-shadow: 0 6px 20px rgba(0,0,0,.08); 
    }

    .pay-stat-icon {
        width: 44px; height: 44px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .pay-stat-value { font-size: 24px; font-weight: 800; line-height: 1; }
    .pay-stat-label { font-size: 12px; color: var(--text-muted); margin-top: 3px; }

    .filter-bar {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
        padding: 14px 18px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: 16px;
    }

    .filter-bar input, .filter-bar select {
        padding: 8px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--bg);
        color: var(--text);
        font-size: 13px;
        font-family: inherit;
    }

    .filter-bar input:focus, .filter-bar select:focus {
        outline: none;
        border-color: var(--primary);
    }
</style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">💰 Payroll Management</h1>
        <p class="page-subtitle">Manage employee salaries, bonuses, deductions, and payout statuses</p>
    </div>
    <div>
        @if (isAdminOrOwner)
        {
            <a href="/Payroll/Generate" class="btn btn-primary">
                <i class="bi bi-gear-fill"></i> Generate Monthly Payroll
            </a>
        }
    </div>
</div>

@* ── Stats Row ────────────────────────────────────────────── *@
<div class="pay-stats-grid">
    <div class="pay-stat-card">
        <div class="pay-stat-icon" style="background:rgba(99,102,241,.12)"><i class="bi bi-cash-stack" style="color:#6366f1"></i></div>
        <div>
            <div class="pay-stat-value" style="color:var(--primary)">@Currency.Format(totalCost)</div>
            <div class="pay-stat-label">Total Monthly Payout</div>
        </div>
    </div>
    <div class="pay-stat-card">
        <div class="pay-stat-icon" style="background:rgba(16,185,129,.12)"><i class="bi bi-check-circle" style="color:#10b981"></i></div>
        <div>
            <div class="pay-stat-value" style="color:#10b981">@paidCount</div>
            <div class="pay-stat-label">Paid Slips</div>
        </div>
    </div>
    <div class="pay-stat-card">
        <div class="pay-stat-icon" style="background:rgba(239,68,68,.12)"><i class="bi bi-exclamation-circle" style="color:#ef4444"></i></div>
        <div>
            <div class="pay-stat-value" style="color:#ef4444">@unpaidCount</div>
            <div class="pay-stat-label">Pending Payouts</div>
        </div>
    </div>
</div>

@* ── Filter Bar ───────────────────────────────────────────── *@
<div class="filter-bar">
    <i class="bi bi-funnel" style="color:var(--text-muted)"></i>
    <input type="text" id="searchInput" placeholder="Search employee name…" oninput="filterTable()" style="min-width:240px" />
    <select id="statusFilter" onchange="filterTable()">
        <option value="">All Statuses</option>
        <option value="Paid">Paid</option>
        <option value="Unpaid">Unpaid</option>
    </select>
    <button class="btn btn-ghost btn-sm" onclick="clearFilters()"><i class="bi bi-x-circle"></i> Clear</button>
    <span style="margin-left:auto;font-size:12px;color:var(--text-muted)">
        Showing <strong id="visibleCount">@payrolls.Count</strong> of @payrolls.Count records
    </span>
</div>

@* ── Table ────────────────────────────────────────────────── *@
<div class="card">
    <div class="table-wrapper">
        <table class="data-table" id="payrollIndexTable">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Salary Month</th>
                    <th>Base Salary</th>
                    <th>Bonus / Overtime</th>
                    <th>Deductions</th>
                    <th>Net Payout</th>
                    <th>Status</th>
                    <th style="text-align:center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!payrolls.Any())
                {
                    <tr>
                        <td colspan="8" style="text-align:center;padding:48px 20px;color:var(--text-muted)">
                            <div style="font-size:48px;margin-bottom:12px">💰</div>
                            <div style="font-weight:600;margin-bottom:6px">No payroll records found</div>
                            @if (isAdminOrOwner)
                            {
                                <a href="/Payroll/Generate" class="btn btn-primary btn-sm" style="margin-top:8px">
                                    Generate Monthly Payroll Now
                                </a>
                            }
                        </td>
                    </tr>
                }
                @foreach (var p in payrolls)
                {
                    var statusText = p.IsPaid ? "Paid" : "Unpaid";
                    var badgeCss = p.IsPaid ? "badge-success" : "badge-danger";
                    var monthName = new System.Globalization.DateTimeFormatInfo().GetMonthName(p.Month);

                    <tr data-name="@p.WorkerName.ToLower()"
                        data-status="@statusText">
                        <td>
                            <div style="display:flex;align-items:center;gap:8px">
                                <div style="width:30px;height:30px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;color:var(--primary);flex-shrink:0">
                                    @(!string.IsNullOrEmpty(p.WorkerName) ? string.Join("", p.WorkerName.Split(' ').Take(2).Select(w => w[0])).ToUpper() : "W")
                                </div>
                                <span style="font-weight:600">@p.WorkerName</span>
                            </div>
                        </td>
                        <td style="font-weight:500">@monthName @p.Year</td>
                        <td style="color:var(--text-muted)">@Currency.Format(p.BaseSalary)</td>
                        <td style="color:var(--success)">
                            +@Currency.Format(p.Bonus + p.OvertimePay)
                            @if (p.OvertimeHours > 0)
                            {
                                <span style="font-size:11px;color:var(--text-muted);display:block">(@p.OvertimeHours hrs OT)</span>
                            }
                        </td>
                        <td style="color:var(--danger)">-@Currency.Format(p.Deductions)</td>
                        <td style="font-weight:700;font-size:14.5px;color:var(--primary)">@Currency.Format(p.NetSalary)</td>
                        <td>
                            <span class="badge @badgeCss">@statusText</span>
                        </td>
                        <td style="text-align:center">
                            <div style="display:flex;gap:6px;justify-content:center">
                                <a href="/Payroll/Details/@p.Id" class="btn btn-outline btn-sm" title="View Slip">
                                    View
                                </a>
                                @if (isAdminOrOwner)
                                {
                                    <a href="/Payroll/Edit/@p.Id" class="btn btn-ghost btn-sm" title="Adjust / Pay">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="/Payroll/Delete/@p.Id" class="btn btn-ghost btn-sm" title="Delete">
                                        <i class="bi bi-trash text-danger"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    function filterTable() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const status = document.getElementById('statusFilter').value;
        const rows = document.querySelectorAll('#payrollIndexTable tbody tr[data-name]');
        let visible = 0;

        rows.forEach(row => {
            const nameMatch = !search || row.dataset.name.includes(search);
            const statusMatch = !status || row.dataset.status === status;
            const show = nameMatch && statusMatch;
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        document.getElementById('visibleCount').textContent = visible;
    }

    function clearFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('statusFilter').value = '';
        filterTable();
    }
</script>
}
