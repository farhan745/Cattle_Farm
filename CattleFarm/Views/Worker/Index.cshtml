@model IEnumerable<CattleFarm.Models.Worker>
@{
    ViewData["Title"] = "Workers";
    int currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    int totalPages  = (int)(ViewData["TotalPages"]  ?? 1);
}
<div class="page-header">
    <div><h1 class="page-title">👷 Workers</h1><p class="page-subtitle">Farm workforce management</p></div>
    <div class="page-actions" style="display:flex;gap:10px">
        <a href="/Attendance/Mark" class="btn btn-outline"><i class="bi bi-pencil-square"></i> Mark Attendance</a>
        <a href="/Worker/Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Hire Worker</a>
    </div>
</div>
<div class="card">
    <div class="table-wrapper">
        <table class="data-table">
            <thead><tr><th>Worker</th><th>Role</th><th>Farm</th><th>Salary</th><th>Experience</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var w in Model)
                {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px">
                                @if (!string.IsNullOrEmpty(w.ImagePath)) { <img src="@w.ImagePath" style="width:36px;height:36px;border-radius:50%;object-fit:cover" /> }
                                else { <div style="width:36px;height:36px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--primary)">@w.FullName.FirstOrDefault()</div> }
                                <div><div style="font-weight:600">@w.FullName</div><div style="font-size:11px;color:var(--text-muted)">@w.Phone</div></div>
                            </div>
                        </td>
                        <td><span class="badge badge-info">@w.Role</span></td>
                        <td style="font-size:12px">@(w.Farm?.Name ?? "—")</td>
                        <td style="font-weight:600">@Currency.Format(w.Salary)</td>
                        <td style="font-size:13px">@w.ExperienceYears yrs</td>
                        <td><span class="badge @(w.IsAvailable ? "badge-success" : "badge-gray")">@(w.IsAvailable ? "Available" : "Busy")</span></td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <a href="/Worker/Details/@w.Id" class="btn btn-outline btn-sm">View</a>
                                <a href="/Worker/Edit/@w.Id" class="btn btn-ghost btn-sm"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="/Worker/Delete/@w.Id" style="display:inline">@Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-ghost btn-sm" onclick="return confirm('Delete this worker?')"><i class="bi bi-trash text-danger"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
