@model CattleFarm.Models.Worker
@{
    ViewData["Title"] = $"{Model.FullName} — Details";
    var salaryHistory = ViewBag.SalaryHistory as List<CattleFarm.Models.SalaryHistory> ?? new();
}

<div class="page-header">
    <div>
        <h1 class="page-title">👷 @Model.FullName</h1>
        <p class="page-subtitle">@Model.Role • @(Model.Farm?.Name ?? "No Assigned Farm")</p>
    </div>
    <div class="page-actions">
        <a href="/Worker" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Back to List</a>
        @if (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager"))
        {
            <a href="/Worker/Edit/@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a>
        }
    </div>
</div>

<div style="display:grid;grid-template-columns:320px 1fr;gap:24px;align-items:start">
    <!-- Left Column: Avatar & Status & Contact Info -->
    <div style="display:flex;flex-direction:column;gap:16px">
        <!-- Card: Profile Summary -->
        <div class="card">
            <div style="padding:24px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:16px;background:linear-gradient(to bottom, #f8fafc, #ffffff);border-bottom:1px solid var(--border)">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" alt="@Model.FullName" style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:3px solid var(--primary);box-shadow:var(--shadow-md)" />
                }
                else
                {
                    <div style="width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);display:flex;align-items:center;justify-content:center;font-size:44px;font-weight:800;color:#ffffff;box-shadow:0 8px 16px rgba(34, 197, 94, 0.2)">
                        @Model.FullName.FirstOrDefault()
                    </div>
                }
                <div>
                    <h2 style="font-family:var(--font-heading);font-size:18px;font-weight:800;color:var(--text-primary);margin-bottom:4px">@Model.FullName</h2>
                    <span class="badge badge-info" style="font-size:12px;padding:4px 10px">@Model.Role</span>
                </div>
            </div>
            <div class="card-body" style="padding:20px;display:flex;flex-direction:column;gap:12px">
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <span style="font-size:13px;color:var(--text-secondary);font-weight:600">Availability</span>
                    <span class="badge @(Model.IsAvailable ? "badge-success" : "badge-gray")">
                        @(Model.IsAvailable ? "Available" : "Busy")
                    </span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <span style="font-size:13px;color:var(--text-secondary);font-weight:600">Employment Status</span>
                    <span class="badge @(Model.IsActive ? "badge-success" : "badge-danger")">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
                <hr style="border:0;border-top:1px solid var(--border);margin:8px 0" />
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:13px">
                    <div>
                        <div style="color:var(--text-muted);font-size:10px;font-weight:700;text-transform:uppercase">Salary</div>
                        <div style="font-weight:700;color:var(--primary);font-size:15px">@Currency.Format(Model.Salary)</div>
                    </div>
                    <div>
                        <div style="color:var(--text-muted);font-size:10px;font-weight:700;text-transform:uppercase">Experience</div>
                        <div style="font-weight:700;color:var(--text-primary);font-size:15px">@Model.ExperienceYears Yrs</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card: Quick Contact -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">📞 Contact Info</h3></div>
            <div class="card-body" style="padding:20px;display:flex;flex-direction:column;gap:12px">
                @if (!string.IsNullOrEmpty(Model.Phone))
                {
                    <div style="display:flex;align-items:center;gap:10px;font-size:13px">
                        <div style="width:30px;height:30px;border-radius:6px;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center"><i class="bi bi-telephone"></i></div>
                        <div>
                            <div style="color:var(--text-muted);font-size:10px;font-weight:600">PHONE</div>
                            <a href="tel:@Model.Phone" style="font-weight:600;color:var(--text-primary)">@Model.Phone</a>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <div style="display:flex;align-items:center;gap:10px;font-size:13px">
                        <div style="width:30px;height:30px;border-radius:6px;background:rgba(59,130,246,0.08);color:var(--info);display:flex;align-items:center;justify-content:center"><i class="bi bi-envelope"></i></div>
                        <div>
                            <div style="color:var(--text-muted);font-size:10px;font-weight:600">EMAIL</div>
                            <a href="mailto:@Model.Email" style="font-weight:600;color:var(--text-primary)">@Model.Email</a>
                        </div>
                    </div>
                }
                @if (string.IsNullOrEmpty(Model.Phone) && string.IsNullOrEmpty(Model.Email))
                {
                    <div style="color:var(--text-muted);font-style:italic;text-align:center;font-size:13px;padding:10px 0">No contact info available</div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column: Details, Attendance, and Milk Log -->
    <div style="display:flex;flex-direction:column;gap:20px">
        <!-- Card: Profile Overview -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">📝 Profile Overview</h3></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:16px">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                    <div>
                        <div style="color:var(--text-muted);font-size:11px;font-weight:700;text-transform:uppercase">Assigned Farm</div>
                        <div style="font-weight:600;margin-top:2px">
                            @if (Model.Farm != null && Model.FarmId.HasValue)
                            {
                                <a href="/Farm/Details/@Model.FarmId.Value" style="color:var(--primary);font-weight:600"><i class="bi bi-building"></i> @Model.Farm.Name</a>
                            }
                            else
                            {
                                <span style="color:var(--text-muted)">Unassigned</span>
                            }
                        </div>
                    </div>
                    <div>
                        <div style="color:var(--text-muted);font-size:11px;font-weight:700;text-transform:uppercase">Hire Date</div>
                        <div style="font-weight:600;margin-top:2px;color:var(--text-primary)"><i class="bi bi-calendar-event"></i> @Model.HiredAt.ToString("MMMM dd, yyyy")</div>
                    </div>
                </div>

                <div>
                    <div style="color:var(--text-muted);font-size:11px;font-weight:700;text-transform:uppercase;margin-bottom:6px">Skills & Competencies</div>
                    @if (!string.IsNullOrEmpty(Model.Skills))
                    {
                        <div style="display:flex;flex-wrap:wrap;gap:8px">
                            @foreach (var s in Model.Skills.Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="badge" style="background:var(--primary-light);color:var(--primary-dark);font-weight:600;border:1px solid rgba(34,197,94,0.15)">@s.Trim()</span>
                            }
                        </div>
                    }
                    else
                      {
                          <span style="color:var(--text-muted);font-style:italic;font-size:13px">No skills registered.</span>
                      }
                  </div>

                  @if (!string.IsNullOrEmpty(Model.Notes))
                  {
                      <div>
                          <div style="color:var(--text-muted);font-size:11px;font-weight:700;text-transform:uppercase;margin-bottom:6px">Notes / Comments</div>
                          <div style="padding:14px;background:#f8fafc;border-left:4px solid var(--primary);border-radius:0 var(--radius-sm) var(--radius-sm) 0;font-size:13.5px;color:var(--text-secondary);line-height:1.5">
                              @Model.Notes
                          </div>
                      </div>
                  }
              </div>
          </div>

          <!-- Card: Salary History -->
          <div class="card">
              <div class="card-header">
                  <h3 class="card-title">💳 Salary History</h3>
              </div>
              <div class="table-wrapper">
                  @if (!salaryHistory.Any())
                  {
                      <div class="empty-state" style="padding:32px;text-align:center">
                          <div style="font-size:36px;margin-bottom:8px">💳</div>
                          <p style="color:var(--text-muted);font-size:13.5px">No salary history found for this worker</p>
                      </div>
                  }
                  else
                  {
                      <table class="data-table">
                          <thead>
                              <tr><th>Month</th><th>Base Salary</th><th>Bonus</th><th>Total</th></tr>
                          </thead>
                          <tbody>
                              @foreach (var s in salaryHistory)
                              {
                                  var monthName = new System.Globalization.DateTimeFormatInfo().GetMonthName(s.Month);
                                  <tr>
                                      <td style="font-weight:600">@monthName @s.Year</td>
                                      <td>@Currency.Format(s.BaseSalary)</td>
                                      <td style="color:var(--success)">+@Currency.Format(s.Bonus)</td>
                                      <td style="font-weight:700;color:var(--primary)">@Currency.Format(s.TotalSalary)</td>
                                  </tr>
                              }
                          </tbody>
                      </table>
                  }
              </div>
          </div>

          <!-- Card: Attendance History -->
          <div class="card">
              <div class="card-header">
                  <h3 class="card-title">📅 Recent Attendance (Last 10 Days)</h3>
              </div>
              <div class="table-wrapper">
                  @if (Model.DailyAttendances == null || !Model.DailyAttendances.Any())
                  {
                      <div class="empty-state" style="padding:40px;text-align:center">
                          <div style="font-size:40px;margin-bottom:8px">📋</div>
                          <p style="color:var(--text-muted);font-size:13.5px">No attendance records found for this worker</p>
                      </div>
                  }
                  else
                  {
                      <table class="data-table">
                          <thead>
                              <tr>
                                  <th>Date</th>
                                  <th>Status</th>
                                  <th>Marked By</th>
                                  <th>Marked At</th>
                              </tr>
                          </thead>
                          <tbody>
                              @foreach (var a in Model.DailyAttendances.OrderByDescending(a => a.Date).Take(10))
                              {
                                  var statusBadgeClass = a.Status switch
                                  {
                                      "Present" => "badge-success",
                                      "Late" => "badge-warning",
                                      "Absent" => "badge-danger",
                                      _ => "badge-gray"
                                  };
                                  <tr>
                                      <td style="font-weight:600">@a.Date.ToString("MMM dd, yyyy")</td>
                                      <td><span class="badge @statusBadgeClass">@a.Status</span></td>
                                      <td>@(a.MarkedByUser?.FullName ?? "System")</td>
                                      <td style="color:var(--text-muted)">@a.MarkedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                                  </tr>
                              }
                          </tbody>
                      </table>
                  }
              </div>
          </div>

          <!-- Card: Milk Production Logs -->
          <div class="card">
              <div class="card-header">
                  <h3 class="card-title">🥛 Milk Production Records</h3>
              </div>
              <div class="table-wrapper">
                  @if (Model.MilkProductions == null || !Model.MilkProductions.Any())
                  {
                      <div class="empty-state" style="padding:40px;text-align:center">
                          <div style="font-size:40px;margin-bottom:8px">🥛</div>
                          <p style="color:var(--text-muted);font-size:13.5px">No milk production logged by this worker</p>
                      </div>
                  }
                  else
                  {
                      <table class="data-table">
                          <thead>
                              <tr>
                                  <th>Date</th>
                                  <th>Cattle Tag / Name</th>
                                  <th>Morning Yield</th>
                                  <th>Evening Yield</th>
                                  <th>Total Yield</th>
                                  <th>Notes</th>
                              </tr>
                          </thead>
                          <tbody>
                              @foreach (var m in Model.MilkProductions.OrderByDescending(m => m.Date).Take(10))
                              {
                                  <tr>
                                      <td style="font-weight:600">@m.Date.ToString("MMM dd, yyyy")</td>
                                      <td>
                                          @if (m.Cattle != null)
                                          {
                                              <a href="/Cattle/Details/@m.CattleId" style="font-weight:600;color:var(--primary)">
                                                  🐄 @m.Cattle.Name <span style="font-size:11px;color:var(--text-muted)">(@m.Cattle.TagId)</span>
                                              </a>
                                          }
                                          else
                                          {
                                              <span style="color:var(--text-muted)">Unknown Cattle</span>
                                          }
                                      </td>
                                      <td>@m.MorningYieldLiters L</td>
                                      <td>@m.EveningYieldLiters L</td>
                                      <td style="font-weight:700;color:var(--primary)">@m.TotalYieldLiters L</td>
                                      <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@m.Notes">@(m.Notes ?? "—")</td>
                                  </tr>
                              }
                          </tbody>
                      </table>
                  }
              </div>
          </div>
      </div>
  </div>
</div>
