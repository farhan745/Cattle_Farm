@model IEnumerable<CattleFarm.Models.Subscription>
@{ ViewData["Title"] = "Subscriptions"; }
<div class="page-header">
    <div><h1 class="page-title">💳 Subscriptions</h1><p class="page-subtitle">@Model.Count() total subscriptions — @Model.Count(s => s.IsActive) active</p></div>
</div>
<div class="card">
    <div class="table-wrapper">
        @if (!Model.Any())
        { <div class="empty-state" style="padding:40px"><div class="empty-icon">💳</div><h3>No subscriptions</h3></div> }
        else
        {
            <table class="data-table">
                <thead><tr><th>User</th><th>Plan</th><th>Start</th><th>End</th><th>Payment</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        var planBadge = s.Plan switch { CattleFarm.Models.SubscriptionPlan.Owner => "badge-warning", CattleFarm.Models.SubscriptionPlan.Member => "badge-primary", _ => "badge-gray" };
                        var isExpiring = s.ExpiryDate < DateTime.Now.AddDays(7) && s.IsActive;
                        <tr>
                            <td>
                                <div style="font-weight:600;font-size:13px">@(s.User?.FullName ?? "—")</div>
                                <div style="font-size:11px;color:var(--text-muted)">@s.User?.Email</div>
                            </td>
                            <td><span class="badge @planBadge">@s.Plan</span></td>
                            <td style="font-size:12px;color:var(--text-muted)">@s.StartDate.ToString("MMM dd, yyyy")</td>
                            <td style="font-size:12px;color:@(s.ExpiryDate < DateTime.Now.AddDays(7) && s.IsActive ? "var(--danger)" : "inherit");font-weight:@(s.ExpiryDate < DateTime.Now.AddDays(7) && s.IsActive ? "700" : "400")">
                                @s.ExpiryDate.ToString("MMM dd, yyyy")
                                @if (s.ExpiryDate < DateTime.Now.AddDays(7) && s.IsActive) { <span class="badge badge-danger" style="font-size:9px">⚠ Soon</span> }
                            </td>
                            <td style="font-weight:700;color:var(--primary)">@Currency.Format(s.PricePaid)</td>
                            <td><span class="badge @(s.IsActive ? "badge-success" : "badge-gray")">@(s.IsActive ? "Active" : "Expired")</span></td>
                            <td>
                                @if (s.IsActive)
                                {
                                    <form method="post" asp-action="RevokeSubscription" asp-controller="Admin" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@s.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Revoke this subscription?')">Revoke</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
