@model IEnumerable<CattleFarm.Models.Notification>
@{ ViewData["Title"] = "Notifications"; }
<div class="page-header">
    <div><h1 class="page-title">🔔 Notifications</h1><p class="page-subtitle">@Model.Count(n => !n.IsRead) unread</p></div>
    <div class="page-actions">
        @if (Model.Any(n => !n.IsRead))
        {
            <form method="post" asp-action="MarkAllRead">@Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline"><i class="bi bi-check2-all"></i> Mark All Read</button>
            </form>
        }
    </div>
</div>
<div class="card">
    @if (!Model.Any())
    { <div class="empty-state" style="padding:60px"><div class="empty-icon">🔔</div><h3>All caught up!</h3></div> }
    @foreach (var n in Model)
    {
        var icon = n.Type switch {
            CattleFarm.Models.NotificationType.HealthAlert => "🚨",
            CattleFarm.Models.NotificationType.Vaccination => "💉",
            CattleFarm.Models.NotificationType.Appointment => "📅",
            CattleFarm.Models.NotificationType.OrderUpdate => "📦",
            CattleFarm.Models.NotificationType.Payment => "💳",
            CattleFarm.Models.NotificationType.Subscription => "⭐",
            _ => "🔔"
        };
        <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;gap:14px;align-items:flex-start;background:@(n.IsRead?"var(--bg-card)":"var(--primary-light)")">
            <div style="font-size:22px;flex-shrink:0">@icon</div>
            <div style="flex:1">
                <div style="font-size:14px;font-weight:@(n.IsRead?"500":"700")">@n.Title</div>
                <div style="font-size:13px;color:var(--text-secondary);margin-top:3px">@n.Message</div>
                <div style="font-size:11px;color:var(--text-muted);margin-top:6px">@n.CreatedAt.ToString("MMM dd, yyyy — HH:mm")</div>
            </div>
            @if (!n.IsRead)
            {
                <form method="post" asp-action="MarkRead">@Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@n.Id" />
                    <button type="submit" class="btn btn-outline btn-sm"><i class="bi bi-check2"></i></button>
                </form>
            }
            else { <span class="badge badge-gray">Read</span> }
        </div>
    }
</div>
