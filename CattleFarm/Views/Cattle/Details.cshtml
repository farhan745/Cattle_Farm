@model CattleFarm.Models.Cattle
@{
    ViewData["Title"] = $"{Model.Name} — Details";
}

<div class="page-header">
    <div>
        <h1 class="page-title">🐄 @Model.Name <small style="font-size:14px;font-weight:500;color:var(--text-muted)">(@Model.TagId)</small></h1>
        <p class="page-subtitle">@Model.Breed • @Model.Farm?.Name</p>
    </div>
    <div class="page-actions">
        <a href="/Cattle" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Back</a>
        @if (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager"))
        {
            <a href="/Cattle/Edit/@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a>
        }
    </div>
</div>

<div style="display:grid;grid-template-columns:320px 1fr;gap:24px;align-items:start">
    <!-- Left: Image + Status -->
    <div style="display:flex;flex-direction:column;gap:16px">
        <div class="card">
            <div style="width:100%;height:260px;overflow:hidden;background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:72px;border-radius:10px 10px 0 0">
                @if (!string.IsNullOrEmpty(Model.ImagePath)) { <img src="@Model.ImagePath" alt="@Model.Name" style="width:100%;height:260px;object-fit:cover" /> }
                else { <span>🐄</span> }
            </div>
            <div class="card-body">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                    @{
                        var hClass = Model.HealthStatus switch { CattleFarm.Models.HealthStatus.Healthy => "badge-success", CattleFarm.Models.HealthStatus.AtRisk => "badge-warning", CattleFarm.Models.HealthStatus.Sick => "badge-danger", _ => "badge-danger" };
                        var sClass = Model.Status == CattleFarm.Models.CattleStatus.Active ? "badge-success" : "badge-gray";
                    }
                    <span class="badge @hClass">@Model.HealthStatus</span>
                    <span class="badge @sClass">@Model.Status</span>
                    @if (Model.IsPremiumListing) { <span class="badge badge-warning">⭐ Premium</span> }
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px">
                    <div><div style="color:var(--text-muted);font-size:11px">AGE</div><div style="font-weight:600">@((DateTime.Now.Year - Model.DateOfBirth.Year)) years</div></div>
                    <div><div style="color:var(--text-muted);font-size:11px">WEIGHT</div><div style="font-weight:600">@Model.Weight kg</div></div>
                    <div><div style="color:var(--text-muted);font-size:11px">GENDER</div><div style="font-weight:600">@Model.Gender</div></div>
                    <div><div style="color:var(--text-muted);font-size:11px">FARM</div><div style="font-weight:600">@Model.Farm?.Name</div></div>
                </div>
                @if (Model.IsListedForSale)
                {
                    <div style="margin-top:12px;padding:10px;background:var(--primary-light);border-radius:6px;text-align:center">
                        <div style="font-size:11px;color:var(--text-muted)">SALE PRICE</div>
                        <div style="font-size:20px;font-weight:800;color:var(--primary)">@Currency.Format(Model.SalePrice)</div>
                        <a href="/Cattle/BuyCattle/@Model.Id" class="btn btn-primary w-100" style="margin-top:8px">💰 Buy Now</a>
                    </div>
                }
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">Quick Actions</h3></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px">
                <a href="/Health/Create?cattleId=@Model.Id" class="btn btn-outline"><i class="bi bi-clipboard2-pulse"></i> Add Health Record</a>
                <a href="/Health/AddVaccination?cattleId=@Model.Id" class="btn btn-outline"><i class="bi bi-shield-plus"></i> Log Vaccination</a>
                <a href="/Appointment/Create?cattleId=@Model.Id" class="btn btn-outline"><i class="bi bi-calendar-plus"></i> Book Appointment</a>
                <a href="/MilkProduction/Create?farmId=@Model.FarmId" class="btn btn-outline"><i class="bi bi-droplet"></i> Log Milk</a>
            </div>
        </div>
    </div>

    <!-- Right: Details Tabs -->
    <div style="display:flex;flex-direction:column;gap:20px">
        <!-- Health Records -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">🏥 Recent Health Records</h3>
                <a href="/Health?cattleId=@Model.Id" class="btn btn-ghost btn-sm">View all</a>
            </div>
            <div class="table-wrapper">
                @if (!Model.HealthRecords.Any())
                { <div class="empty-state" style="padding:30px"><div class="empty-icon">📋</div><p>No health records yet</p></div> }
                else
                {
                    <table class="data-table">
                        <thead><tr><th>Date</th><th>Status</th><th>Risk</th><th>Temp</th><th>Notes</th></tr></thead>
                        <tbody>
                            @foreach (var h in Model.HealthRecords.Take(5))
                            {
                                <tr>
                                    <td>@h.RecordDate.ToString("MMM dd, yyyy")</td>
                                    <td><span class="badge @(h.HealthStatus == CattleFarm.Models.HealthStatus.Healthy ? "badge-success" : "badge-danger")">@h.HealthStatus</span></td>
                                    <td><span class="badge @(h.RiskLevel == CattleFarm.Models.RiskLevel.Low ? "badge-success" : h.RiskLevel == CattleFarm.Models.RiskLevel.Medium ? "badge-warning" : "badge-danger")">@h.RiskLevel</span></td>
                                    <td>@(h.Temperature.HasValue ? $"{h.Temperature}°C" : "—")</td>
                                    <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@(h.Notes ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- Vaccinations -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">💉 Vaccination History</h3>
                <a href="/Health/Vaccinations?cattleId=@Model.Id" class="btn btn-ghost btn-sm">View all</a>
            </div>
            <div class="table-wrapper">
                @if (!Model.Vaccinations.Any())
                { <div class="empty-state" style="padding:30px"><div class="empty-icon">💉</div><p>No vaccinations recorded</p></div> }
                else
                {
                    <table class="data-table">
                        <thead><tr><th>Vaccine</th><th>Date</th><th>Next Due</th><th>Dose</th></tr></thead>
                        <tbody>
                            @foreach (var v in Model.Vaccinations.Take(5))
                            {
                                var isOverdue = v.NextDueDate.HasValue && v.NextDueDate < DateTime.Now;
                                <tr>
                                    <td style="font-weight:500">@v.VaccineName</td>
                                    <td>@v.VaccinationDate.ToString("MMM dd, yyyy")</td>
                                    <td style="color:@(isOverdue ? "var(--danger)" : "inherit")">
                                        @(v.NextDueDate?.ToString("MMM dd, yyyy") ?? "—")
                                        @if (isOverdue) { <span class="badge badge-danger" style="margin-left:4px">Overdue</span> }
                                    </td>
                                    <td>Dose @v.DoseNumber</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- Milk Production Chart -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">🥛 Milk Production (Last 30 days)</h3>
            </div>
            <div class="card-body">
                <div class="chart-container" style="height:200px">
                    <canvas id="milkChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const milkDates = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MilkProductions.Select(m => m.Date.ToString("MMM dd")).ToList()));
const milkYields = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MilkProductions.Select(m => m.MorningYieldLiters + m.EveningYieldLiters).ToList()));
new Chart(document.getElementById('milkChart'), {
    type: 'line',
    data: { labels: milkDates, datasets: [{ label: 'Total Yield (L)', data: milkYields, borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,.1)', tension: .4, fill: true, pointRadius: 3 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true }, x: { grid: { display: false } } } }
});
</script>
}
