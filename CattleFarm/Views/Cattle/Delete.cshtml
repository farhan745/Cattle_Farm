@model CattleFarm.Models.Cattle
@{
    ViewData["Title"] = $"Delete — {Model?.Name}";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3" id="deleteBackBtn">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <h2 class="mb-0 text-danger"><i class="bi bi-trash3 me-2"></i>Delete Cattle</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white py-3">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Confirm Deletion</h5>
            </div>
            <div class="card-body p-4">

                <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                    <div>
                        You are about to permanently delete <strong>@Model?.Name</strong>.
                        This action <strong>cannot be undone</strong>.
                    </div>
                </div>

                <dl class="row mb-4">
                    <dt class="col-sm-4 text-muted">Cattle Name</dt>
                    <dd class="col-sm-8 fw-semibold">@Model?.Name</dd>

                    <dt class="col-sm-4 text-muted">Breed</dt>
                    <dd class="col-sm-8">@Model?.Breed</dd>

                    <dt class="col-sm-4 text-muted">Date of Birth</dt>
                    <dd class="col-sm-8">@Model?.DateOfBirth.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-4 text-muted">Weight</dt>
                    <dd class="col-sm-8">@Model?.Weight.ToString("F1") kg</dd>
                </dl>

                <form asp-action="Delete" method="post" id="deleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4" id="deleteConfirmBtn">
                            <i class="bi bi-trash3"></i> Yes, Delete
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary" id="deleteCancelBtn">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
