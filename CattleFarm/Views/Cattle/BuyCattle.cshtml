@model CattleFarm.Models.Cattle
@{
    ViewData["Title"] = $"Buy {Model.Name}";
}

<div class="page-header">
    <div>
        <h1 class="page-title">💰 Purchase Cattle</h1>
        <p class="page-subtitle">Complete your purchase request for <strong>@Model.Name</strong></p>
    </div>
    <div class="page-actions">
        <a href="/Cattle/Details/@Model.Id" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Back to Details</a>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 360px;gap:24px;align-items:start">

    <!-- Purchase Form -->
    <div class="card animate-in">
        <div class="card-header">
            <h3 class="card-title">📋 Purchase Request</h3>
        </div>
        <div class="card-body">
            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle-fill" style="font-size:18px;flex-shrink:0"></i>
                <div>After submitting, the farm owner will contact you to arrange payment and pickup. Submitting this request will mark the cattle as <strong>Sold</strong>.</div>
            </div>

            <form method="post" asp-action="BuyCattle" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label" for="deliveryAddress">
                        <i class="bi bi-geo-alt"></i> Delivery / Contact Address <span style="color:var(--danger)">*</span>
                    </label>
                    <textarea id="deliveryAddress" name="deliveryAddress" class="form-control" rows="3"
                              placeholder="Enter your address or area for cattle pickup / delivery..." required></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label" for="notes">
                        <i class="bi bi-chat-text"></i> Additional Notes (optional)
                    </label>
                    <textarea id="notes" name="notes" class="form-control" rows="2"
                              placeholder="Any special requests, preferred contact time, etc."></textarea>
                </div>

                <div class="form-group" style="margin-bottom:20px">
                    <label class="form-label"><i class="bi bi-credit-card"></i> Payment Method <span style="color:var(--danger)">*</span></label>
                    <div style="display:flex;flex-direction:column;gap:12px;margin-top:8px">
                        <label style="display:flex;align-items:center;gap:12px;padding:12px;border:1px solid var(--border);border-radius:8px;cursor:pointer">
                            <input type="radio" name="paymentMethod" value="@CattleFarm.Models.PaymentMethod.Cash" checked style="accent-color:var(--primary);width:18px;height:18px" />
                            <div>
                                <div style="font-weight:600">💵 Cash / Direct Contact</div>
                                <div style="font-size:12px;color:var(--text-muted)">Arrange payment and pickup directly with the seller</div>
                            </div>
                        </label>
                        
                        <label style="display:flex;align-items:center;gap:12px;padding:12px;border:1px solid var(--border);border-radius:8px;cursor:pointer">
                            <input type="radio" name="paymentMethod" value="@CattleFarm.Models.PaymentMethod.Bkash" style="accent-color:var(--primary);width:18px;height:18px" />
                            <div>
                                <div style="font-weight:600">📱 Online Payment</div>
                                <div style="font-size:12px;color:var(--text-muted)">Pay securely via SSLCommerz (bKash, Nagad, Cards)</div>
                            </div>
                        </label>
                    </div>
                </div>

                <div style="display:flex;gap:12px;margin-top:8px">
                    <button type="submit" class="btn btn-primary btn-lg" style="flex:1">
                        <i class="bi bi-bag-check-fill"></i> Proceed to Purchase
                    </button>
                    <a href="/Cattle/Details/@Model.Id" class="btn btn-outline btn-lg">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Cattle Summary Card -->
    <div class="card animate-in">
        <div class="card-header">
            <h3 class="card-title">🐄 Cattle Details</h3>
        </div>
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" alt="@Model.Name"
                 style="width:100%;height:200px;object-fit:cover" />
        }
        else
        {
            <div style="width:100%;height:160px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-size:64px">🐄</div>
        }
        <div class="card-body">
            @{
                var rows = new (string Label, string Value)[]
                {
                    ("🏷️ Name",     Model.Name),
                    ("🔖 Tag",      Model.TagId),
                    ("🐄 Breed",    Model.Breed),
                    ("⚖️ Weight",   $"{Model.Weight} kg"),
                    ("🚻 Gender",   Model.Gender.ToString()),
                    ("🏡 Farm",     Model.Farm?.Name ?? "—"),
                    ("📍 Location", Model.Farm?.Location ?? "—"),
                };
            }
            @foreach (var (label, value) in rows)
            {
                <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px">
                    <span style="color:var(--text-muted)">@label</span>
                    <span style="font-weight:600">@value</span>
                </div>
            }
            @if (Model.IsPremiumListing)
            {
                <div style="padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;display:flex;justify-content:space-between">
                    <span style="color:var(--text-muted)">⭐ Listing</span>
                    <span class="badge badge-warning">Premium</span>
                </div>
            }
            <div style="margin-top:16px;padding:16px;background:var(--primary-light);border-radius:var(--radius-md);text-align:center">
                <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px">SALE PRICE</div>
                <div style="font-size:28px;font-weight:800;color:var(--primary)">৳@Model.SalePrice?.ToString("N0")</div>
            </div>
        </div>
    </div>

</div>
