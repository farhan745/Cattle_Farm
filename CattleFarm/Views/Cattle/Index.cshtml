@model IEnumerable<CattleFarm.Models.Cattle>
@{
    ViewData["Title"] = "Cattle Records";
    int currentPage = (int)ViewData["CurrentPage"]!;
    int totalPages  = (int)ViewData["TotalPages"]!;
    int totalCount  = (int)ViewData["TotalCount"]!;
    var likeCounts = ViewBag.LikeCounts as Dictionary<int, int> ?? new();
    var commentCounts = ViewBag.CommentCounts as Dictionary<int, int> ?? new();
    var shareCounts = ViewBag.ShareCounts as Dictionary<int, int> ?? new();
}

<div class="page-header">
    <div>
        <h1 class="page-title">🐄 Cattle Records</h1>
        <p class="page-subtitle">@totalCount total cattle across all farms</p>
    </div>
    <div class="page-actions">
        @if (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager"))
        {
            <a href="/Cattle/Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add Cattle</a>
        }
        <a href="/Cattle/Marketplace" class="btn btn-outline"><i class="bi bi-shop"></i> Marketplace</a>
    </div>
</div>

<!-- Filters -->
<div class="card animate-in" style="margin-bottom:24px">
    <div class="card-body" style="padding:20px">
        <form method="get" style="display:flex;gap:16px;align-items:flex-end;flex-wrap:wrap">
            <div class="form-group" style="margin:0;flex:1;min-width:240px">
                <label class="form-label" style="margin-bottom:6px;font-family:var(--font-heading);font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:0.5px"><i class="bi bi-search" style="color:var(--primary)"></i> Search Cattle</label>
                <div style="position:relative">
                    <input type="text" name="search" value="@ViewData["Search"]" placeholder="Enter name, breed, tag ID..." class="form-control" style="padding-left:38px" />
                    <i class="bi bi-search" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--text-muted)"></i>
                </div>
            </div>
            <div class="form-group" style="margin:0;min-width:180px">
                <label class="form-label" style="margin-bottom:6px;font-family:var(--font-heading);font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:0.5px"><i class="bi bi-heart-pulse" style="color:var(--primary)"></i> Status</label>
                <select name="status" class="form-select" style="width:100%">
                    <option value="">All Herd Status</option>
                    <option value="0" selected="@(ViewData["Status"]?.ToString() == "0")">Active</option>
                    <option value="1" selected="@(ViewData["Status"]?.ToString() == "1")">Sold</option>
                    <option value="2" selected="@(ViewData["Status"]?.ToString() == "2")">Deceased</option>
                </select>
            </div>
            <div class="form-group" style="margin:0">
                <button type="submit" class="btn btn-primary"><i class="bi bi-funnel"></i> Filter</button>
            </div>
            <div class="form-group" style="margin:0">
                <a href="/Cattle" class="btn btn-outline"><i class="bi bi-arrow-counterclockwise"></i> Reset</a>
            </div>
        </form>
    </div>
</div>

<!-- Cattle Grid -->
@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon">🐄</div>
        <h3>No cattle found</h3>
        <p style="margin-top:8px">Try adjusting your filters or <a href="/Cattle/Create">add your first cattle</a>.</p>
    </div>
}
else
{
    <div class="cattle-grid animate-in">
        @foreach (var c in Model)
        {
            <div class="cattle-card">
                <div class="cattle-card-img">
                    @if (!string.IsNullOrEmpty(c.ImagePath))
                    { <img src="@c.ImagePath" alt="@c.Name" loading="lazy" /> }
                    else { <span>🐄</span> }
                </div>
                <div class="cattle-card-body">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start">
                        <div>
                            <div class="cattle-card-title">@c.Name</div>
                            <div class="cattle-card-meta">@c.Breed • @c.TagId</div>
                        </div>
                        @{
                            var hBadge = c.HealthStatus switch { CattleFarm.Models.HealthStatus.Healthy => "badge-success", CattleFarm.Models.HealthStatus.AtRisk => "badge-warning", CattleFarm.Models.HealthStatus.Sick => "badge-danger", _ => "badge-danger" };
                        }
                        <span class="badge @hBadge">@c.HealthStatus</span>
                    </div>
                    <div style="display:flex;gap:16px;margin-top:12px;font-size:12px;color:var(--text-secondary)">
                        <span>⚖️ @c.Weight kg</span>
                        <span>@(c.Gender == CattleFarm.Models.Gender.Female ? "♀ Female" : "♂ Male")</span>
                        <span>🎂 @((DateTime.Now.Year - c.DateOfBirth.Year))y</span>
                    </div>
                    @if (c.IsListedForSale)
                    {
                        <div style="margin-top:10px;padding:8px;background:var(--primary-light);border-radius:6px;font-size:12px;color:var(--primary-dark);font-weight:600">
                            💰 For Sale — @Currency.Format(c.SalePrice)
                            @if (c.IsPremiumListing) { <span class="badge badge-warning" style="margin-left:4px">⭐ Premium</span> }
                        </div>
                    }
                    <div style="display:flex;gap:8px;align-items:center;margin-top:12px;flex-wrap:wrap">
                        <form asp-action="ToggleLike" asp-route-id="@c.Id" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-ghost btn-sm" title="Like">
                                <i class="bi bi-heart"></i> @(likeCounts.TryGetValue(c.Id, out var likes) ? likes : 0)
                            </button>
                        </form>
                        <a href="/Cattle/Details/@c.Id#comments" class="btn btn-ghost btn-sm" title="Comments">
                            <i class="bi bi-chat-dots"></i> @(commentCounts.TryGetValue(c.Id, out var comments) ? comments : 0)
                        </a>
                        <form asp-action="Share" asp-route-id="@c.Id" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-ghost btn-sm" title="Share">
                                <i class="bi bi-share"></i> @(shareCounts.TryGetValue(c.Id, out var shares) ? shares : 0)
                            </button>
                        </form>
                    </div>
                </div>
                <div class="cattle-card-footer">
                    <span style="font-size:12px;color:var(--text-muted)">@c.Farm?.Name</span>
                    <div style="display:flex;gap:6px">
                        <a href="/Cattle/Details/@c.Id" class="btn btn-outline btn-sm">View</a>
                        @if (c.IsListedForSale)
                        {
                            <a href="/Cattle/BuyCattle/@c.Id" class="btn btn-primary btn-sm">💰 Buy Now</a>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager"))
                        {
                            <a href="/Cattle/Edit/@c.Id" class="btn btn-ghost btn-sm"><i class="bi bi-pencil"></i></a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="pagination">
            @if (currentPage > 1)
            { <a href="?page=@(currentPage-1)&search=@ViewData["Search"]&status=@ViewData["Status"]" class="page-link"><i class="bi bi-chevron-left"></i></a> }
            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
            { <a href="?page=@i&search=@ViewData["Search"]&status=@ViewData["Status"]" class="page-link @(i == currentPage ? "active" : "")">@i</a> }
            @if (currentPage < totalPages)
            { <a href="?page=@(currentPage+1)&search=@ViewData["Search"]&status=@ViewData["Status"]" class="page-link"><i class="bi bi-chevron-right"></i></a> }
        </div>
    }
}
