@model CattleFarm.ViewModels.WorkerDashboardViewModel
@{ ViewData["Title"] = "Worker Dashboard"; }
<div class="page-header">
    <div><h1 class="page-title">👷 Worker Dashboard</h1><p class="page-subtitle">Welcome, @(Model.WorkerProfile?.FullName ?? User.Identity?.Name)</p></div>
</div>
<div class="stat-grid">
    <div class="stat-card green"><div class="stat-icon green">📅</div><div><div class="stat-value">@Model.PresentThisMonth</div><div class="stat-label">Days Present (Month)</div></div></div>
    <div class="stat-card blue"><div class="stat-icon blue">🥛</div><div><div class="stat-value">@Model.RecentMilkLogs.Count</div><div class="stat-label">Milk Logs Recorded</div></div></div>
</div>
<div class="card">
    <div class="card-header"><h3 class="card-title">🥛 Recent Milk Production Logs</h3></div>
    <div class="table-wrapper">
        @if (!Model.RecentMilkLogs.Any()) { <div class="empty-state" style="padding:30px"><div class="empty-icon">🥛</div><p>No logs recorded yet</p></div> }
        else {
            <table class="data-table"><thead><tr><th>Date</th><th>Cattle</th><th>Morning (L)</th><th>Evening (L)</th><th>Total</th></tr></thead><tbody>
            @foreach (var m in Model.RecentMilkLogs)
            { <tr><td>@m.Date.ToString("MMM dd")</td><td>@m.Cattle?.Name</td><td>@m.MorningYieldLiters</td><td>@m.EveningYieldLiters</td><td style="font-weight:700">@((m.MorningYieldLiters + m.EveningYieldLiters).ToString("F1"))L</td></tr> }
            </tbody></table>
        }
    </div>
</div>
