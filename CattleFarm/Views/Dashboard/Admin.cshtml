@model CattleFarm.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header animate-in">
    <div>
        <h1 class="page-title">System Administration</h1>
        <p class="page-subtitle">@DateTime.Now.ToString("dddd, MMMM dd, yyyy") &mdash; Platform-wide operational overview</p>
    </div>
    <div class="page-actions">
        <a href="/Admin/Users" class="btn btn-primary"><i class="bi bi-people-fill"></i> Manage Users</a>
        <a href="/Admin/Farms" class="btn btn-outline"><i class="bi bi-check2-circle"></i> Pending Approvals</a>
    </div>
</div>

<!-- KPI Row -->
<div class="stat-grid animate-in">
    <div class="stat-card blue">
        <div class="stat-icon blue"><i class="bi bi-people"></i></div>
        <div>
            <div class="stat-value">@Model.TotalUsers</div>
            <div class="stat-label">Total Users</div>
        </div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon green"><i class="bi bi-house-door"></i></div>
        <div>
            <div class="stat-value">@Model.TotalFarms</div>
            <div class="stat-label">Registered Farms</div>
            @if (Model.PendingFarms > 0)
            {
                <div class="stat-change down"><i class="bi bi-clock"></i> @Model.PendingFarms pending approval</div>
            }
        </div>
    </div>
    <div class="stat-card teal">
        <div class="stat-icon teal"><i class="bi bi-collection"></i></div>
        <div>
            <div class="stat-value">@Model.TotalCattle</div>
            <div class="stat-label">Total Cattle</div>
        </div>
    </div>
    <div class="stat-card purple">
        <div class="stat-icon purple"><i class="bi bi-people-fill"></i></div>
        <div>
            <div class="stat-value">@Model.TotalWorkers</div>
            <div class="stat-label">Workers</div>
        </div>
    </div>
    <div class="stat-card amber">
        <div class="stat-icon amber"><i class="bi bi-person-badge"></i></div>
        <div>
            <div class="stat-value">@Model.TotalDoctors</div>
            <div class="stat-label">Veterinarians</div>
        </div>
    </div>
    <div class="stat-card red">
        <div class="stat-icon red"><i class="bi bi-hourglass-split"></i></div>
        <div>
            <div class="stat-value">@Model.PendingFarms</div>
            <div class="stat-label">Pending Approvals</div>
            <div class="stat-change @(Model.PendingFarms > 0 ? "down" : "up")">
                @(Model.PendingFarms > 0 ? "Action required" : "All cleared")
            </div>
        </div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:18px" class="animate-in">
    <!-- Recent Activity -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title"><i class="bi bi-activity" style="color:var(--primary)"></i> Recent Activity</h3>
            <a href="/Admin/AuditLogs" class="btn btn-ghost btn-sm">View all</a>
        </div>
        @if (Model.RecentActivity.Any())
        {
            <div style="padding:0">
                @foreach (var log in Model.RecentActivity.Take(8))
                {
                    <div style="padding:11px 18px;border-bottom:1px solid var(--border);display:flex;gap:12px;align-items:flex-start">
                        <div style="width:6px;height:6px;border-radius:50%;background:var(--primary);margin-top:6px;flex-shrink:0"></div>
                        <div style="flex:1">
                            <div style="font-size:13px;color:var(--text-primary)">@log.Description</div>
                            <div style="font-size:11px;color:var(--text-muted);margin-top:2px">@log.Timestamp.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card-body empty-state"><i class="bi bi-inbox" style="font-size:32px;opacity:.3"></i><h3 style="margin-top:8px">No recent activity</h3></div>
        }
    </div>

    <!-- Audit Logs -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title"><i class="bi bi-journal-text" style="color:var(--accent)"></i> Audit Log</h3>
            <a href="/Admin/AuditLogs" class="btn btn-ghost btn-sm">View all</a>
        </div>
        @if (Model.RecentAuditLogs.Any())
        {
            <div class="table-wrapper">
                <table class="data-table">
                    <thead><tr><th>Action</th><th>Entity</th><th>Time</th></tr></thead>
                    <tbody>
                        @foreach (var log in Model.RecentAuditLogs.Take(8))
                        {
                            <tr>
                                <td><span style="font-weight:600;font-size:12px">@log.Action</span></td>
                                <td><span class="badge badge-gray">@log.EntityName</span></td>
                                <td style="color:var(--text-muted);font-size:12px">@log.Timestamp.ToString("MMM dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-body empty-state"><i class="bi bi-shield-check" style="font-size:32px;opacity:.3"></i><h3 style="margin-top:8px">No audit records</h3></div>
        }
    </div>
</div>
