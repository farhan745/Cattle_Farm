@model IEnumerable<CattleFarm.Models.Vaccination>
@{
    ViewData["Title"] = "Vaccination Schedules";
    var cattleId = ViewData["CattleId"] as int?;
}

<div class="page-header">
    <div>
        <h1 class="page-title"> Vaccination Schedules</h1>
        <p class="page-subtitle">Manage herd immunization cycles, vaccine batches, and booster dates</p>
    </div>
    <div class="page-actions">
        <a href="/Health" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Health Records</a>
        <a href="/Health/AddVaccination@(cattleId.HasValue ? $"?cattleId={cattleId.Value}" : "")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Vaccination
        </a>
    </div>
</div>

<!-- Quick Statistics Strip -->
<div class="stat-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:20px">
    <div class="stat-card blue">
        <div class="stat-icon blue">🛡️</div>
        <div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label">Total Vaccinations</div>
        </div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon green">📅</div>
        <div>
            <div class="stat-value">@Model.Count(v => v.NextDueDate.HasValue && v.NextDueDate.Value > DateTime.UtcNow)</div>
            <div class="stat-label">Active Booster Cycles</div>
        </div>
    </div>
    <div class="stat-card amber">
        <div class="stat-icon amber">🔔</div>
        <div>
            <div class="stat-value">@Model.Count(v => v.NextDueDate.HasValue && v.NextDueDate.Value <= DateTime.UtcNow.AddDays(7) && v.NextDueDate.Value >= DateTime.UtcNow)</div>
            <div class="stat-label">Due Next 7 Days</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header"><h3 class="card-title">📋 Immunization Trail</h3></div>
    <div class="table-wrapper">
        @if (!Model.Any())
        {
            <div class="empty-state" style="padding:40px">
                <div class="empty-icon" style="font-size:48px;margin-bottom:12px">🛡️</div>
                <h3>No vaccination records</h3>
                <p style="color:var(--text-muted);font-size:13px;margin-top:6px">No immunization records have been logged for the selected filter.</p>
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Cattle</th>
                        <th>Vaccine Name</th>
                        <th>Dose #</th>
                        <th>Batch / Serial</th>
                        <th>Administered By</th>
                        <th>Next Due (Booster)</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model)
                    {
                        var isOverdue = v.NextDueDate.HasValue && v.NextDueDate.Value <= DateTime.UtcNow;
                        var dueText = v.NextDueDate.HasValue ? v.NextDueDate.Value.ToString("MMM dd, yyyy") : "None";
                        <tr>
                            <td style="font-size:12px;white-space:nowrap;font-weight:600">@v.VaccinationDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a href="/Cattle/Details/@v.CattleId" style="font-weight:600">
                                    @(v.Cattle?.Name ?? $"#{v.CattleId}")
                                </a>
                                <span style="font-size:11px;color:var(--text-muted);display:block">@(v.Cattle?.TagId ?? "")</span>
                            </td>
                            <td>
                                <span style="font-weight:700;color:var(--primary)">@v.VaccineName</span>
                            </td>
                            <td>
                                <span class="badge badge-gray" style="font-weight:700;padding:2px 8px">Dose @v.DoseNumber</span>
                            </td>
                            <td style="font-family:monospace;font-size:11px;color:var(--text-secondary)">
                                @(string.IsNullOrEmpty(v.BatchNumber) ? "—" : v.BatchNumber)
                            </td>
                            <td>
                                <span style="font-size:12px">@(v.Doctor?.FullName ?? v.AdministeredBy ?? "—")</span>
                            </td>
                            <td>
                                @if (v.NextDueDate.HasValue)
                                {
                                    @if (isOverdue)
                                    {
                                        <span class="badge badge-danger" style="display:inline-flex;align-items:center;gap:4px">
                                            <i class="bi bi-exclamation-triangle-fill"></i> Overdue (@dueText)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-success">
                                            @dueText
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);font-size:12px">Single Dose</span>
                                }
                            </td>
                            <td style="font-size:11px;color:var(--text-muted);max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@v.Notes">
                                @(string.IsNullOrEmpty(v.Notes) ? "—" : v.Notes)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
