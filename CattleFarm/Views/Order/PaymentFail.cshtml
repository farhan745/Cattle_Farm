@{
    ViewData["Title"] = "Payment Failed";
    Layout = "_Layout";
}

<div style="max-width: 600px; margin: 40px auto; text-align: center;">
    <div class="card" style="padding: 40px;">
        <div style="font-size: 64px; color: var(--danger); margin-bottom: 20px;">
            <i class="bi bi-x-circle-fill"></i>
        </div>
        <h2 style="font-weight: 800; margin-bottom: 8px;">Payment Failed</h2>
        <p style="color: var(--text-secondary); margin-bottom: 24px;">Something went wrong while processing your payment transaction.</p>

        <div style="background: var(--bg); border-radius: 12px; padding: 20px; text-align: left; margin-bottom: 30px; border: 1px solid var(--border)">
            @if (ViewBag.TransactionId != null)
            {
                <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                    <span style="color: var(--text-muted); font-size: 13px;">Transaction ID:</span>
                    <span style="font-weight: 600; font-family: monospace;">@ViewBag.TransactionId</span>
                </div>
            }
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <span style="color: var(--text-muted); font-size: 13px; flex-shrink: 0; margin-right: 16px;">Reason:</span>
                <span style="font-weight: 600; color: var(--danger); text-align: right;">@ViewBag.Error</span>
            </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 10px;">
            <a href="/Product" class="btn btn-primary btn-lg w-100">
                <i class="bi bi-arrow-clockwise"></i> Try Purchasing Again
            </a>
            <a href="/Order" class="btn btn-outline w-100">
                <i class="bi bi-list-task"></i> View My Orders
            </a>
        </div>
    </div>
</div>
