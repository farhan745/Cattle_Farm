@model CattleFarm.ViewModels.OrderViewModel
@{
    ViewData["Title"] = "Place Order";
    var products = (IEnumerable<CattleFarm.Models.Product>)ViewBag.Products;
    var initialItem = Model.Items.FirstOrDefault();
    var selectedProduct = products?.FirstOrDefault(p => p.Id == initialItem?.ProductId);
}

<div class="page-header">
    <div>
        <h1 class="page-title"> Complete Your Order</h1>
        <p class="page-subtitle">Configure quantity, delivery address, and payment method</p>
    </div>
    <a href="/Product" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Back to Products</a>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="FarmId" />
    
    <div style="display:grid;grid-template-columns:1fr 360px;gap:24px;align-items:start">
        <div style="display:flex;flex-direction:column;gap:20px">
            
            <!-- Product Section -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">📦 Selected Product</h3>
                </div>
                <div class="card-body">
                    @if (selectedProduct != null)
                    {
                        <div style="display:flex;gap:16px;align-items:center">
                            <div style="background:var(--bg);border-radius:12px;width:80px;height:80px;display:flex;align-items:center;justify-content:center;overflow:hidden">
                                @if (!string.IsNullOrEmpty(selectedProduct.ImagePath))
                                {
                                    <img src="@selectedProduct.ImagePath" alt="@selectedProduct.Name" style="width:100%;height:100%;object-fit:cover" />
                                }
                                else
                                {
                                    <span style="font-size:48px">
                                        @(selectedProduct.Category switch { 
                                            CattleFarm.Models.ProductCategory.Milk => "🥛", 
                                            CattleFarm.Models.ProductCategory.Beef => "🥩", 
                                            CattleFarm.Models.ProductCategory.Manure => "♻️", 
                                            CattleFarm.Models.ProductCategory.BreedingService => "🐄", 
                                            _ => "📦" 
                                        })
                                    </span>
                                }
                            </div>
                            <div>
                                <div style="font-size:18px;font-weight:700">@selectedProduct.Name</div>
                                <div style="font-size:13px;color:var(--text-muted)">Farm: @(selectedProduct.Farm?.Name ?? "Smart Cattle Farm")</div>
                                <div style="font-size:14px;color:var(--primary);font-weight:600;margin-top:4px">
                                    Price: @Currency.GetSettings().Symbol <span id="unitPrice">@selectedProduct.Price</span> per @selectedProduct.Unit
                                </div>
                            </div>
                        </div>
                        <input type="hidden" name="Items[0].ProductId" value="@selectedProduct.Id" />
                    }
                    else
                    {
                        <div class="form-group">
                            <label class="form-label">Select Product</label>
                            <select id="productSelector" name="Items[0].ProductId" class="form-control">
                                @if (products != null)
                                {
                                    foreach (var p in products)
                                    {
                                        <option value="@p.Id" data-price="@p.Price" data-unit="@p.Unit">@p.Name (@Currency.GetSettings().Symbol @p.Price/@p.Unit)</option>
                                    }
                                }
                            </select>
                        </div>
                    }

                    <div class="form-group" style="margin-top:20px">
                        <label class="form-label">Quantity</label>
                        <input type="number" name="Items[0].Quantity" id="quantityInput" class="form-control" value="1" min="1" step="any" required />
                        @if (selectedProduct != null)
                        {
                            <span style="font-size:12px;color:var(--text-muted);display:block;margin-top:4px">
                                Available Stock: @selectedProduct.StockQuantity @selectedProduct.Unit
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- Delivery Section -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">📍 Delivery Details</h3>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label class="form-label">Delivery Address *</label>
                        <textarea asp-for="DeliveryAddress" class="form-control" rows="3" placeholder="Full address for order delivery..." required></textarea>
                        <span asp-validation-for="DeliveryAddress" class="form-error"></span>
                    </div>
                    <div class="form-group" style="margin-top:16px">
                        <label class="form-label">Order Notes (Optional)</label>
                        <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Instructions for delivery driver, timing, etc..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Checkout Summary -->
        <div style="display:flex;flex-direction:column;gap:20px">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">💳 Payment Method</h3>
                </div>
                <div class="card-body">
                    <div style="display:flex;flex-direction:column;gap:12px">
                        <label style="display:flex;align-items:center;gap:12px;padding:12px;border:1px solid var(--border);border-radius:8px;cursor:pointer">
                            <input type="radio" asp-for="PaymentMethod" value="@CattleFarm.Models.PaymentMethod.Cash" checked style="accent-color:var(--primary);width:18px;height:18px" />
                            <div>
                                <div style="font-weight:600">💵 Cash on Delivery</div>
                                <div style="font-size:12px;color:var(--text-muted)">Pay cash when product arrives</div>
                            </div>
                        </label>
                        
                        <label style="display:flex;align-items:center;gap:12px;padding:12px;border:1px solid var(--border);border-radius:8px;cursor:pointer">
                            <input type="radio" asp-for="PaymentMethod" value="@CattleFarm.Models.PaymentMethod.Bkash" style="accent-color:var(--primary);width:18px;height:18px" />
                            <div>
                                <div style="font-weight:600">📱 Online Payment</div>
                                <div style="font-size:12px;color:var(--text-muted)">bKash, Nagad, Cards (SSLCommerz)</div>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">📊 Order Summary</h3>
                </div>
                <div class="card-body">
                    <div style="display:flex;justify-content:space-between;margin-bottom:8px">
                        <span style="color:var(--text-muted)">Subtotal:</span>
                        <span style="font-weight:600">@Currency.GetSettings().Symbol <span id="subtotalAmount">0.00</span></span>
                    </div>
                    <div style="display:flex;justify-content:space-between;margin-bottom:16px">
                        <span style="color:var(--text-muted)">Delivery Fee:</span>
                        <span style="font-weight:600;color:var(--success)">FREE</span>
                    </div>
                    <hr style="border:0;border-top:1px solid var(--border);margin-bottom:16px" />
                    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:20px">
                        <span style="font-weight:700;font-size:16px">Total:</span>
                        <span style="font-size:24px;font-weight:800;color:var(--primary)">@Currency.GetSettings().Symbol <span id="totalAmount">0.00</span></span>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-check2-circle"></i> Place Order
                    </button>
                    <a href="/Product" class="btn btn-outline w-100" style="margin-top:10px">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const quantityInput = document.getElementById("quantityInput");
            const subtotalSpan = document.getElementById("subtotalAmount");
            const totalSpan = document.getElementById("totalAmount");
            
            function calculateTotal() {
                let price = 0;
                const productSelector = document.getElementById("productSelector");
                const unitPriceSpan = document.getElementById("unitPrice");
                
                if (unitPriceSpan) {
                    price = parseFloat(unitPriceSpan.textContent);
                } else if (productSelector) {
                    const selectedOpt = productSelector.options[productSelector.selectedIndex];
                    price = parseFloat(selectedOpt.getAttribute("data-price") || 0);
                }
                
                const quantity = parseFloat(quantityInput.value || 0);
                const total = price * quantity;
                const formatted = total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                
                subtotalSpan.textContent = formatted;
                totalSpan.textContent = formatted;
            }

            quantityInput.addEventListener("input", calculateTotal);
            const productSelector = document.getElementById("productSelector");
            if (productSelector) {
                productSelector.addEventListener("change", calculateTotal);
            }
            
            calculateTotal();
        });
    </script>
}
