@model CattleFarm.Models.Order
@{
    ViewData["Title"] = $"Order #{Model.Id}";
    
    var statusBadge = Model.OrderStatus switch {
        CattleFarm.Models.OrderStatus.Delivered  => "badge-success",
        CattleFarm.Models.OrderStatus.Cancelled  => "badge-danger",
        CattleFarm.Models.OrderStatus.Processing => "badge-info",
        CattleFarm.Models.OrderStatus.Shipped    => "badge-primary",
        _ => "badge-warning"
    };

    var payBadge = Model.PaymentStatus switch {
        CattleFarm.Models.PaymentStatus.Completed => "badge-success",
        CattleFarm.Models.PaymentStatus.Failed    => "badge-danger",
        CattleFarm.Models.PaymentStatus.Refunded  => "badge-warning",
        _ => "badge-gray"
    };
}

<div class="page-header">
    <div>
        <h1 class="page-title"> Order #@Model.Id</h1>
        <p class="page-subtitle">Placed on @Model.OrderDate.ToString("MMMM dd, yyyy 'at' hh:mm tt")</p>
    </div>
    <div style="display:flex;gap:8px">
        <a href="/Order" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Back to Orders</a>
        
        @if (Model.OrderStatus == CattleFarm.Models.OrderStatus.Pending)
        {
            <form method="post" asp-action="Cancel" asp-route-id="@Model.Id" style="display:inline" onsubmit="return confirm('Are you sure you want to cancel this order?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger"><i class="bi bi-x-circle"></i> Cancel Order</button>
            </form>
        }
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 340px;gap:24px;align-items:start">
    <div style="display:flex;flex-direction:column;gap:20px">
        
        <!-- Status Tracker -->
        <div class="card">
            <div class="card-body" style="display:flex;justify-content:space-between;align-items:center;padding:20px">
                <div style="display:flex;gap:24px">
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;font-weight:700">Fulfillment Status</div>
                        <div style="margin-top:4px"><span class="badge @statusBadge" style="font-size:14px;padding:6px 12px">@Model.OrderStatus</span></div>
                    </div>
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;font-weight:700">Payment Status</div>
                        <div style="margin-top:4px"><span class="badge @payBadge" style="font-size:14px;padding:6px 12px">@Model.PaymentStatus</span></div>
                    </div>
                </div>
                @if (Model.DeliveredAt.HasValue)
                {
                    <div style="font-size:13px;color:var(--success);font-weight:600">
                        <i class="bi bi-check-circle-fill"></i> Delivered @Model.DeliveredAt.Value.ToString("MMM dd, yyyy")
                    </div>
                }
            </div>
        </div>

        <!-- Items Table -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">📦 Items in this Order</h3></div>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Item Name</th>
                            <th style="text-align:right">Quantity</th>
                            <th style="text-align:right">Unit Price</th>
                            <th style="text-align:right">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:600;color:var(--text-primary)">@(item.Product?.Name ?? $"Product #{item.ProductId}")</div>
                                    <div style="font-size:11px;color:var(--text-muted)">Category: @(item.Product?.Category.ToString() ?? "N/A")</div>
                                </td>
                                <td style="text-align:right">@item.Quantity @(item.Product?.Unit ?? "unit")</td>
                                <td style="text-align:right">@Currency.Format(item.UnitPrice)</td>
                                <td style="text-align:right;font-weight:700;color:var(--primary)">@Currency.Format(item.TotalPrice)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Delivery & Address Info -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">📍 Shipping &amp; Logistics</h3></div>
            <div class="card-body" style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
                <div>
                    <div style="font-weight:600;font-size:13px;color:var(--text-muted);margin-bottom:6px">Delivery Address</div>
                    <p style="white-space:pre-line;font-size:14px;line-height:1.5;color:var(--text-primary)">@(Model.DeliveryAddress ?? "No address specified")</p>
                </div>
                <div>
                    <div style="font-weight:600;font-size:13px;color:var(--text-muted);margin-bottom:6px">Customer Notes</div>
                    <p style="white-space:pre-line;font-size:14px;line-height:1.5;color:var(--text-primary)">@(Model.Notes ?? "No additional notes provided")</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Right column: summary + action panel -->
    <div style="display:flex;flex-direction:column;gap:20px">
        
        <!-- Summary Panel -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">💵 Payment Summary</h3></div>
            <div class="card-body">
                <div style="display:flex;justify-content:space-between;margin-bottom:10px">
                    <span style="color:var(--text-muted)">Payment Method:</span>
                    <span style="font-weight:600">
                        @if (Model.Payments.Any())
                        {
                            <span>@Model.Payments.First().Method</span>
                        }
                        else
                        {
                            <span>Cash on Delivery</span>
                        }
                    </span>
                </div>
                
                @if (Model.Payments.Any(p => !string.IsNullOrEmpty(p.TransactionId)))
                {
                    <div style="display:flex;justify-content:space-between;margin-bottom:10px;font-size:12px">
                        <span style="color:var(--text-muted)">Transaction ID:</span>
                        <span style="font-family:monospace;word-break:break-all">@Model.Payments.First(p => !string.IsNullOrEmpty(p.TransactionId)).TransactionId</span>
                    </div>
                }
                
                <hr style="border:0;border-top:1px solid var(--border);margin:12px 0" />
                <div style="display:flex;justify-content:space-between;align-items:baseline">
                    <span style="font-weight:700">Total Paid/Due:</span>
                    <span style="font-size:22px;font-weight:800;color:var(--primary)">@Currency.Format(Model.TotalAmount)</span>
                </div>
                
                @if (Model.PaymentStatus == CattleFarm.Models.PaymentStatus.Pending && Model.OrderStatus != CattleFarm.Models.OrderStatus.Cancelled)
                {
                    <form method="post" asp-action="Pay" style="margin-top: 16px;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-warning w-100">
                            <i class="bi bi-credit-card"></i> Pay Online
                        </button>
                    </form>
                }
            </div>
        </div>

        <!-- Administrator Actions -->
        @if (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager"))
        {
            @if (Model.OrderStatus != CattleFarm.Models.OrderStatus.Cancelled && Model.OrderStatus != CattleFarm.Models.OrderStatus.Delivered)
            {
                <div class="card">
                    <div class="card-header"><h3 class="card-title">⚙️ Fulfillment Panel</h3></div>
                    <div class="card-body">
                        <form method="post" asp-action="UpdateStatus">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            
                            <div class="form-group">
                                <label class="form-label">Update Status</label>
                                <select name="status" class="form-control">
                                    @if (Model.OrderStatus == CattleFarm.Models.OrderStatus.Pending)
                                    {
                                        <option value="@((int)CattleFarm.Models.OrderStatus.Processing)">Processing</option>
                                    }
                                    @if (Model.OrderStatus == CattleFarm.Models.OrderStatus.Pending || Model.OrderStatus == CattleFarm.Models.OrderStatus.Processing)
                                    {
                                        <option value="@((int)CattleFarm.Models.OrderStatus.Shipped)">Shipped</option>
                                    }
                                    <option value="@((int)CattleFarm.Models.OrderStatus.Delivered)">Delivered</option>
                                </select>
                            </div>
                            
                            <button type="submit" class="btn btn-primary w-100" style="margin-top:12px">
                                <i class="bi bi-save"></i> Save Status
                            </button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>
