@model IEnumerable<CattleFarm.Models.Order>
@{
    ViewData["Title"] = "Orders";
    int currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    int totalPages  = (int)(ViewData["TotalPages"]  ?? 1);
}
<div class="page-header">
    <div><h1 class="page-title">🛒 Orders</h1><p class="page-subtitle">Customer orders and fulfillment management</p></div>
    <div class="page-actions">
        <a href="/Product" class="btn btn-primary"><i class="bi bi-plus-circle"></i> New Order</a>
    </div>
</div>

<div class="card">
    <div class="table-wrapper">
        @if (!Model.Any())
        { <div class="empty-state" style="padding:40px"><div class="empty-icon">🛒</div><h3>No orders yet</h3></div> }
        else
        {
            <table class="data-table">
                <thead><tr><th>Order #</th><th>Customer</th><th>Farm</th><th>Items</th><th>Total</th><th>Payment</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        var statusBadge = o.OrderStatus switch {
                            CattleFarm.Models.OrderStatus.Delivered  => "badge-success",
                            CattleFarm.Models.OrderStatus.Cancelled  => "badge-danger",
                            CattleFarm.Models.OrderStatus.Processing => "badge-info",
                            CattleFarm.Models.OrderStatus.Shipped    => "badge-primary",
                            _ => "badge-warning"
                        };
                        var payBadge = o.PaymentStatus switch {
                            CattleFarm.Models.PaymentStatus.Completed => "badge-success",
                            CattleFarm.Models.PaymentStatus.Failed    => "badge-danger",
                            CattleFarm.Models.PaymentStatus.Refunded  => "badge-warning",
                            _ => "badge-gray"
                        };
                        <tr>
                            <td><a href="/Order/Details/@o.Id" style="font-weight:700;color:var(--primary)">#@o.Id</a></td>
                            <td>
                                <div style="font-size:13px;font-weight:600">@(o.Customer?.FullName ?? "—")</div>
                                <div style="font-size:11px;color:var(--text-muted)">@o.Customer?.Email</div>
                            </td>
                            <td style="font-size:12px">@(o.Farm?.Name ?? "—")</td>
                            <td style="font-size:13px;color:var(--text-secondary)">@o.OrderItems.Count items</td>
                            <td style="font-weight:700;color:var(--primary)">৳@o.TotalAmount.ToString("N0")</td>
                            <td><span class="badge @payBadge">@o.PaymentStatus</span></td>
                            <td><span class="badge @statusBadge">@o.OrderStatus</span></td>
                            <td style="font-size:12px;color:var(--text-muted)">@o.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div style="display:flex;gap:6px">
                                    <a href="/Order/Details/@o.Id" class="btn btn-outline btn-sm">View</a>
                                    @if (o.PaymentStatus == CattleFarm.Models.PaymentStatus.Pending && o.OrderStatus != CattleFarm.Models.OrderStatus.Cancelled)
                                    {
                                        <form method="post" asp-action="Pay" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@o.Id" />
                                            <button class="btn btn-warning btn-sm">Pay Online</button>
                                        </form>
                                    }
                                    @if (o.OrderStatus == CattleFarm.Models.OrderStatus.Pending && (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager")))
                                    {
                                        <form method="post" asp-action="UpdateStatus" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@o.Id" />
                                            <input type="hidden" name="status" value="@((int)CattleFarm.Models.OrderStatus.Processing)" />
                                            <button class="btn btn-primary btn-sm">Process</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
    @if (totalPages > 1)
    {
        <div class="card-footer">
            <div class="pagination" style="padding:0">
                @if (currentPage > 1) { <a href="?page=@(currentPage-1)" class="page-link"><i class="bi bi-chevron-left"></i></a> }
                @for (int i = Math.Max(1,currentPage-2); i <= Math.Min(totalPages,currentPage+2); i++)
                { <a href="?page=@i" class="page-link @(i==currentPage?"active":"")">@i</a> }
                @if (currentPage < totalPages) { <a href="?page=@(currentPage+1)" class="page-link"><i class="bi bi-chevron-right"></i></a> }
            </div>
        </div>
    }
</div>
