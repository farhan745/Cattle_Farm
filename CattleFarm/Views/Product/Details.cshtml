@model CattleFarm.Models.Product
@{
    ViewData["Title"] = Model.Name;
    var emoji = Model.Category switch
    {
        CattleFarm.Models.ProductCategory.Milk => "🥛",
        CattleFarm.Models.ProductCategory.Beef => "🥩",
        CattleFarm.Models.ProductCategory.Manure => "🌱",
        CattleFarm.Models.ProductCategory.BreedingService => "🐄",
        _ => "📦"
    };
}

<div class="page-header">
    <div>
        <h1 class="page-title">📦 @Model.Name</h1>
        <p class="page-subtitle">@Model.Category Product — Provided by @(Model.Farm?.Name ?? "Our Farm")</p>
    </div>
    <div class="page-actions" style="display:flex;gap:8px;align-items:center">
        @if (User.IsInRole("Admin") || User.IsInRole("Owner") || User.IsInRole("Manager"))
        {
            <a href="/Product/Edit/@Model.Id" class="btn btn-outline"><i class="bi bi-pencil"></i> Edit</a>
        }
        @if (User.IsInRole("Admin"))
        {
            <form method="post" asp-action="Delete" asp-route-id="@Model.Id" onsubmit="return confirm('Are you sure you want to delete this product?');" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
            </form>
        }
        <a href="/Product" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Back to Products</a>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 360px;gap:24px;align-items:start">
    <div style="display:flex;flex-direction:column;gap:20px">
        <!-- Product Main Card -->
        <div class="card" style="padding:0;overflow:hidden">
            <div style="display:flex;background:var(--card-bg);height:320px;align-items:center;justify-content:center;font-size:120px;border-bottom:1px solid var(--border);position:relative;overflow:hidden">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" alt="@Model.Name" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s ease" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
                }
                else
                {
                    <span>@emoji</span>
                }
                @if (Model.IsFeatured)
                {
                    <span style="position:absolute;top:16px;right:16px;background:#f59e0b;color:#fff;font-size:11px;font-weight:800;padding:4px 12px;border-radius:999px;text-transform:uppercase;letter-spacing:1px;box-shadow:0 4px 10px rgba(245,158,11,0.3)">
                        ⭐ Featured
                    </span>
                }
            </div>
            <div class="card-body" style="padding:24px">
                <h3 style="font-size:20px;font-weight:800;margin-bottom:12px;color:var(--text-primary)">Description</h3>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p style="font-size:14px;color:var(--text-secondary);line-height:1.7;margin:0">@Model.Description</p>
                }
                else
                {
                    <p style="font-size:14px;color:var(--text-muted);font-style:italic;margin:0">No description provided for this product.</p>
                }
            </div>
        </div>
    </div>

    <!-- Right Sidebar Info Card -->
    <div style="display:flex;flex-direction:column;gap:20px">
        <!-- Pricing & Order Action Card -->
        <div class="card" style="border-top: 4px solid var(--primary)">
            <div class="card-body" style="padding:24px">
                <div style="text-align:center;margin-bottom:20px">
                    <div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;font-weight:700;letter-spacing:0.5px">Price</div>
                    <div style="font-size:32px;font-weight:900;color:var(--primary);margin:6px 0 2px">
                        @Currency.Format(Model.Price)
                    </div>
                    <div style="font-size:13px;color:var(--text-secondary)">per @Model.Unit</div>
                </div>

                <div style="display:flex;justify-content:space-between;padding:12px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);margin-bottom:20px;font-size:13px">
                    <span style="color:var(--text-muted)">Availability Status</span>
                    @if (!Model.IsAvailable)
                    {
                        <span class="badge badge-danger">Out of Stock</span>
                    }
                    else if (Model.StockQuantity <= Model.MinStockLevel)
                    {
                        <span class="badge badge-warning">Low Stock (@Model.StockQuantity @Model.Unit)</span>
                    }
                    else
                    {
                        <span class="badge badge-success">In Stock (@Model.StockQuantity @Model.Unit)</span>
                    }
                </div>

                @if (Model.IsAvailable && Model.StockQuantity > 0)
                {
                    <a href="/Order/Create?farmId=@Model.FarmId&productId=@Model.Id" class="btn btn-primary w-100" style="padding:12px;font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center;gap:8px">
                        <i class="bi bi-cart-check-fill" style="font-size:16px"></i> Place Order Now
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary w-100" disabled style="padding:12px;font-size:14px;font-weight:700">
                        Currently Unavailable
                    </button>
                }
            </div>
        </div>

        <!-- Supplier Farm Card -->
        @if (Model.Farm != null)
        {
            <div class="card">
                <div class="card-header" style="padding-bottom:8px">
                    <h3 class="card-title" style="font-size:14px"><i class="bi bi-shop"></i> Supplier Farm</h3>
                </div>
                <div class="card-body" style="padding:16px 20px 20px">
                    <div style="font-size:16px;font-weight:800;color:var(--text-primary);margin-bottom:4px">@Model.Farm.Name</div>
                    <div style="font-size:12px;color:var(--text-secondary);display:flex;align-items:center;gap:4px;margin-bottom:14px">
                        <i class="bi bi-geo-alt-fill" style="color:var(--primary)"></i> @Model.Farm.Location
                    </div>
                    <a href="/Farm/Details/@Model.FarmId" class="btn btn-outline btn-sm w-100" style="font-size:12px">
                        <i class="bi bi-arrow-right-short"></i> View Farm Details
                    </a>
                </div>
            </div>
        }
    </div>
</div>
