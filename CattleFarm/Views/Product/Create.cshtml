@model CattleFarm.ViewModels.ProductViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Add Product" : "Edit Product";
    var isEdit = Model.Id > 0;
    var farms = (IEnumerable<CattleFarm.Models.Farm>)ViewBag.Farms;
}
<div class="page-header">
    <div>
        <h1 class="page-title">@(isEdit ? "✏️ Edit Product" : "📦 Add Product / Service")</h1>
        <p class="page-subtitle">@(isEdit ? $"Editing {Model.Name}" : "Add a new product or service listing to the marketplace")</p>
    </div>
    <a href="/Product" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }
    <input type="hidden" asp-for="ExistingImagePath" />

    <div style="display:grid;grid-template-columns:1fr 300px;gap:24px;align-items:start">
        <div style="display:flex;flex-direction:column;gap:20px">

            <div class="card">
                <div class="card-header"><h3 class="card-title">📦 Product Information</h3></div>
                <div class="card-body">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                        <div class="form-group" style="grid-column:1/-1">
                            <label class="form-label">Product/Service Name *</label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Fresh Organic Milk" />
                            <span asp-validation-for="Name" class="form-error"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Category *</label>
                            <select asp-for="Category" class="form-control" asp-items="Html.GetEnumSelectList<CattleFarm.Models.ProductCategory>()"></select>
                            <span asp-validation-for="Category" class="form-error"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Farm *</label>
                            <select asp-for="FarmId" class="form-control">
                                <option value="">Select a farm...</option>
                                @foreach (var f in farms)
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </select>
                            <span asp-validation-for="FarmId" class="form-error"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Price per Unit * (@Currency.GetSettings().Symbol)</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="0.00" />
                            <span asp-validation-for="Price" class="form-error"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Unit of Measure *</label>
                            <input asp-for="Unit" class="form-control" placeholder="e.g. Liter, kg, Service" />
                            <span asp-validation-for="Unit" class="form-error"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Stock Quantity</label>
                            <input asp-for="StockQuantity" class="form-control" type="number" step="0.01" placeholder="0.0" />
                            <span asp-validation-for="StockQuantity" class="form-error"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Minimum Stock Level (Alert threshold)</label>
                            <input asp-for="MinStockLevel" class="form-control" type="number" step="0.01" placeholder="0.0" />
                            <span asp-validation-for="MinStockLevel" class="form-error"></span>
                        </div>
                        <div class="form-group" style="grid-column:1/-1">
                            <label class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the quality, packaging, specifications, etc..."></textarea>
                            <span asp-validation-for="Description" class="form-error"></span>
                        </div>
                        <div class="form-group" style="grid-column:1/-1;display:flex;gap:24px">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input asp-for="IsAvailable" type="checkbox" style="accent-color:var(--primary);width:16px;height:16px" />
                                <span class="form-label" style="margin:0">Available in Shop</span>
                            </label>
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input asp-for="IsFeatured" type="checkbox" style="accent-color:var(--primary);width:16px;height:16px" />
                                <span class="form-label" style="margin:0">Featured Product ⭐</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:20px">
            <div class="card">
                <div class="card-header"><h3 class="card-title">📷 Product Image</h3></div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ExistingImagePath))
                    {
                        <img id="productPreview" src="@Model.ExistingImagePath" style="width:100%;height:200px;object-fit:cover;border-radius:8px;margin-bottom:12px" />
                    }
                    else
                    {
                        <div id="productPlaceholder" style="width:100%;height:200px;background:var(--bg);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:64px;margin-bottom:12px">📦</div>
                        <img id="productPreview" style="display:none;width:100%;height:200px;object-fit:cover;border-radius:8px;margin-bottom:12px" />
                    }
                    <label class="img-upload-zone" for="productImg">
                        <div style="font-size:22px">📷</div>
                        <div style="font-size:13px;font-weight:600">Upload Image</div>
                        <div style="font-size:11px;color:var(--text-muted)">JPG, PNG — max 5MB</div>
                    </label>
                    <input type="file" name="ImageFile" id="productImg" accept="image/*" style="display:none"
                           onchange="previewImage(this,'productPreview');document.getElementById('productPlaceholder')?.remove()" />
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        <i class="bi bi-@(isEdit?"check-circle":"plus-circle")"></i>
                        @(isEdit ? "Save Changes" : "Add Product")
                    </button>
                    <a href="/Product" class="btn btn-outline w-100" style="margin-top:10px">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</form>
