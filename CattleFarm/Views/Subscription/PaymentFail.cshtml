@{
    Layout = "_Layout";
    ViewData["Title"] = "Payment Failed";
}
<div style="text-align:center;padding:80px 20px">
    <div style="font-size:80px;margin-bottom:20px">❌</div>
    <h1 style="font-size:36px;font-weight:800;color:#ef4444;margin-bottom:8px">Payment Failed</h1>
    <p style="font-size:16px;color:#6B6B66;max-width:480px;margin:0 auto 32px;line-height:1.7">
        @(ViewBag.Error ?? "Your payment could not be processed. No amount was charged.")
    </p>
    @if (ViewBag.TransactionId != null)
    {
        <p style="font-size:12px;color:#9CA3AF;margin-bottom:32px">Reference: <code>@ViewBag.TransactionId</code></p>
    }
    <div style="display:flex;gap:12px;justify-content:center">
        <a href="/Subscription" class="btn btn-primary btn-lg"><i class="bi bi-arrow-repeat"></i> Try Again</a>
        <a href="/Dashboard" class="btn btn-outline btn-lg">Dashboard</a>
    </div>
</div>
