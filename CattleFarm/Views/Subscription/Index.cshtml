@model CattleFarm.Models.Subscription
@{
    ViewData["Title"] = "Subscription Plans";
    var current = Model;

    var plans = new[]
    {
        new { Enum="Free",       Display="Free",       Price=0m,    Icon="🌱", Features=new[]{"1 Farm","Up to 10 Cattle","Basic Dashboard","Community Support"}, Popular=false },
        new { Enum="Member",     Display="Basic",      Price=999m,  Icon="⭐", Features=new[]{"3 Farms","Up to 100 Cattle","Advanced Analytics","Health Monitoring","Email Support","Financial Reports"}, Popular=false },
        new { Enum="Owner",      Display="Pro",        Price=2999m, Icon="🏆", Features=new[]{"Unlimited Farms","Unlimited Cattle","Full AI Dashboard","AI-Powered Insights","Priority Support","PDF/Excel Export","IoT Ready","Marketplace Access"}, Popular=true },
        new { Enum="Enterprise", Display="Enterprise", Price=5000m, Icon="🚀", Features=new[]{"Everything in Pro","White-label Option","Dedicated Support","Custom Integrations","SLA Guarantee","Onboarding Service"}, Popular=false }
    };
}

<div class="page-header">
    <div>
        <h1 class="page-title">⭐ Subscription Plans</h1>
        <p class="page-subtitle">Choose the plan that fits your farm. Cancel anytime.</p>
    </div>
</div>

<!-- Current Plan Banner -->
@if (current != null)
{
    <div class="alert alert-success" style="margin-bottom:24px">
        <i class="bi bi-star-fill" style="font-size:20px"></i>
        <div>
            <strong>Current Plan: @(current.Plan == CattleFarm.Models.SubscriptionPlan.Owner ? "Pro" : current.Plan == CattleFarm.Models.SubscriptionPlan.Member ? "Basic" : current.Plan.ToString())</strong> —
            Active until @current.ExpiryDate.ToString("MMMM dd, yyyy")
            @if (current.IsActive && current.ExpiryDate > DateTime.Now.AddDays(30))
            { <span class="badge badge-success" style="margin-left:8px">Active ✓</span> }
            else
            { <span class="badge badge-warning" style="margin-left:8px">Expiring Soon</span> }
        </div>
    </div>
}

<!-- Billing Toggle -->
<div style="text-align:center;margin-bottom:32px">
    <div style="display:inline-flex;background:#F2EDE4;border-radius:30px;padding:4px;gap:4px">
        <button id="btnMonthly" onclick="setBilling('monthly')"
                style="padding:8px 24px;border-radius:26px;border:none;font-weight:600;font-size:13px;cursor:pointer;background:#2D5A3D;color:#fff;transition:.2s">
            Monthly
        </button>
        <button id="btnAnnual" onclick="setBilling('annual')"
                style="padding:8px 24px;border-radius:26px;border:none;font-weight:600;font-size:13px;cursor:pointer;background:transparent;color:#6B6B66;transition:.2s">
            Annual <span style="background:#C8761A;color:#fff;font-size:10px;padding:2px 6px;border-radius:10px;margin-left:4px">Save 20%</span>
        </button>
    </div>
</div>

<!-- Pricing Cards -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:40px" id="plansGrid">
    @foreach (var plan in plans)
    {
        var isCurrent = current?.Plan.ToString() == plan.Enum;
        var cardStyle = plan.Popular
            ? "border:2px solid #C8761A;transform:translateY(-8px);box-shadow:0 20px 60px rgba(200,118,26,.2)"
            : "border:1px solid #DDD5C8";
        <div class="card animate-in" style="position:relative;@cardStyle;border-radius:16px;overflow:visible">
            @if (plan.Popular)
            {
                <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:#C8761A;color:#fff;font-size:11px;font-weight:700;padding:4px 16px;border-radius:20px;white-space:nowrap;letter-spacing:.05em">
                    ✦ MOST POPULAR
                </div>
            }
            <div class="card-body" style="padding:32px 24px;text-align:center">
                <div style="font-size:40px;margin-bottom:12px">@plan.Icon</div>
                <div style="font-size:13px;font-weight:700;letter-spacing:.1em;color:#6B6B66;text-transform:uppercase;margin-bottom:8px">@plan.Display</div>
                <div class="plan-price" data-monthly="@plan.Price" data-annual="@(Math.Floor(plan.Price * 0.8m))"
                     style="font-size:42px;font-weight:800;color:@(plan.Popular ? "#C8761A" : "#1C3A2A");line-height:1;margin-bottom:4px">
                    @(plan.Price == 0 ? "Free" : $"৳{plan.Price:N0}")
                </div>
                @if (plan.Price > 0)
                {
                    <div style="font-size:12px;color:#9CA3AF;margin-bottom:20px">/month · billed monthly</div>
                }
                else
                {
                    <div style="font-size:12px;color:#9CA3AF;margin-bottom:20px">forever</div>
                }

                <div style="text-align:left;margin-bottom:24px">
                    @foreach (var f in plan.Features)
                    {
                        <div style="display:flex;align-items:center;gap:8px;padding:5px 0;font-size:13px;color:#3D3D3A;border-bottom:1px solid #F2EDE4">
                            <i class="bi bi-check-circle-fill" style="color:#2D5A3D;font-size:13px;flex-shrink:0"></i>
                            @f
                        </div>
                    }
                </div>

                @if (isCurrent)
                {
                    <span class="badge badge-success" style="font-size:13px;padding:10px 24px;width:100%;display:block">✓ Current Plan</span>
                }
                else if (plan.Enum == "Free")
                {
                    <a href="/Dashboard" class="btn btn-outline w-100">Get Started Free</a>
                }
                else
                {
                    <!-- Order Summary Modal Trigger -->
                    <button class="btn @(plan.Popular ? "btn-primary" : "btn-outline") w-100"
                            onclick="showOrderSummary('@plan.Enum','@plan.Display','@plan.Price')"
                            style="@(plan.Popular ? "" : "")">
                        <i class="bi bi-bag-check"></i> Subscribe Now
                    </button>
                }
            </div>
        </div>
    }
</div>

<!-- Money-back guarantee -->
<div style="text-align:center;margin-bottom:32px;font-size:13px;color:#6B6B66">
    <i class="bi bi-shield-check" style="color:#2D5A3D;font-size:18px;margin-right:6px"></i>
    <strong>30-Day Money-Back Guarantee</strong> · No questions asked · Cancel anytime
</div>

<!-- Payment Methods -->
<div class="card" style="margin-bottom:32px">
    <div class="card-header"><h3 class="card-title">💳 Accepted Payment Methods</h3></div>
    <div class="card-body">
        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
            @foreach (var m in new[]{ ("💚","bKash"), ("🟠","Nagad"), ("💳","Visa"), ("💳","MasterCard"), ("💎","Amex") })
            {
                <div style="display:flex;align-items:center;gap:6px;padding:8px 16px;border:1px solid #DDD5C8;border-radius:8px;font-size:13px;font-weight:600;background:#FAF8F4">
                    <span>@m.Item1</span> @m.Item2
                </div>
            }
            <div style="margin-left:auto;display:flex;align-items:center;gap:6px;font-size:12px;color:#9CA3AF">
                <i class="bi bi-lock-fill" style="color:#2D5A3D"></i> Secured by SSLCommerz
            </div>
        </div>
        <p style="font-size:12px;color:#9CA3AF;margin-top:12px;margin-bottom:0">
            All transactions are encrypted and processed via SSLCommerz, Bangladesh's #1 payment gateway.
        </p>
    </div>
</div>

<!-- ORDER SUMMARY MODAL -->
<div id="orderModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;backdrop-filter:blur(4px)">
    <div style="background:#fff;border-radius:20px;padding:40px;max-width:440px;width:90%;animation:fadeInUp .3s ease;box-shadow:0 20px 60px rgba(0,0,0,.2)">
        <h3 style="font-size:22px;font-weight:700;color:#1C3A2A;margin-bottom:4px">Order Summary</h3>
        <p style="color:#9CA3AF;font-size:13px;margin-bottom:24px">Review your subscription details</p>

        <div style="background:#FAF8F4;border-radius:12px;padding:20px;margin-bottom:24px">
            <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #E8E0D4">
                <span style="color:#6B6B66;font-size:14px">Plan</span>
                <strong id="modalPlanName" style="color:#1C3A2A"></strong>
            </div>
            <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #E8E0D4">
                <span style="color:#6B6B66;font-size:14px">Billing Cycle</span>
                <strong style="color:#1C3A2A">Monthly</strong>
            </div>
            <div style="display:flex;justify-content:space-between;padding:8px 0">
                <span style="color:#6B6B66;font-size:14px">Amount</span>
                <strong id="modalAmount" style="color:#C8761A;font-size:20px"></strong>
            </div>
        </div>

        <p style="font-size:12px;color:#9CA3AF;margin-bottom:20px">
            By proceeding, you'll be redirected to SSLCommerz secure payment gateway. You can pay via bKash, Nagad, Visa, MasterCard, or Amex.
        </p>

        <form method="post" asp-action="InitiatePayment" asp-controller="Subscription" id="paymentForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="plan" id="modalPlanInput" />
            <div style="display:flex;gap:12px">
                <button type="submit" id="proceedBtn" class="btn btn-primary btn-lg" style="flex:1">
                    <i class="bi bi-credit-card"></i> Proceed to Payment
                </button>
                <button type="button" onclick="closeModal()" class="btn btn-outline btn-lg" style="padding:12px 20px">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function showOrderSummary(planEnum, planDisplay, price) {
    document.getElementById('modalPlanName').textContent  = planDisplay + ' Plan';
    document.getElementById('modalAmount').textContent    = '৳' + Number(price).toLocaleString() + '/month';
    document.getElementById('modalPlanInput').value       = planEnum;
    const modal = document.getElementById('orderModal');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}
function closeModal() {
    document.getElementById('orderModal').style.display = 'none';
    document.body.style.overflow = '';
}
document.getElementById('orderModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });

// Billing toggle
function setBilling(mode) {
    const isAnnual = mode === 'annual';
    document.getElementById('btnMonthly').style.background = isAnnual ? 'transparent' : '#2D5A3D';
    document.getElementById('btnMonthly').style.color      = isAnnual ? '#6B6B66' : '#fff';
    document.getElementById('btnAnnual').style.background  = isAnnual ? '#2D5A3D' : 'transparent';
    document.getElementById('btnAnnual').style.color       = isAnnual ? '#fff' : '#6B6B66';
    document.querySelectorAll('.plan-price').forEach(el => {
        const monthly = parseFloat(el.dataset.monthly);
        const annual  = parseFloat(el.dataset.annual);
        if (!monthly) return;
        el.textContent = '৳' + (isAnnual ? annual : monthly).toLocaleString();
    });
}

// Proceed button loading state
document.getElementById('paymentForm').addEventListener('submit', () => {
    const btn = document.getElementById('proceedBtn');
    btn.innerHTML = '<i class="bi bi-arrow-repeat" style="animation:spin 1s linear infinite;display:inline-block"></i> Redirecting...';
    btn.disabled = true;
});
</script>
