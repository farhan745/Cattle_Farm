@model CattleFarm.ViewModels.LoginViewModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — Smart Cattle Farm</title>
    <meta name="description" content="Sign in to your Smart Cattle Farm management account to track livestock, health, and finances." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            font-family: 'IBM Plex Sans', 'Inter', system-ui, sans-serif;
            background-color: #f3f6f4;
            background-image: 
                linear-gradient(rgba(23, 33, 27, 0.045) 1px, transparent 1px),
                linear-gradient(90deg, rgba(23, 33, 27, 0.04) 1px, transparent 1px),
                linear-gradient(180deg, #ffffff 0%, #edf4ef 100%);
            background-size: 32px 32px;
            color: #17211b;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            margin: 0;
            position: relative;
            overflow-x: hidden;
        }

        .login-wrapper {
            width: 100%;
            max-width: 960px;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 32px;
            animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .brand-header-center {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            text-align: center;
        }

        .brand-logo-icon {
            width: 52px;
            height: 52px;
            background: #137a3a;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            font-size: 26px;
            box-shadow: 0 10px 22px rgba(19, 122, 58, 0.18);
        }

        .brand-logo-name {
            font-family: 'Inter', 'IBM Plex Sans', system-ui, sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: #17211b;
            letter-spacing: 0;
        }

        .brand-logo-sub {
            font-size: 14px;
            color: #506058;
            font-weight: 600;
            margin-top: -4px;
        }

        .auth-container-wrapper {
            width: 100%;
            display: flex;
            gap: 32px;
            justify-content: center;
            align-items: stretch;
            flex-wrap: wrap;
        }

        .auth-card-premium {
            background: #ffffff;
            border: 1px solid #dbe3de;
            border-radius: 8px;
            box-shadow: 0 18px 40px rgba(18, 31, 24, 0.12);
            width: 100%;
            max-width: 440px;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .auth-card-premium:hover {
            transform: translateY(-2px);
            box-shadow: 0 22px 46px rgba(18, 31, 24, 0.14);
        }

        .auth-header-premium {
            padding: 32px 32px 20px;
            text-align: center;
            border-bottom: 1px solid #dbe3de;
            background: #fbfdfc;
        }

        .auth-header-premium h2 {
            font-family: 'Inter', 'IBM Plex Sans', system-ui, sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: #17211b;
            letter-spacing: 0;
        }

        .auth-header-premium p {
            font-size: 14px;
            color: #506058;
            margin-top: 4px;
        }

        .auth-body-premium {
            padding: 32px;
            flex: 1;
        }

        .auth-footer-premium {
            padding: 20px 32px;
            background: #fbfdfc;
            border-top: 1px solid #dbe3de;
            text-align: center;
            font-size: 13.5px;
            color: #506058;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 13.5px;
            font-weight: 600;
            color: #405049;
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            padding: 11px 14px;
            border: 1px solid #b9c7c0;
            border-radius: 6px;
            background: #ffffff;
            color: #17211b;
            font-size: 14px;
            font-family: inherit;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: #137a3a;
            box-shadow: 0 0 0 3px rgba(19, 122, 58, 0.14);
        }

        .input-group {
            display: flex;
            position: relative;
        }

        .input-group .form-control {
            border-top-right-radius: 0;
            border-bottom-right-radius: 0;
            flex: 1;
        }

        .input-group-append {
            display: flex;
        }

        .btn-outline {
            border: 1px solid #b9c7c0;
            border-left: none;
            background: #ffffff;
            color: #506058;
            border-top-right-radius: 6px;
            border-bottom-right-radius: 6px;
            padding: 0 16px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-outline:hover {
            color: #17211b;
            background: #eef5f1;
        }

        .btn-primary {
            background: #137a3a;
            color: #ffffff;
            border: none;
            padding: 12px 24px;
            font-size: 14.5px;
            font-weight: 600;
            border-radius: 6px;
            width: 100%;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 8px 18px rgba(19, 122, 58, 0.16);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary:hover {
            background: #0f5f2e;
            box-shadow: 0 10px 22px rgba(19, 122, 58, 0.2);
            transform: translateY(-1px);
        }

        .form-error {
            color: #ef4444;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 13.5px;
            margin-bottom: 20px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }



        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <!-- Logo and brand at top center -->
        <div class="brand-header-center">
            <div class="brand-logo-icon">
                <i class="bi bi-houses"></i>
            </div>
            <div>
                <div class="brand-logo-name">Smart Cattle Farm</div>
                <div class="brand-logo-sub">Livestock & Ranch Operations Platform</div>
            </div>
        </div>

        <div class="auth-container-wrapper">
            <!-- Auth Form Card -->
            <div class="auth-card-premium">
                <div class="auth-header-premium">
                    <h2>Welcome Back</h2>
                    <p>Enter details to access the system</p>
                </div>
                <div class="auth-body-premium">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success" style="background:#f0fdf4;border:1px solid #bbf7d0;color:#166534;padding:12px 16px;border-radius:10px;font-size:13.5px;margin-bottom:20px;display:flex;align-items:flex-start;gap:10px;">
                            <i class="bi bi-check-circle-fill" style="margin-top:2px"></i>
                            <span>@TempData["SuccessMessage"]</span>
                        </div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle-fill" style="margin-top:2px"></i>
                            <span>@Html.ValidationSummary()</span>
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />

                        <div class="form-group">
                            <label class="form-label" for="Email">Email Address</label>
                            <input asp-for="Email" id="Email" class="form-control" placeholder="you@example.com" type="email" autofocus autocomplete="email" />
                            <span asp-validation-for="Email" class="form-error"></span>
                        </div>

                        <div class="form-group" style="margin-bottom: 20px;">
                            <label class="form-label" for="Password">Password</label>
                            <div class="input-group">
                                <input asp-for="Password" id="Password" class="form-control" placeholder="••••••••" type="password" autocomplete="current-password" />
                                <div class="input-group-append">
                                    <button type="button" class="btn btn-outline" id="togglePwd" onclick="togglePassword()" aria-label="Toggle password visibility">
                                        <i class="bi bi-eye" id="pwdIcon"></i>
                                    </button>
                                </div>
                            </div>
                            <span asp-validation-for="Password" class="form-error"></span>
                        </div>

                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
                            <label style="display:flex;align-items:center;gap:8px;font-size:13.5px;cursor:pointer;color:#506058">
                                <input asp-for="RememberMe" type="checkbox" style="accent-color:#137a3a;width:16px;height:16px" />
                                Remember me
                            </label>
                            <a href="/Account/ForgotPassword" style="font-size:13.5px;color:#137a3a;text-decoration:none;font-weight:700">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-box-arrow-in-right"></i> Sign In
                        </button>
                    </form>
                </div>
                <div class="auth-footer-premium">
                    Don't have an account?
                    <a href="/Account/Register" style="font-weight:700;color:#137a3a;text-decoration:none;">Create account &rarr;</a>
                </div>
            </div>


        </div>
    </div>

    <script>
    function togglePassword() {
        const input = document.getElementById('Password');
        const icon  = document.getElementById('pwdIcon');
        if (input.type === 'password') { 
            input.type = 'text'; 
            icon.className = 'bi bi-eye-slash'; 
        } else { 
            input.type = 'password'; 
            icon.className = 'bi bi-eye'; 
        }
    }


    </script>
</body>
</html>
