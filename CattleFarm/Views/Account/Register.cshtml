@model CattleFarm.ViewModels.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Create Account";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account — Smart Cattle Farm</title>
    <meta name="description" content="Register a new account on Smart Cattle Farm to manage livestock, breeding logs, milk records, and more." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            font-family: 'DM Sans', sans-serif;
            background-color: #f8fafc;
            background-image: 
                linear-gradient(rgba(34, 197, 94, 0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(34, 197, 94, 0.04) 1px, transparent 1px);
            background-size: 32px 32px;
            color: #0f172a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            margin: 0;
            position: relative;
            overflow-x: hidden;
        }

        /* Decorative background gradient blobs */
        .bg-blob-1 {
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(34, 197, 94, 0.08) 0%, transparent 70%);
            top: -200px;
            left: -150px;
            pointer-events: none;
            z-index: 1;
        }

        .bg-blob-2 {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.06) 0%, transparent 70%);
            bottom: -250px;
            right: -150px;
            pointer-events: none;
            z-index: 1;
        }

        .register-wrapper {
            width: 100%;
            max-width: 580px;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 32px;
            animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .brand-header-center {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            text-align: center;
        }

        .brand-logo-icon {
            width: 52px;
            height: 52px;
            background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            font-size: 26px;
            box-shadow: 0 10px 20px -5px rgba(34, 197, 94, 0.3);
        }

        .brand-logo-name {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.5px;
        }

        .brand-logo-sub {
            font-size: 14px;
            color: #64748b;
            font-weight: 500;
            margin-top: -4px;
        }

        .auth-container-wrapper {
            width: 100%;
            display: flex;
            justify-content: center;
        }

        .auth-card-premium {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
            width: 100%;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .auth-card-premium:hover {
            transform: translateY(-2px);
            box-shadow: 0 25px 30px -5px rgba(0, 0, 0, 0.08), 0 15px 15px -5px rgba(0, 0, 0, 0.03);
        }

        .auth-header-premium {
            padding: 32px 32px 20px;
            text-align: center;
            border-bottom: 1px solid #f1f5f9;
        }

        .auth-header-premium h2 {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.3px;
        }

        .auth-header-premium p {
            font-size: 14px;
            color: #64748b;
            margin-top: 4px;
        }

        .auth-body-premium {
            padding: 32px;
            flex: 1;
        }

        .auth-footer-premium {
            padding: 20px 32px;
            background: #f8fafc;
            border-top: 1px solid #f1f5f9;
            text-align: center;
            font-size: 13.5px;
            color: #64748b;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 13.5px;
            font-weight: 600;
            color: #334155;
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            padding: 11px 14px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            background: #ffffff;
            color: #0f172a;
            font-size: 14px;
            font-family: inherit;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: #22c55e;
            box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12);
        }

        .btn-primary {
            background: #22c55e;
            color: #ffffff;
            border: none;
            padding: 12px 24px;
            font-size: 14.5px;
            font-weight: 600;
            border-radius: 10px;
            width: 100%;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px rgba(34, 197, 94, 0.2);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary:hover {
            background: #16a34a;
            box-shadow: 0 6px 20px rgba(34, 197, 94, 0.35);
            transform: translateY(-1px);
        }

        .form-error {
            color: #ef4444;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .form-hint {
            font-size: 12px;
            color: #64748b;
            margin-top: 6px;
        }

        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 13.5px;
            margin-bottom: 20px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .avatar-upload-zone {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            background: #f8fafc;
            border: 2px dashed #cbd5e1;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            margin: 0 auto 12px;
            position: relative;
            overflow: hidden;
            transition: all 0.2s ease;
        }
        
        .avatar-upload-zone:hover {
            border-color: #22c55e;
            background: #f0fdf4;
        }
        
        .avatar-upload-zone img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }
        
        .avatar-upload-zone .upload-icon {
            font-size: 24px;
            color: #94a3b8;
            pointer-events: none;
            transition: color 0.2s ease;
        }

        .avatar-upload-zone:hover .upload-icon {
            color: #22c55e;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    <div class="bg-blob-1"></div>
    <div class="bg-blob-2"></div>

    <div class="register-wrapper">
        <!-- Logo and brand at top center -->
        <div class="brand-header-center">
            <div class="brand-logo-icon">
                <i class="bi bi-houses"></i>
            </div>
            <div>
                <div class="brand-logo-name">Smart Cattle Farm</div>
                <div class="brand-logo-sub">Livestock & Ranch Operations Platform</div>
            </div>
        </div>

        <div class="auth-container-wrapper">
            <!-- Auth Form Card -->
            <div class="auth-card-premium">
                <div class="auth-header-premium">
                    <h2>Create Account</h2>
                    <p>Register a new operator or customer profile</p>
                </div>
                <div class="auth-body-premium">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle-fill" style="margin-top:2px"></i>
                            <div>@Html.ValidationSummary(false)</div>
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Register" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <!-- Profile Photo Upload -->
                        <div style="text-align:center;margin-bottom:24px">
                            <label class="form-label" style="text-align:center; margin-bottom:8px">
                                Profile Photo (optional)
                            </label>
                            <div class="avatar-upload-zone" id="avatarZone" onclick="document.getElementById('ProfileImage').click()" title="Click to upload photo">
                                <span class="upload-icon" id="uploadIcon">📷</span>
                                <img id="avatarPreview" style="display:none" alt="Preview" />
                            </div>
                            <input type="file" name="ProfileImage" id="ProfileImage" accept=".jpg,.jpeg,.png,.webp" style="display:none" onchange="previewAvatar(this)" />
                            <div style="font-size:11px;color:#64748b">JPG, PNG, WEBP · Max 5MB</div>
                        </div>

                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                            <div class="form-group" style="grid-column:1/-1">
                                <label class="form-label">Full Name *</label>
                                <input asp-for="FullName" class="form-control" placeholder="e.g. Rahman Hossain" required />
                                <span asp-validation-for="FullName" class="form-error"></span>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Username *</label>
                                <input asp-for="Username" class="form-control" placeholder="your_username" required />
                                <span asp-validation-for="Username" class="form-error"></span>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Phone</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="+8801XXXXXXXXX" />
                            </div>
                            <div class="form-group" style="grid-column:1/-1">
                                <label class="form-label">Email Address *</label>
                                <input asp-for="Email" class="form-control" placeholder="you@example.com" type="email" required />
                                <span asp-validation-for="Email" class="form-error"></span>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Password *</label>
                                <input asp-for="Password" class="form-control" placeholder="••••••••" type="password" required />
                                <span asp-validation-for="Password" class="form-error"></span>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Confirm Password *</label>
                                <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" type="password" required />
                                <span asp-validation-for="ConfirmPassword" class="form-error"></span>
                            </div>
                            <div class="form-group" style="grid-column:1/-1">
                                <label class="form-label">Account Type</label>
                                <select asp-for="Role" class="form-control">
                                    <option value="User">👤 Customer / General User</option>
                                    <option value="Owner">🏡 Farm Owner</option>
                                    <option value="Worker">👷 Farm Worker</option>
                                    <option value="Doctor">👨‍⚕️ Veterinarian</option>
                                </select>
                                <div class="form-hint">Farm Owners can register and manage multiple farms.</div>
                            </div>
                        </div>

                        <div style="margin:20px 0">
                            <label style="display:flex;align-items:flex-start;gap:8px;font-size:12.5px;color:#475569;cursor:pointer;line-height:1.5">
                                <input type="checkbox" required style="accent-color:#22c55e;margin-top:3px;flex-shrink:0;width:16px;height:16px" />
                                <span>I agree to the <a href="#" style="color:#22c55e;text-decoration:none;font-weight:600">Terms of Service</a> and <a href="#" style="color:#22c55e;text-decoration:none;font-weight:600">Privacy Policy</a></span>
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-person-plus-fill"></i> Create Account
                        </button>
                    </form>
                </div>
                <div class="auth-footer-premium">
                    Already have an account? 
                    <a href="/Account/Login" style="font-weight:700;color:#22c55e;text-decoration:none">Sign in &rarr;</a>
                </div>
            </div>
        </div>
    </div>

    <script>
    function previewAvatar(input) {
        if (!input.files[0]) return;
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('uploadIcon').style.display  = 'none';
            const img = document.getElementById('avatarPreview');
            img.src   = e.target.result;
            img.style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
    }
    </script>
</body>
</html>
