@{
    Layout = null;
    ViewData["Title"] = "Reset Password";
    var email = ViewBag.Email as string ?? "";
    var token = ViewBag.Token as string ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password — Smart Cattle Farm</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700;800&family=Barlow+Condensed:wght@500;600;700&family=Lora:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .strength-bar { height:6px; border-radius:4px; background:#E8E0D4; overflow:hidden; margin:8px 0; }
        .strength-fill { height:100%; border-radius:4px; transition:width .4s, background-color .4s; width:0; }
        .req-list { list-style:none; padding:0; margin:0; font-size:12px; }
        .req-list li { display:flex; align-items:center; gap:6px; padding:2px 0; color:#6B6B66; transition:color .2s; }
        .req-list li.ok { color:#2D5A3D; }
        .req-list li i { font-size:13px; }
    </style>
</head>
<body>
<div class="auth-page">
    <div class="auth-card" style="max-width:440px;animation:fadeInUp .5s ease both">
        <div class="auth-header">
            <div class="auth-logo">🔐</div>
            <h1>Smart Cattle Farm</h1>
            <p>Set your new password</p>
        </div>

        <div class="auth-body">
            <h2 style="font-size:22px;font-weight:700;margin-bottom:16px">New Password</h2>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@ViewBag.Error</span>
                </div>
            }

            <form method="post" asp-action="ResetPassword" asp-controller="Account" id="resetForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@email" />
                <input type="hidden" name="token" value="@token" />

                <div class="form-group">
                    <label class="form-label" for="newPassword">New Password</label>
                    <div class="input-group">
                        <input type="password" name="newPassword" id="newPassword" class="form-control"
                               placeholder="••••••••" autocomplete="new-password" oninput="checkStrength()" required />
                        <div class="input-group-append">
                            <button type="button" class="btn btn-outline" onclick="togglePwd('newPassword','icon1')">
                                <i class="bi bi-eye" id="icon1"></i>
                            </button>
                        </div>
                    </div>
                    <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                    <div style="font-size:11px;font-weight:600;color:#6B6B66;margin-bottom:8px" id="strengthLabel">Strength</div>
                    <ul class="req-list" id="reqList">
                        <li id="req-len"><i class="bi bi-circle"></i> At least 8 characters</li>
                        <li id="req-upper"><i class="bi bi-circle"></i> One uppercase letter</li>
                        <li id="req-num"><i class="bi bi-circle"></i> One number</li>
                        <li id="req-special"><i class="bi bi-circle"></i> One special character (!&#64;#$%^&amp;*)</li>
                    </ul>
                </div>

                <div class="form-group" style="margin-top:16px">
                    <label class="form-label" for="confirmPassword">Confirm Password</label>
                    <div class="input-group">
                        <input type="password" name="confirmPassword" id="confirmPassword" class="form-control"
                               placeholder="••••••••" autocomplete="new-password" oninput="checkMatch()" required />
                        <div class="input-group-append">
                            <button type="button" class="btn btn-outline" onclick="togglePwd('confirmPassword','icon2')">
                                <i class="bi bi-eye" id="icon2"></i>
                            </button>
                        </div>
                    </div>
                    <div id="matchMsg" style="font-size:12px;margin-top:4px"></div>
                </div>

                <button type="submit" id="submitBtn" class="btn btn-primary w-100 btn-lg" disabled style="margin-top:16px">
                    <i class="bi bi-lock-fill"></i> Reset Password
                </button>
            </form>
        </div>
    </div>
</div>
<script>
function togglePwd(id, iconId) {
    const inp  = document.getElementById(id);
    const icon = document.getElementById(iconId);
    inp.type = inp.type === 'password' ? 'text' : 'password';
    icon.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
}

let strengthOk = false, matchOk = false;

function checkStrength() {
    const v = document.getElementById('newPassword').value;
    const reqs = {
        'req-len':     v.length >= 8,
        'req-upper':   /[A-Z]/.test(v),
        'req-num':     /[0-9]/.test(v),
        'req-special': /[!\x40#$%^&*]/.test(v)

    };
    let score = Object.values(reqs).filter(Boolean).length;
    Object.entries(reqs).forEach(([id, ok]) => {
        const li = document.getElementById(id);
        li.className = ok ? 'ok' : '';
        li.querySelector('i').className = ok ? 'bi bi-check-circle-fill' : 'bi bi-circle';
    });
    const fill  = document.getElementById('strengthFill');
    const label = document.getElementById('strengthLabel');
    const colors = ['','#ef4444','#f59e0b','#f59e0b','#10b981'];
    const labels = ['','Weak','Fair','Good','Strong'];
    fill.style.width = `${score * 25}%`;
    fill.style.backgroundColor = colors[score] || '#ef4444';
    label.textContent = labels[score] || '';
    label.style.color = colors[score] || '#6B6B66';
    strengthOk = score === 4;
    checkMatch();
}

function checkMatch() {
    const p1 = document.getElementById('newPassword').value;
    const p2 = document.getElementById('confirmPassword').value;
    const msg = document.getElementById('matchMsg');
    if (!p2) { msg.textContent = ''; matchOk = false; }
    else if (p1 === p2) { msg.textContent = '✓ Passwords match'; msg.style.color = '#2D5A3D'; matchOk = true; }
    else { msg.textContent = '✗ Passwords do not match'; msg.style.color = '#ef4444'; matchOk = false; }
    document.getElementById('submitBtn').disabled = !(strengthOk && matchOk);
}
</script>
</body>
</html>
