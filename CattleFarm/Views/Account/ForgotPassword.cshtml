@model CattleFarm.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password — Smart Cattle Farm</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@800&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            font-family: 'DM Sans', sans-serif;
            background-color: #f8fafc;
            background-image: 
                linear-gradient(rgba(34, 197, 94, 0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(34, 197, 94, 0.04) 1px, transparent 1px);
            background-size: 32px 32px;
            color: #0f172a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            margin: 0;
            position: relative;
            overflow-x: hidden;
        }

        .bg-blob-1 {
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(34, 197, 94, 0.08) 0%, transparent 70%);
            top: -200px;
            left: -150px;
            pointer-events: none;
            z-index: 1;
        }

        .bg-blob-2 {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.06) 0%, transparent 70%);
            bottom: -250px;
            right: -150px;
            pointer-events: none;
            z-index: 1;
        }

        .login-wrapper {
            width: 100%;
            max-width: 960px;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 32px;
            animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .brand-header-center {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            text-align: center;
        }

        .brand-logo-icon {
            width: 52px;
            height: 52px;
            background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            font-size: 26px;
            box-shadow: 0 10px 20px -5px rgba(34, 197, 94, 0.3);
        }

        .brand-logo-name {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.5px;
        }

        .brand-logo-sub {
            font-size: 14px;
            color: #64748b;
            font-weight: 500;
            margin-top: -4px;
        }

        .auth-card-premium {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
            width: 100%;
            max-width: 440px;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .auth-header-premium {
            padding: 32px 32px 20px;
            text-align: center;
            border-bottom: 1px solid #f1f5f9;
        }

        .auth-header-premium h2 {
            font-family: 'Bricolage Grotesque', sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.3px;
        }

        .auth-header-premium p {
            font-size: 14px;
            color: #64748b;
            margin-top: 4px;
        }

        .auth-body-premium {
            padding: 32px;
        }

        .auth-footer-premium {
            padding: 20px 32px;
            background: #f8fafc;
            border-top: 1px solid #f1f5f9;
            text-align: center;
            font-size: 13.5px;
            color: #64748b;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 13.5px;
            font-weight: 600;
            color: #334155;
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            padding: 11px 14px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            background: #ffffff;
            color: #0f172a;
            font-size: 14px;
            font-family: inherit;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: #22c55e;
            box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12);
        }

        .btn-primary {
            background: #22c55e;
            color: #ffffff;
            border: none;
            padding: 12px 24px;
            font-size: 14.5px;
            font-weight: 600;
            border-radius: 10px;
            width: 100%;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px rgba(34, 197, 94, 0.2);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary:hover {
            background: #16a34a;
            box-shadow: 0 6px 20px rgba(34, 197, 94, 0.35);
            transform: translateY(-1px);
        }

        .form-error {
            color: #ef4444;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 13.5px;
            margin-bottom: 20px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    <div class="bg-blob-1"></div>
    <div class="bg-blob-2"></div>

    <div class="login-wrapper">
        <div class="brand-header-center">
            <div class="brand-logo-icon">
                <i class="bi bi-houses"></i>
            </div>
            <div>
                <div class="brand-logo-name">Smart Cattle Farm</div>
                <div class="brand-logo-sub">Livestock & Ranch Operations Platform</div>
            </div>
        </div>

        <div class="auth-card-premium">
            <div class="auth-header-premium">
                <h2>Reset Your Password</h2>
                <p>Enter your email and we'll send you a password reset link.</p>
            </div>
            <div class="auth-body-premium">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle-fill" style="margin-top:2px"></i>
                        <span>@Html.ValidationSummary()</span>
                    </div>
                }

                <form asp-controller="Account" asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label class="form-label" for="Email">Email Address</label>
                        <input asp-for="Email" id="Email" class="form-control" placeholder="you@example.com" type="email" autofocus autocomplete="email" />
                        <span asp-validation-for="Email" class="form-error"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-envelope-at"></i> Send Reset Link
                    </button>
                </form>
            </div>
            <div class="auth-footer-premium">
                Remember your password?
                <a href="/Account/Login" style="font-weight:700;color:#22c55e;text-decoration:none;">Back to Sign In &rarr;</a>
            </div>
        </div>
    </div>
</body>
</html>
