@model CattleFarm.ViewModels.AttendanceEditViewModel
@{
    ViewData["Title"] = "Edit Attendance";
}

<div class="page-header">
    <div>
        <h1 class="page-title">✏️ Edit Attendance</h1>
        <p class="page-subtitle">Update the attendance record for this worker</p>
    </div>
    <a href="/Attendance" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Back to Records</a>
</div>

<div style="max-width:560px">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="WorkerId" />

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">📋 Attendance Details</h3>
            </div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:18px">

                <div class="form-group">
                    <label class="form-label">Worker ID</label>
                    <input value="@Model.WorkerId" class="form-control" readonly disabled
                           style="background:var(--bg);color:var(--text-muted)" />
                </div>

                <div class="form-group">
                    <label class="form-label">Attendance Date *</label>
                    <input asp-for="Date" type="date" class="form-control"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="Date" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Status *</label>
                    <select asp-for="Status" class="form-control" id="editStatusSelect"
                            onchange="updateStatusStyle(this)">
                        @{var raw = Model.Notes ?? Model.Status.ToString();}
                        <option value="Present" selected="@(raw == "Present" ? "selected" : null)">✔ Present</option>
                        <option value="Absent"  selected="@(raw == "Absent"  ? "selected" : null)">✘ Absent</option>
                        <option value="Late"    selected="@(raw == "Late"    ? "selected" : null)">⏱ Late</option>
                    </select>
                    <span asp-validation-for="Status" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"
                              placeholder="Optional notes about this attendance entry…"></textarea>
                </div>

                <div style="display:flex;gap:10px;padding-top:4px">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> Save Changes
                    </button>
                    <a href="/Attendance" class="btn btn-outline">Cancel</a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
